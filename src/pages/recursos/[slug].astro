---
import { sitePath } from "../../lib/site-paths";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAllVisualResources,
  getLessonsByVisualResourceId,
  type VisualResource,
  type VisualResourceLesson,
} from "../../lib/queries";

type Props = {
  resource: VisualResource;
  lessons: VisualResourceLesson[];
};

export function getStaticPaths() {
  const resources = getAllVisualResources().filter(
    (resource) => resource.status !== "Borrador",
  );

  return resources.map((resource) => ({
    params: { slug: resource.slug },
    props: {
      resource,
      lessons: getLessonsByVisualResourceId(resource.id),
    },
  }));
}

const { resource, lessons } = Astro.props;

const imageUrl = resource.url?.startsWith("/")
  ? sitePath(resource.url)
  : resource.url;

const description =
  resource.description ?? "Recurso visual en preparación editorial.";

const statusLabel =
  resource.status === "Idea"
    ? "Idea visual"
    : resource.status;
---

<BaseLayout
  title={resource.title}
  description={description}
>
  <main class="page visual-resource-page">
    <div class="breadcrumb">
      <a href={sitePath("/")}>Inicio</a> →
      <a href={sitePath("/recursos/")}>Recursos visuales</a> →
      {resource.title}
    </div>

    <section class="hero visual-resource-hero">
      <div class="visual-resource-hero-content">
        <p class="eyebrow">{resource.resource_type}</p>

        <h1>{resource.title}</h1>

        <p class="subtitle">
          {description}
        </p>

        <div class="actions">
          <a href={sitePath("/recursos/")} class="button secondary">
            Ver todos los recursos
          </a>

          {lessons[0] && (
            <a href={sitePath(`/lecciones/${lessons[0].slug}/`)} class="button">
              Ver lección relacionada
            </a>
          )}
        </div>
      </div>

      <aside class="visual-resource-status-card" aria-label="Estado del recurso">
        <span>Estado</span>
        <strong>{statusLabel}</strong>
        <p>
          {imageUrl
            ? "Este recurso ya tiene una imagen o archivo asociado."
            : "Este recurso está preparado como ficha editorial y espera imagen final."}
        </p>
      </aside>
    </section>

    <section class="visual-resource-preview-section">
      <div class="visual-resource-preview">
        {imageUrl ? (
          <img
            src={imageUrl}
            alt={resource.alt_text ?? resource.title}
          />
        ) : (
          <div class="visual-resource-placeholder">
            <span>{resource.resource_type}</span>
            <strong>{resource.title}</strong>
            <p>
              Imagen pendiente. Esta ficha ya puede conectarse con lecciones y
              funcionar como recurso visual editorial.
            </p>
          </div>
        )}
      </div>
    </section>

    <section class="route-overview">
      <article class="route-stat">
        <span>Tipo</span>
        <strong>{resource.resource_type}</strong>
      </article>

      <article class="route-stat">
        <span>Estado</span>
        <strong>{statusLabel}</strong>
      </article>

      <article class="route-stat">
        <span>Lecciones</span>
        <strong>{lessons.length}</strong>
      </article>

      <article class="route-stat">
        <span>Imagen</span>
        <strong>{imageUrl ? "Disponible" : "Pendiente"}</strong>
      </article>
    </section>

    {resource.alt_text && (
      <section class="section">
        <div class="section-header">
          <div>
            <p class="eyebrow">Accesibilidad</p>
            <h2>Texto alternativo</h2>
          </div>
        </div>

        <div class="content">
          <p>{resource.alt_text}</p>
        </div>
      </section>
    )}

    <section class="section">
      <div class="section-header">
        <div>
          <p class="eyebrow">Conexión didáctica</p>
          <h2>Lecciones relacionadas</h2>
        </div>

        <a href={sitePath("/lecciones/")} class="button secondary">
          Ver índice de lecciones
        </a>
      </div>

      {lessons.length > 0 ? (
        <ol class="lesson-track">
          {lessons.map((lesson) => (
            <li class="lesson-track-item">
              <a href={sitePath(`/lecciones/${lesson.slug}/`)} class="lesson-track-card">
                <span class="lesson-track-number">
                  {String(lesson.lesson_number).padStart(2, "0")}
                </span>

                <span class="lesson-track-content">
                  <strong>{lesson.title}</strong>

                  <small>
                    {lesson.main_idea ?? lesson.summary ?? "Resumen pendiente."}
                  </small>

                  <em>
                    {lesson.estimated_time ?? "7–10 minutos"} · {lesson.status}
                  </em>
                </span>
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <div class="content">
          <p>
            Este recurso todavía no está conectado con una lección publicada.
          </p>
        </div>
      )}
    </section>

    <section class="section visual-resource-footer-nav">
      <a href={sitePath("/recursos/")} class="button secondary">
        Volver a recursos visuales
      </a>

      <a href={sitePath("/explorar/")} class="button secondary">
        Explorar enciclopedia
      </a>

      <a href={sitePath("/rutas/panorama-visual-de-la-biblia/")} class="button">
        Ruta principal
      </a>
    </section>
  </main>
</BaseLayout>

<style>
  .visual-resource-page,
  .visual-resource-page * {
    box-sizing: border-box;
  }

  .visual-resource-page {
    max-width: 100%;
    overflow-x: clip;
  }

  .visual-resource-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(230px, 320px);
    gap: 32px;
    align-items: end;
  }

  .visual-resource-hero-content,
  .visual-resource-status-card {
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  .visual-resource-hero-content h1,
  .visual-resource-hero-content .subtitle,
  .visual-resource-status-card strong,
  .visual-resource-status-card p,
  .visual-resource-placeholder strong,
  .visual-resource-placeholder p {
    max-width: 100%;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .visual-resource-status-card {
    display: grid;
    gap: 10px;
    padding: 24px;
    border: 1px solid #eadcc4;
    border-radius: 24px;
    background: white;
    box-shadow: 0 18px 42px rgba(45, 36, 24, 0.1);
  }

  .visual-resource-status-card span {
    color: #8a5a2b;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .visual-resource-status-card strong {
    color: #2d2418;
    font-size: 1.6rem;
    line-height: 1.15;
  }

  .visual-resource-status-card p {
    margin: 0;
    color: #6a5c4d;
    line-height: 1.7;
  }

  .visual-resource-preview-section {
    margin-top: 24px;
  }

  .visual-resource-preview {
    overflow: hidden;
    border: 1px solid #eadcc4;
    border-radius: 28px;
    background:
      radial-gradient(circle at top left, rgba(233, 184, 114, 0.28), transparent 36%),
      linear-gradient(135deg, #fff2d8, #f7dfb7);
    box-shadow: 0 18px 42px rgba(45, 36, 24, 0.08);
  }

  .visual-resource-preview img {
    display: block;
    width: 100%;
    max-height: 640px;
    object-fit: cover;
  }

  .visual-resource-placeholder {
    display: grid;
    min-width: 0;
    min-height: 360px;
    place-items: center;
    gap: 14px;
    padding: 48px;
    text-align: center;
    contain: layout paint;
  }

  .visual-resource-placeholder span {
    max-width: 100%;
    color: #8a5a2b;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .visual-resource-placeholder strong {
    max-width: 720px;
    color: #2d2418;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 1;
  }

  .visual-resource-placeholder p {
    max-width: 640px;
    margin: 0;
    color: #6a5c4d;
    line-height: 1.8;
  }

  .visual-resource-footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  :global(html[data-theme="dark"]) .visual-resource-status-card,
  :global(html[data-theme="dark"]) .visual-resource-preview,
  :global(html[data-theme="dark"]) .visual-resource-footer-nav {
    background: #18110c;
    border-color: #3a2a1d;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.28);
  }

  :global(html[data-theme="dark"]) .visual-resource-preview {
    background:
      radial-gradient(circle at top left, rgba(233, 184, 114, 0.18), transparent 36%),
      linear-gradient(135deg, #2a1c11, #3a2a1d);
  }

  :global(html[data-theme="dark"]) .visual-resource-status-card span,
  :global(html[data-theme="dark"]) .visual-resource-placeholder span {
    color: #e9b872;
  }

  :global(html[data-theme="dark"]) .visual-resource-status-card strong,
  :global(html[data-theme="dark"]) .visual-resource-placeholder strong {
    color: #fff5e8;
  }

  :global(html[data-theme="dark"]) .visual-resource-status-card p,
  :global(html[data-theme="dark"]) .visual-resource-placeholder p {
    color: #d8c8b6;
  }

  @media (max-width: 860px) {
    .visual-resource-hero {
      grid-template-columns: 1fr;
    }

    .visual-resource-placeholder {
      min-height: 280px;
      padding: 32px 22px;
    }
  }

  @media (max-width: 420px) {
    .visual-resource-placeholder {
      min-height: 260px;
      padding: 28px 20px;
    }

    .visual-resource-placeholder strong {
      font-size: clamp(1.7rem, 10vw, 2.6rem);
    }
  }
</style>