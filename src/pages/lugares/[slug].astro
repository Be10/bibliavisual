---
import { sitePath } from "../../lib/site-paths";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAllPlaces,
  getEventsByPlaceId,
  getLessonsByPlaceId,
  type Event,
  type Lesson,
  type Place,
} from "../../lib/queries";

type Props = {
  place: Place;
  events: Event[];
  lessons: Lesson[];
};

export function getStaticPaths() {
  const places = getAllPlaces();

  return places
    .filter((place) => place.status !== "Borrador")
    .map((place) => ({
      params: { slug: place.slug },
      props: {
        place,
        events: getEventsByPlaceId(place.id),
        lessons: getLessonsByPlaceId(place.id),
      },
    }));
}

const { place, events, lessons } = Astro.props as Props;

const hasCoordinates = place.latitude !== null && place.longitude !== null;
const coordinatesLabel = hasCoordinates
  ? `${place.latitude}, ${place.longitude}`
  : "Pendiente";

const certaintyLabel = place.geographical_certainty ?? "Pendiente";
const placeTypeLabel = place.place_type ?? "Lugar bíblico";
const summaryLabel = place.summary ?? "Descripción pendiente.";
---

<BaseLayout
  title={place.name}
  description={place.summary ?? "Lugar de la Enciclopedia Bíblica Visual."}
>
  <main class="page">
    <div class="breadcrumb">
      <a href={sitePath("/")}>Inicio</a> →
      <a href={sitePath("/lugares/")}>Lugares</a> →
      {place.name}
    </div>

    <section class="hero place-hero">
      <div class="place-hero-content">
        <p class="eyebrow">{placeTypeLabel}</p>

        <h1>{place.name}</h1>

        <p class="subtitle">
          {summaryLabel}
        </p>

        <div class="actions">
          {hasCoordinates ? (
            <a href={sitePath(`/mapa/?lugar=${place.slug}`)} class="button">
              Ver en el mapa
            </a>
          ) : (
            <a href={sitePath("/mapa/")} class="button secondary">
              Ver mapa general
            </a>
          )}

          <a href={sitePath("/lugares/")} class="button secondary">
            Todos los lugares
          </a>
        </div>
      </div>

      <aside class="place-hero-card" aria-label="Resumen rápido del lugar">
        <span>{placeTypeLabel}</span>
        <strong>{place.name}</strong>
        <p>{certaintyLabel}</p>
      </aside>
    </section>

    <section class="place-meta-grid" aria-label="Datos rápidos del lugar">
      <article class="place-meta-card">
        <span>Tipo</span>
        <strong>{placeTypeLabel}</strong>
      </article>

      <article class="place-meta-card">
        <span>Certeza geográfica</span>
        <strong>{certaintyLabel}</strong>
      </article>

      <article class="place-meta-card">
        <span>Coordenadas</span>
        <strong>{coordinatesLabel}</strong>
      </article>

      <article class="place-meta-card">
        <span>Estado editorial</span>
        <strong>{place.status}</strong>
      </article>
    </section>

    <section class="section place-map-panel">
      <div class="section-header">
        <div>
          <p class="eyebrow">Ubicación</p>
          <h2>Mapa del lugar</h2>
        </div>

        {hasCoordinates && (
          <a href={sitePath(`/mapa/?lugar=${place.slug}`)} class="button secondary">
            Abrir mapa enfocado
          </a>
        )}
      </div>

      {hasCoordinates ? (
        <div class="place-map-preview">
          <div>
            <strong>{place.name} en el mapa bíblico</strong>
            <p>
              Este lugar tiene coordenadas registradas. Puedes abrirlo en el mapa
              bíblico con el marcador centrado y el popup enfocado en este lugar.
            </p>
          </div>

          <a href={sitePath(`/mapa/?lugar=${place.slug}`)} class="place-map-link">
            Ver {place.name} en el mapa →
          </a>
        </div>
      ) : (
        <div class="place-empty-map">
          <strong>Coordenadas pendientes</strong>
          <p>
            Este lugar todavía no tiene coordenadas definidas. Puede tratarse de
            una ubicación incierta, simbólica o pendiente de investigación editorial.
          </p>
        </div>
      )}
    </section>

    <section class="section place-importance-section">
      <div class="section-header">
        <div>
          <p class="eyebrow">Síntesis</p>
          <h2>Importancia bíblica</h2>
        </div>
      </div>

      <div class="place-importance-card">
        <p>{summaryLabel}</p>
      </div>
    </section>

    {events.length > 0 ? (
      <section class="section place-events-section">
        <div class="section-header">
          <div>
            <p class="eyebrow">Historia bíblica</p>
            <h2>Eventos relacionados</h2>
          </div>

          <span class="section-count">
            {events.length} {events.length === 1 ? "evento" : "eventos"}
          </span>
        </div>

        <div class="place-events-grid">
          {events.map((event) => (
            <a href={sitePath(`/eventos/${event.slug}/`)} class="place-event-card">
              <span>{event.approximate_date ?? event.biblical_period ?? "Evento bíblico"}</span>
              <strong>{event.title}</strong>

              {event.summary && (
                <small>{event.summary}</small>
              )}
            </a>
          ))}
        </div>
      </section>
    ) : (
      <section class="section place-empty-section">
        <p class="eyebrow">Historia bíblica</p>
        <h2>Eventos relacionados</h2>
        <p>
          Todavía no hay eventos relacionados registrados para este lugar.
        </p>
      </section>
    )}

    {lessons.length > 0 ? (
      <section class="section place-lessons-section">
        <div class="section-header">
          <div>
            <p class="eyebrow">Recorrido guiado</p>
            <h2>Lecciones relacionadas</h2>
          </div>

          <span class="section-count">
            {lessons.length} {lessons.length === 1 ? "lección" : "lecciones"}
          </span>
        </div>

        <div class="place-lessons-grid">
          {lessons.map((lesson) => (
            <a href={sitePath(`/lecciones/${lesson.slug}/`)} class="place-lesson-card">
              <span>Lección {lesson.lesson_number}</span>
              <strong>{lesson.title}</strong>

              {lesson.main_idea && (
                <small>{lesson.main_idea}</small>
              )}
            </a>
          ))}
        </div>
      </section>
    ) : (
      <section class="section place-empty-section">
        <p class="eyebrow">Recorrido guiado</p>
        <h2>Lecciones relacionadas</h2>
        <p>
          Todavía no hay lecciones relacionadas registradas para este lugar.
        </p>
      </section>
    )}
  </main>
</BaseLayout>