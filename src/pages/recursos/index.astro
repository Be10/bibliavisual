---
import { sitePath } from "../../lib/site-paths";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAllEvents,
  getAllGlossaryTerms,
  getAllPassages,
  getAllPeople,
  getAllPlaces,
  getAllTopics,
  getAllVisualResources,
} from "../../lib/queries";

const eventsCount = getAllEvents().filter((item) => item.status !== "Borrador").length;
const placesCount = getAllPlaces().filter((item) => item.status !== "Borrador").length;
const peopleCount = getAllPeople().filter((item) => item.status !== "Borrador").length;
const topicsCount = getAllTopics().filter((item) => item.status !== "Borrador").length;
const glossaryCount = getAllGlossaryTerms().filter((item) => item.status !== "Borrador").length;
const passagesCount = getAllPassages().filter((item) => item.status !== "Borrador").length;

const visualResources = getAllVisualResources();

const visibleVisualResources = visualResources.filter(
  (resource) => resource.status !== "Borrador",
);

const visualResourceTypes = Array.from(
  new Set(visibleVisualResources.map((resource) => resource.resource_type)),
);

const visualResourcesWithImages = visibleVisualResources.filter(
  (resource) => Boolean(resource.url),
);

const ideaResources = visibleVisualResources.filter(
  (resource) => resource.status === "Idea",
);

function getResourceImageUrl(url: string | null) {
  if (!url) return null;

  return url.startsWith("/") ? sitePath(url) : url;
}

function truncateText(value: string | null, maxLength = 112) {
  const text = value?.trim() || "Recurso visual en preparación editorial.";

  if (text.length <= maxLength) {
    return text;
  }

  const trimmed = text.slice(0, maxLength).trim();
  const lastSpaceIndex = trimmed.lastIndexOf(" ");

  if (lastSpaceIndex <= 0) {
    return `${trimmed}...`;
  }

  return `${trimmed.slice(0, lastSpaceIndex)}...`;
}

function truncateTitle(value: string, maxLength = 62) {
  const title = value.trim();

  if (title.length <= maxLength) {
    return title;
  }

  const trimmed = title.slice(0, maxLength).trim();
  const lastSpaceIndex = trimmed.lastIndexOf(" ");

  if (lastSpaceIndex <= 0) {
    return `${trimmed}...`;
  }

  return `${trimmed.slice(0, lastSpaceIndex)}...`;
}

const platformResources = [
  {
    title: "Mapa bíblico",
    eyebrow: "Geografía",
    description:
      "Explora lugares bíblicos ubicados visualmente, con conexiones a eventos, pasajes y fichas individuales.",
    count: `${placesCount} lugares`,
    url: sitePath("/mapa/"),
    featured: true,
  },
  {
    title: "Línea de tiempo",
    eyebrow: "Cronología",
    description:
      "Recorre los eventos bíblicos en una secuencia narrativa para visualizar el desarrollo de la historia bíblica.",
    count: `${eventsCount} eventos`,
    url: sitePath("/linea-de-tiempo/"),
    featured: true,
  },
  {
    title: "Lugares bíblicos",
    eyebrow: "Ubicaciones",
    description:
      "Consulta ciudades, regiones, montes, ríos y espacios vinculados con la narrativa bíblica.",
    count: `${placesCount} lugares`,
    url: sitePath("/lugares/"),
    featured: false,
  },
  {
    title: "Eventos bíblicos",
    eyebrow: "Narrativa",
    description:
      "Conecta acontecimientos bíblicos con personas, lugares, temas, libros y pasajes relacionados.",
    count: `${eventsCount} eventos`,
    url: sitePath("/eventos/"),
    featured: false,
  },
];

const editorialResources = [
  {
    title: "Personajes",
    eyebrow: "Biografías",
    description:
      "Explora personas bíblicas y sus conexiones con eventos, lugares, temas y lecciones.",
    count: `${peopleCount} personajes`,
    url: sitePath("/personajes/"),
  },
  {
    title: "Temas",
    eyebrow: "Conceptos",
    description:
      "Revisa temas bíblicos principales y su relación con pasajes, eventos y lecciones.",
    count: `${topicsCount} temas`,
    url: sitePath("/temas/"),
  },
  {
    title: "Glosario",
    eyebrow: "Términos",
    description:
      "Consulta definiciones claras de palabras importantes para comprender mejor el contenido bíblico.",
    count: `${glossaryCount} términos`,
    url: sitePath("/glosario/"),
  },
  {
    title: "Pasajes conectados",
    eyebrow: "Referencias",
    description:
      "Accede a pasajes bíblicos destacados y sus conexiones con libros, temas, eventos y lecciones.",
    count: `${passagesCount} pasajes`,
    url: sitePath("/pasajes/"),
  },
];
---

<BaseLayout
  title="Recursos visuales"
  description="Explora recursos visuales y editoriales de la Enciclopedia Bíblica Visual: mapa bíblico, línea de tiempo, infografías, esquemas, lugares, eventos, personajes, temas, glosario y pasajes."
>
  <main class="page resources-page">
    <div class="breadcrumb">
      <a href={sitePath("/")}>Inicio</a> → Recursos visuales
    </div>

    <section class="hero resources-hero">
      <div class="resources-hero-content">
        <p class="eyebrow">Recursos visuales</p>

        <h1>Ver la Biblia con claridad</h1>

        <p class="subtitle">
          Explora mapas, líneas de tiempo, infografías, esquemas y conexiones
          visuales que ayudan a estudiar la Biblia como una historia unificada.
        </p>

        <div class="actions">
          <a href={sitePath("/mapa/")} class="button">
            Abrir mapa bíblico
          </a>

          <a href={sitePath("/linea-de-tiempo/")} class="button secondary">
            Ver línea de tiempo
          </a>

          <a href={sitePath("/buscar/")} class="button secondary">
            Búsqueda avanzada
          </a>
        </div>
      </div>

      <aside class="resources-hero-card" aria-label="Resumen de recursos visuales">
        <span>Recursos visuales</span>
        <strong>{visibleVisualResources.length}</strong>
        <p>
          Ideas, esquemas, mapas e infografías conectadas a las lecciones
        </p>
      </aside>
    </section>

    <section class="resources-stats" aria-label="Resumen de recursos disponibles">
      <article class="resources-stat-card">
        <span>Visuales</span>
        <strong>{visibleVisualResources.length}</strong>
      </article>

      <article class="resources-stat-card">
        <span>Con imagen</span>
        <strong>{visualResourcesWithImages.length}</strong>
      </article>

      <article class="resources-stat-card">
        <span>Tipos</span>
        <strong>{visualResourceTypes.length}</strong>
      </article>

      <article class="resources-stat-card">
        <span>Ideas</span>
        <strong>{ideaResources.length}</strong>
      </article>
    </section>

    <section class="section resources-section">
      <div class="section-header">
        <div>
          <p class="eyebrow">Banco visual</p>
          <h2>Recursos visuales editoriales</h2>
        </div>

        <span class="section-count">
          {visibleVisualResources.length} recursos
        </span>
      </div>

      {visibleVisualResources.length > 0 ? (
        <div class="visual-resource-grid">
          {visibleVisualResources.map((resource) => {
            const imageUrl = getResourceImageUrl(resource.url);

            return (
              <a
                href={sitePath(`/recursos/${resource.slug}/`)}
                class:list={[
                  "visual-resource-card",
                  imageUrl ? "has-image" : "has-placeholder",
                ]}
              >
                <div class="visual-resource-media">
                  {imageUrl ? (
                    <img
                      src={imageUrl}
                      alt={resource.alt_text ?? resource.title}
                      loading="lazy"
                    />
                  ) : (
                    <div class="visual-resource-placeholder" aria-hidden="true">
                      <span>{resource.resource_type}</span>
                    </div>
                  )}
                </div>

                <div class="visual-resource-body">
                  <span>{resource.resource_type}</span>

                  <strong title={resource.title}>{truncateTitle(resource.title)}</strong>

                  <p>{truncateText(resource.description)}</p>

                  <small>{resource.status}</small>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="content">
          <p>
            Todavía no hay recursos visuales registrados.
          </p>
        </div>
      )}
    </section>

    <section class="section resources-section">
      <div class="section-header">
        <div>
          <p class="eyebrow">Visualización principal</p>
          <h2>Mapas y cronología</h2>
        </div>

        <span class="section-count">
          {platformResources.length} recursos
        </span>
      </div>

      <div class="resources-feature-grid">
        {platformResources.map((resource) => (
          <a
            href={resource.url}
            class:list={[
              "resources-card",
              resource.featured ? "is-featured" : "",
            ]}
          >
            <span>{resource.eyebrow}</span>
            <strong>{resource.title}</strong>
            <p>{resource.description}</p>
            <small>{resource.count}</small>
          </a>
        ))}
      </div>
    </section>

    <section class="section resources-section">
      <div class="section-header">
        <div>
          <p class="eyebrow">Conexiones editoriales</p>
          <h2>Recursos para explorar la red bíblica</h2>
        </div>

        <span class="section-count">
          {editorialResources.length} módulos
        </span>
      </div>

      <div class="resources-grid">
        {editorialResources.map((resource) => (
          <a href={resource.url} class="resources-card">
            <span>{resource.eyebrow}</span>
            <strong>{resource.title}</strong>
            <p>{resource.description}</p>
            <small>{resource.count}</small>
          </a>
        ))}
      </div>
    </section>

    <section class="section resources-footer-nav">
      <a href={sitePath("/explorar/")} class="button secondary">
        Ver centro de navegación
      </a>

      <a href={sitePath("/biblia/")} class="button secondary">
        Leer la Biblia
      </a>

      <a href={sitePath("/rutas/panorama-visual-de-la-biblia/")} class="button">
        Ruta principal
      </a>
    </section>
  </main>
</BaseLayout>

<style>
  .resources-page,
  .resources-page * {
    box-sizing: border-box;
  }

  .resources-page {
    max-width: 100%;
    overflow-x: clip;
  }

  .resources-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(230px, 320px);
    gap: 32px;
    align-items: end;
  }

  .resources-hero-content,
  .resources-hero-card {
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  .resources-hero-card,
  .resources-stat-card,
  .resources-card,
  .visual-resource-card {
    border: 1px solid #eadcc4;
    box-shadow: 0 14px 34px rgba(45, 36, 24, 0.05);
  }

  .resources-hero-card {
    display: grid;
    gap: 10px;
    padding: 24px;
    border-radius: 24px;
    background: white;
    box-shadow: 0 18px 42px rgba(45, 36, 24, 0.1);
  }

  .resources-hero-card span,
  .resources-stat-card span,
  .resources-card span,
  .visual-resource-body span,
  .visual-resource-placeholder span {
    display: block;
    max-width: 100%;
    color: #8a5a2b;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    line-height: 1.25;
    text-transform: uppercase;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .resources-hero-card strong {
    max-width: 100%;
    color: #2d2418;
    font-size: 3rem;
    line-height: 1;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .resources-hero-card p,
  .resources-card p,
  .visual-resource-body p {
    max-width: 100%;
    margin: 0;
    color: #6a5c4d;
    line-height: 1.7;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .resources-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-top: 24px;
  }

  .resources-stat-card {
    min-width: 0;
    padding: 22px;
    border-radius: 22px;
    background: white;
  }

  .resources-stat-card span {
    margin-bottom: 10px;
  }

  .resources-stat-card strong {
    display: block;
    max-width: 100%;
    color: #2d2418;
    font-size: 2rem;
    line-height: 1;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .visual-resource-grid,
  .resources-feature-grid,
  .resources-grid {
    display: grid;
    gap: 16px;
    min-width: 0;
  }

  .visual-resource-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: stretch;
  }

  .resources-feature-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .resources-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .visual-resource-card,
  .resources-card {
    min-width: 0;
    max-width: 100%;
    border-radius: 22px;
    background: #fffaf0;
    text-decoration: none;
  }

  .visual-resource-card {
    display: grid;
    grid-template-rows: 300px auto;
    min-height: 515px;
    overflow: hidden;
  }

  .resources-card {
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    gap: 10px;
    min-height: 220px;
    padding: 22px;
    overflow: hidden;
  }

  .visual-resource-card:hover,
  .resources-card:hover {
    border-color: #c8a982;
    box-shadow: 0 14px 30px rgba(45, 36, 24, 0.08);
  }

  .visual-resource-media {
    width: 100%;
    height: 300px;
    min-width: 0;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, rgba(233, 184, 114, 0.28), transparent 36%),
      linear-gradient(135deg, #fff2d8, #f7dfb7);
  }

  .visual-resource-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .visual-resource-placeholder {
    display: grid;
    width: 100%;
    height: 100%;
    min-width: 0;
    place-items: center;
    padding: 20px;
    text-align: center;
  }

  .visual-resource-body {
    display: grid;
    grid-template-rows: auto auto auto auto;
    gap: 10px;
    min-width: 0;
    max-width: 100%;
    padding: 22px 24px 24px;
    overflow: hidden;
  }

  .visual-resource-body strong,
  .resources-card strong {
    display: block;
    min-width: 0;
    max-width: 100%;
    overflow: visible;
    color: #2d2418;
    font-size: 1.15rem;
    line-height: 1.32;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .visual-resource-body p {
    display: block;
    min-width: 0;
    max-width: 100%;
    overflow: visible;
    line-height: 1.7;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .resources-card p {
    display: -webkit-box;
    overflow: hidden;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
  }

  .visual-resource-body small,
  .resources-card small {
    display: block;
    align-self: start;
    min-width: 0;
    max-width: 100%;
    padding-top: 2px;
    color: #5d3212;
    font-size: 0.84rem;
    font-weight: 900;
    line-height: 1.25;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .resources-card.is-featured {
    min-height: 240px;
    background: white;
  }

  .resources-footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  :global(html[data-theme="dark"]) .resources-hero-card,
  :global(html[data-theme="dark"]) .resources-stat-card,
  :global(html[data-theme="dark"]) .resources-section,
  :global(html[data-theme="dark"]) .resources-footer-nav {
    background: #18110c;
    border-color: #3a2a1d;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.28);
  }

  :global(html[data-theme="dark"]) .resources-card,
  :global(html[data-theme="dark"]) .visual-resource-card {
    background: #21160e;
    border-color: #3a2a1d;
  }

  :global(html[data-theme="dark"]) .resources-card.is-featured {
    background: #18110c;
  }

  :global(html[data-theme="dark"]) .visual-resource-media {
    background:
      radial-gradient(circle at top left, rgba(233, 184, 114, 0.18), transparent 36%),
      linear-gradient(135deg, #2a1c11, #3a2a1d);
  }

  :global(html[data-theme="dark"]) .resources-hero-card span,
  :global(html[data-theme="dark"]) .resources-stat-card span,
  :global(html[data-theme="dark"]) .resources-card span,
  :global(html[data-theme="dark"]) .resources-card small,
  :global(html[data-theme="dark"]) .visual-resource-body span,
  :global(html[data-theme="dark"]) .visual-resource-body small,
  :global(html[data-theme="dark"]) .visual-resource-placeholder span {
    color: #e9b872;
  }

  :global(html[data-theme="dark"]) .resources-hero-card strong,
  :global(html[data-theme="dark"]) .resources-stat-card strong,
  :global(html[data-theme="dark"]) .resources-card strong,
  :global(html[data-theme="dark"]) .visual-resource-body strong {
    color: #fff5e8;
  }

  :global(html[data-theme="dark"]) .resources-hero-card p,
  :global(html[data-theme="dark"]) .resources-card p,
  :global(html[data-theme="dark"]) .visual-resource-body p {
    color: #d8c8b6;
  }

  @media (max-width: 960px) {
    .resources-hero,
    .resources-feature-grid {
      grid-template-columns: 1fr;
    }

    .visual-resource-grid,
    .resources-stats,
    .resources-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .resources-hero,
    .visual-resource-grid,
    .resources-stats,
    .resources-grid {
      grid-template-columns: 1fr;
    }

    .resources-card {
      min-height: auto;
    }

    .visual-resource-card {
      grid-template-rows: 225px auto;
      min-height: 455px;
      height: auto;
    }

    .visual-resource-media {
      height: 225px;
    }

    .visual-resource-body {
      padding: 20px 22px 24px;
    }

    .resources-footer-nav {
      align-items: flex-start;
    }
  }

  @media (max-width: 420px) {
    .visual-resource-card {
      grid-template-rows: 220px auto;
      min-height: 450px;
      height: auto;
    }

    .visual-resource-media {
      height: 220px;
    }

    .visual-resource-body {
      padding: 20px 20px 24px;
    }
  }

  @media (hover: none) and (pointer: coarse) {
    .visual-resource-card:hover,
    .resources-card:hover {
      border-color: #eadcc4;
      box-shadow: 0 14px 34px rgba(45, 36, 24, 0.05);
    }
  }
</style>