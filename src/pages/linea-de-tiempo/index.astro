---
import { sitePath } from "../../lib/site-paths";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllEvents, type Event } from "../../lib/queries";

const events = getAllEvents()
  .filter((event) => event.status !== "Borrador" && event.appears_on_timeline)
  .sort((a, b) => {
    const firstOrder = a.chronological_order ?? 999999;
    const secondOrder = b.chronological_order ?? 999999;

    return firstOrder - secondOrder || a.title.localeCompare(b.title, "es");
  });

const periods = Array.from(
  new Set(events.map((event) => event.biblical_period ?? "Período pendiente"))
);

const eventsWithDate = events.filter((event) => event.approximate_date).length;
const eventsWithMap = events.filter((event) => event.appears_on_map).length;

const eventsByPeriod = periods.map((period) => ({
  period,
  events: events.filter(
    (event) => (event.biblical_period ?? "Período pendiente") === period
  ),
}));

function getEventMeta(event: Event) {
  return [
    event.event_type,
    event.temporal_certainty ? `Certeza: ${event.temporal_certainty}` : null,
    event.appears_on_map ? "Disponible en mapa" : null,
  ].filter(Boolean);
}
---

<BaseLayout
  title="Línea de tiempo bíblica"
  description="Explora una línea de tiempo visual de eventos bíblicos principales, organizada por períodos, fechas aproximadas y conexiones narrativas."
>
  <main class="page timeline-page timeline-ready">
    <div class="breadcrumb">
      <a href={sitePath("/")}>Inicio</a> → Línea de tiempo
    </div>

    <section class="hero timeline-hero">
      <div class="timeline-hero-content">
        <p class="eyebrow">Panorama cronológico</p>

        <h1>Línea de tiempo bíblica</h1>

        <p class="subtitle">
          Recorre los eventos principales de la historia bíblica en orden narrativo.
          Esta vista conecta períodos, fechas aproximadas, lugares, personajes,
          temas y recursos visuales.
        </p>

        <div class="actions">
          <a href={sitePath("/eventos/")} class="button">
            Ver eventos bíblicos
          </a>

          <a href={sitePath("/recursos/")} class="button secondary">
            Recursos visuales
          </a>

          <a href={sitePath("/mapa/")} class="button secondary">
            Abrir mapa bíblico
          </a>
        </div>
      </div>

      <aside class="timeline-hero-card" aria-label="Resumen de la línea de tiempo">
        <span>Eventos en línea</span>
        <strong>{events.length}</strong>
        <p>
          {periods.length} períodos representados
        </p>
      </aside>
    </section>

    <section class="timeline-stats" aria-label="Resumen de eventos cronológicos">
      <article class="timeline-stat-card">
        <span>Eventos visibles</span>
        <strong>{events.length}</strong>
      </article>

      <article class="timeline-stat-card">
        <span>Períodos</span>
        <strong>{periods.length}</strong>
      </article>

      <article class="timeline-stat-card">
        <span>Con fecha</span>
        <strong>{eventsWithDate}</strong>
      </article>

      <article class="timeline-stat-card">
        <span>En mapa</span>
        <strong>{eventsWithMap}</strong>
      </article>
    </section>

    <section class="section timeline-section">
      <div class="section-header">
        <div>
          <p class="eyebrow">Secuencia narrativa</p>
          <h2>Eventos por período bíblico</h2>
        </div>

        <span class="section-count">
          {events.length} eventos
        </span>
      </div>

      {events.length > 0 ? (
        <div class="timeline-periods">
          {eventsByPeriod.map((group) => (
            <section class="timeline-period" aria-label={group.period}>
              <div class="timeline-period-header">
                <div>
                  <span>Período</span>
                  <h3>{group.period}</h3>
                </div>

                <strong>
                  {group.events.length} {group.events.length === 1 ? "evento" : "eventos"}
                </strong>
              </div>

              <div class="timeline-list">
                {group.events.map((event) => (
                  <article class="timeline-item">
                    <div class="timeline-marker" aria-hidden="true">
                      <span></span>
                    </div>

                    <a href={sitePath(`/eventos/${event.slug}/`)} class="timeline-card">
                      <div class="timeline-card-header">
                        <span class="timeline-date">
                          {event.approximate_date ?? "Fecha pendiente"}
                        </span>

                        {event.chronological_order && (
                          <span class="timeline-order">
                            #{event.chronological_order}
                          </span>
                        )}
                      </div>

                      <h4>{event.title}</h4>

                      <p>
                        {event.summary ?? "Resumen pendiente."}
                      </p>

                      <div class="timeline-meta">
                        {getEventMeta(event).map((item) => (
                          <span>{item}</span>
                        ))}
                      </div>
                    </a>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>
      ) : (
        <div class="content">
          <p>
            Todavía no hay eventos publicados para la línea de tiempo.
          </p>
        </div>
      )}
    </section>

    <section class="section timeline-footer-nav">
      <a href={sitePath("/eventos/")} class="button">
        Explorar eventos
      </a>

      <a href={sitePath("/recursos/")} class="button secondary">
        Ver recursos visuales
      </a>

      <a href={sitePath("/explorar/")} class="button secondary">
        Centro de navegación
      </a>
    </section>
  </main>
</BaseLayout>

<style>
  .timeline-hero {
    display: grid;
    grid-template-columns: 1fr minmax(230px, 320px);
    gap: 32px;
    align-items: end;
  }

  .timeline-hero-content,
  .timeline-hero-card {
    position: relative;
    z-index: 1;
  }

  .timeline-hero-card,
  .timeline-stat-card,
  .timeline-period,
  .timeline-card {
    border: 1px solid #eadcc4;
    box-shadow: 0 14px 34px rgba(45, 36, 24, 0.05);
  }

  .timeline-hero-card {
    display: grid;
    gap: 10px;
    padding: 24px;
    border-radius: 24px;
    background: white;
    box-shadow: 0 18px 42px rgba(45, 36, 24, 0.1);
  }

  .timeline-hero-card span,
  .timeline-stat-card span,
  .timeline-period-header span,
  .timeline-date,
  .timeline-order,
  .timeline-meta span {
    color: #8a5a2b;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .timeline-hero-card strong {
    color: #2d2418;
    font-size: 3rem;
    line-height: 1;
  }

  .timeline-hero-card p,
  .timeline-card p {
    margin: 0;
    color: #6a5c4d;
    line-height: 1.65;
  }

  .timeline-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-top: 24px;
  }

  .timeline-stat-card {
    padding: 22px;
    border-radius: 22px;
    background: white;
  }

  .timeline-stat-card span {
    display: block;
    margin-bottom: 10px;
  }

  .timeline-stat-card strong {
    display: block;
    color: #2d2418;
    font-size: 2rem;
    line-height: 1;
  }

  .timeline-periods {
    display: grid;
    gap: 22px;
  }

  .timeline-period {
    display: grid;
    gap: 18px;
    padding: 22px;
    border-radius: 24px;
    background: #fffaf0;
  }

  .timeline-period-header {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
  }

  .timeline-period-header h3 {
    margin: 4px 0 0;
    color: #2d2418;
    font-size: 1.35rem;
    line-height: 1.25;
  }

  .timeline-period-header strong {
    display: inline-flex;
    min-height: 34px;
    max-width: 100%;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: white;
    border: 1px solid #eadcc4;
    color: #5d3212;
    font-size: 0.86rem;
    line-height: 1.2;
    white-space: normal;
    overflow-wrap: anywhere;
  }

  .timeline-list {
    position: relative;
    display: grid;
    gap: 14px;
  }

  .timeline-list::before {
    content: "";
    position: absolute;
    top: 12px;
    bottom: 12px;
    left: 13px;
    width: 2px;
    background: #eadcc4;
  }

  .timeline-item {
    position: relative;
    display: grid;
    grid-template-columns: 28px minmax(0, 1fr);
    gap: 14px;
  }

  .timeline-marker {
    position: relative;
    display: flex;
    justify-content: center;
    padding-top: 18px;
    z-index: 1;
  }

  .timeline-marker span {
    width: 12px;
    height: 12px;
    border-radius: 999px;
    background: #8a5a2b;
    border: 3px solid #fffaf0;
    box-shadow: 0 0 0 1px #c8a982;
  }

  .timeline-card {
    display: grid;
    gap: 10px;
    min-width: 0;
    padding: 18px;
    border-radius: 20px;
    background: white;
    text-decoration: none;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .timeline-card:hover {
    transform: translateY(-2px);
    border-color: #c8a982;
    box-shadow: 0 14px 30px rgba(45, 36, 24, 0.08);
  }

  .timeline-card-header {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
  }

  .timeline-date,
  .timeline-order,
  .timeline-meta span {
    display: inline-flex;
    min-height: 30px;
    max-width: 100%;
    align-items: center;
    padding: 7px 12px;
    border-radius: 18px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    line-height: 1.22;
    white-space: normal;
    overflow-wrap: anywhere;
  }

  .timeline-card h4 {
    margin: 0;
    color: #2d2418;
    font-size: 1.08rem;
    line-height: 1.3;
  }

  .timeline-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .timeline-footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  :global(html[data-theme="dark"]) .timeline-hero-card,
  :global(html[data-theme="dark"]) .timeline-stat-card,
  :global(html[data-theme="dark"]) .timeline-section,
  :global(html[data-theme="dark"]) .timeline-footer-nav {
    background: #18110c;
    border-color: #3a2a1d;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.28);
  }

  :global(html[data-theme="dark"]) .timeline-period,
  :global(html[data-theme="dark"]) .timeline-card {
    background: #21160e;
    border-color: #3a2a1d;
  }

  :global(html[data-theme="dark"]) .timeline-list::before {
    background: #4a3523;
  }

  :global(html[data-theme="dark"]) .timeline-marker span {
    background: #e9b872;
    border-color: #21160e;
    box-shadow: 0 0 0 1px #6c4c2f;
  }

  :global(html[data-theme="dark"]) .timeline-hero-card span,
  :global(html[data-theme="dark"]) .timeline-stat-card span,
  :global(html[data-theme="dark"]) .timeline-period-header span,
  :global(html[data-theme="dark"]) .timeline-date,
  :global(html[data-theme="dark"]) .timeline-order,
  :global(html[data-theme="dark"]) .timeline-meta span {
    color: #e9b872;
  }

  :global(html[data-theme="dark"]) .timeline-hero-card strong,
  :global(html[data-theme="dark"]) .timeline-stat-card strong,
  :global(html[data-theme="dark"]) .timeline-period-header h3,
  :global(html[data-theme="dark"]) .timeline-card h4 {
    color: #fff5e8;
  }

  :global(html[data-theme="dark"]) .timeline-hero-card p,
  :global(html[data-theme="dark"]) .timeline-card p {
    color: #d8c8b6;
  }

  :global(html[data-theme="dark"]) .timeline-period-header strong,
  :global(html[data-theme="dark"]) .timeline-date,
  :global(html[data-theme="dark"]) .timeline-order,
  :global(html[data-theme="dark"]) .timeline-meta span {
    background: #18110c;
    border-color: #3a2a1d;
    color: #e9b872;
  }

  @media (max-width: 960px) {
    .timeline-hero {
      grid-template-columns: 1fr;
    }

    .timeline-stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .timeline-stats {
      grid-template-columns: 1fr;
    }

    .timeline-hero-card,
    .timeline-stat-card,
    .timeline-period,
    .timeline-card {
      padding: 18px;
    }

    .timeline-period-header,
    .timeline-card-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .timeline-footer-nav {
      align-items: flex-start;
    }

    .timeline-card,
    .timeline-card-header,
    .timeline-meta,
    .timeline-date,
    .timeline-order,
    .timeline-meta span,
    .timeline-period-header strong {
      max-width: 100%;
      min-width: 0;
    }

    .timeline-date,
    .timeline-order,
    .timeline-meta span {
      width: fit-content;
      max-width: 100%;
    }

    .timeline-date,
    .timeline-order,
    .timeline-meta span {
      padding: 8px 12px;
      border-radius: 16px;
      line-height: 1.25;
      letter-spacing: 0.06em;
    }

    .timeline-date {
      max-width: min(100%, 220px);
    }

    .timeline-meta span {
      max-width: 100%;
    }

  }
</style>