---
import { sitePath } from "../../lib/site-paths";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildSearchIndex } from "../../lib/search-index";

const searchItems = buildSearchIndex();

const searchStats = [
  {
    label: "Lecciones",
    count: searchItems.filter((item) => item.type === "Lección").length,
  },
  {
    label: "Libros",
    count: searchItems.filter((item) => item.type === "Libro").length,
  },
  {
    label: "Pasajes",
    count: searchItems.filter((item) => item.type === "Pasaje").length,
  },
  {
    label: "Versículos",
    count: searchItems.filter((item) => item.type === "Versículo").length,
  },
];

const searchableTypes = Array.from(
  new Set(searchItems.map((item) => item.type))
);

type ExploreItem = {
  title: string;
  eyebrow: string;
  description: string;
  url: string;
};

const exploreItems: ExploreItem[] = [
  {
    title: "Libros",
    eyebrow: "Biblioteca bíblica",
    description: "Explora los libros de la Biblia por testamento, género y resumen editorial.",
    url: sitePath("/libros/"),
  },
  {
    title: "Temas",
    eyebrow: "Conceptos",
    description: "Revisa temas bíblicos conectados con lecciones, eventos y pasajes.",
    url: sitePath("/temas/"),
  },
  {
    title: "Glosario",
    eyebrow: "Términos",
    description: "Consulta definiciones breves de términos bíblicos importantes.",
    url: sitePath("/glosario/"),
  },
  {
    title: "Mapa",
    eyebrow: "Geografía bíblica",
    description: "Ubica visualmente lugares bíblicos registrados en el mapa.",
    url: sitePath("/mapa/"),
  },
  {
    title: "Personajes",
    eyebrow: "Biografías",
    description: "Explora personas bíblicas y sus conexiones narrativas.",
    url: sitePath("/personajes/"),
  },
  {
    title: "Eventos",
    eyebrow: "Narrativa",
    description: "Sigue acontecimientos bíblicos en orden narrativo e histórico.",
    url: sitePath("/eventos/"),
  },
  {
    title: "Lugares",
    eyebrow: "Ubicaciones",
    description: "Consulta ciudades, regiones, montes y lugares bíblicos.",
    url: sitePath("/lugares/"),
  },
  {
    title: "Pasajes",
    eyebrow: "Referencias",
    description: "Explora pasajes bíblicos destacados y sus conexiones.",
    url: sitePath("/pasajes/"),
  },
];

function getCountByType(type: string) {
  return searchItems.filter((item) => item.type === type).length;
}

function getExploreCount(item: ExploreItem) {
  const typeByTitle: Record<string, string> = {
    Libros: "Libro",
    Temas: "Tema",
    Glosario: "Glosario",
    Personajes: "Personaje",
    Eventos: "Evento",
    Lugares: "Lugar",
    Pasajes: "Pasaje",
  };

  if (item.title === "Mapa") {
    return getCountByType("Lugar");
  }

  const type = typeByTitle[item.title];

  return type ? getCountByType(type) : 0;
}
---

<BaseLayout
  title="Búsqueda avanzada"
  description="Busca libros, pasajes, lecciones, eventos, temas, personajes, lugares, términos del glosario y versículos bíblicos."
>
  <main class="page advanced-search-page">
    <div class="breadcrumb">
      <a href={sitePath("/")}>Inicio</a> → Búsqueda avanzada
    </div>

    <section class="hero advanced-search-hero">
      <div class="advanced-search-hero-content">
        <p class="eyebrow">Búsqueda avanzada</p>

        <h1>Buscar en la enciclopedia</h1>

        <p class="subtitle">
          Encuentra libros, pasajes, lecciones, eventos, temas, personajes, lugares,
          términos del glosario y versículos bíblicos desde un solo lugar.
        </p>

        <div class="actions advanced-search-hero-actions">
          <a href="#busqueda-avanzada" class="button">
            Buscar contenido
          </a>

          <a href={sitePath("/biblia/")} class="button secondary">
            Leer la Biblia
          </a>

          <a href={sitePath("/rutas/panorama-visual-de-la-biblia/")} class="button secondary">
            Ruta principal
          </a>
        </div>
      </div>

      <aside class="advanced-search-hero-card" aria-label="Resumen del índice de búsqueda">
        <span>Índice local</span>
        <strong>{searchItems.length}</strong>
        <p>
          {searchableTypes.length} tipos de contenido disponibles
        </p>
      </aside>
    </section>

    <section class="section search-section advanced-search-section" id="busqueda-avanzada">
      <div class="section-header">
        <div>
          <p class="eyebrow">Consulta rápida</p>
          <h2>Búsqueda avanzada</h2>
        </div>

        <span class="section-count">
          {searchItems.length} elementos
        </span>
      </div>

      <div class="search-panel enhanced-search-panel">
        <label class="search-label" for="search-input">
          Escribe una palabra, referencia, personaje, lugar o tema
        </label>

        <input
          id="search-input"
          class="search-input"
          type="search"
          placeholder="Busca: Jesús, Génesis, redención, Jerusalén, en el principio..."
          autocomplete="off"
        />
      </div>

      <div id="search-empty" class="search-empty enhanced-search-empty" hidden></div>

      <div
        id="search-filters"
        class="search-filters"
        aria-label="Filtros de búsqueda"
        hidden
      ></div>

      <div id="search-results-summary" class="search-results-summary" hidden></div>

      <div id="search-results" class="search-results enhanced-search-results"></div>

      <section class="advanced-explore-block" aria-label="Explorar por categoría">
        <div class="advanced-explore-header">
          <div>
            <p class="eyebrow">También puedes explorar</p>
            <h3>Explorar por categoría</h3>
          </div>

          <span>
            Recursos visuales y editoriales
          </span>
        </div>

        <div class="advanced-explore-grid">
          {exploreItems.map((item) => (
            <a href={item.url} class="advanced-explore-card">
              <span>{item.eyebrow}</span>
              <strong>{item.title}</strong>
              <p>{item.description}</p>

              <small>
                {getExploreCount(item)} {getExploreCount(item) === 1 ? "elemento" : "elementos"}
              </small>
            </a>
          ))}
        </div>
      </section>
    </section>

    <section class="search-stats" aria-label="Resumen del índice de búsqueda">
      {searchStats.map((stat) => (
        <article class="search-stat-card">
          <span>{stat.label}</span>
          <strong>{stat.count}</strong>
        </article>
      ))}
    </section>

    <script type="application/json" id="search-data" set:html={JSON.stringify(searchItems)} />
  </main>
</BaseLayout>

<script>
  import {
    SEARCH_FILTER_ORDER,
    getAvailableSearchFilters,
    getDisplaySearchResults,
    getSearchCounts,
    getSearchResults,
    normalizeSearchText,
  } from "../../lib/search-engine";

  const dataElement = document.getElementById("search-data");
  const input = document.getElementById("search-input");
  const resultsElement = document.getElementById("search-results");
  const emptyElement = document.getElementById("search-empty");
  const resultsSummaryElement = document.getElementById("search-results-summary");
  const filtersElement = document.getElementById("search-filters");

  const items = dataElement?.textContent
    ? JSON.parse(dataElement.textContent)
    : [];

  const initialParams = new URLSearchParams(window.location.search);
  const initialQuery = initialParams.get("q") ?? "";

  let activeSearchType = "Todos";
  let currentResults = [];

  function normalizeText(value) {
    return normalizeSearchText(value);
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  function updateUrl(value) {
    const url = new URL(window.location.href);

    if (normalizeText(value)) {
      url.searchParams.set("q", value);
    } else {
      url.searchParams.delete("q");
    }

    window.history.replaceState({}, "", url);
  }

  function getFilteredResults(results) {
    return getDisplaySearchResults(results, activeSearchType, 120);
  }

  function renderFilters(results) {
    if (!filtersElement) return;

    const counts = getSearchCounts(results);

    if (
      activeSearchType !== "Todos" &&
      !SEARCH_FILTER_ORDER.includes(activeSearchType)
    ) {
      activeSearchType = "Todos";
    }

    if (activeSearchType !== "Todos" && !counts[activeSearchType]) {
      activeSearchType = "Todos";
    }

    const filters = getAvailableSearchFilters(results);

    filtersElement.hidden = false;

    filtersElement.innerHTML = [
      `<button type="button" data-search-filter="Todos">Todos <span>${results.length}</span></button>`,
      ...filters.map(
        ({ type, count }) =>
          `<button type="button" data-search-filter="${escapeHtml(type)}">${escapeHtml(type)} <span>${count}</span></button>`
      ),
    ].join("");

    filtersElement
      .querySelectorAll("[data-search-filter]")
      .forEach((button) => {
        button.classList.toggle(
          "is-active",
          button.getAttribute("data-search-filter") === activeSearchType
        );

        button.addEventListener("click", () => {
          activeSearchType =
            button.getAttribute("data-search-filter") ?? "Todos";

          renderFilteredResults();
        });
      });
  }

  function renderResultCard(item) {
    return `
      <a href="${escapeHtml(item.url)}" class="search-result">
        <span class="search-result-type">${escapeHtml(item.type)}</span>
        <h3>${escapeHtml(item.title)}</h3>
        <p>${escapeHtml(item.summary)}</p>
      </a>
    `;
  }

  function renderFilteredResults() {
    if (!resultsElement || !resultsSummaryElement || !filtersElement) return;

    renderFilters(currentResults);

    const filteredResults = getFilteredResults(currentResults);
    const query = input?.value ?? "";

    resultsSummaryElement.hidden = false;
    resultsSummaryElement.textContent =
      activeSearchType === "Todos"
        ? `${currentResults.length} resultado${currentResults.length === 1 ? "" : "s"} para “${query}”`
        : `${filteredResults.length} resultado${filteredResults.length === 1 ? "" : "s"} en ${activeSearchType} para “${query}”`;

    resultsElement.innerHTML = filteredResults.map(renderResultCard).join("");
  }

  function renderResults(query) {
    const normalizedQuery = normalizeText(query);

    if (!resultsElement || !emptyElement || !resultsSummaryElement || !filtersElement) {
      return;
    }

    if (!normalizedQuery) {
      currentResults = [];
      activeSearchType = "Todos";
      resultsElement.innerHTML = "";
      filtersElement.innerHTML = "";
      filtersElement.hidden = true;
      resultsSummaryElement.hidden = true;
      resultsSummaryElement.textContent = "";
      emptyElement.hidden = true;
      emptyElement.textContent = "";
      emptyElement.style.display = "none";
      return;
    }

    const results = getSearchResults(items, query);

    currentResults = results;

    if (results.length === 0) {
      resultsElement.innerHTML = "";
      filtersElement.innerHTML = "";
      filtersElement.hidden = true;
      resultsSummaryElement.hidden = true;
      resultsSummaryElement.textContent = "";
      emptyElement.hidden = false;
      emptyElement.textContent = "No se encontraron resultados para esa búsqueda.";
      emptyElement.style.display = "block";
      return;
    }

    emptyElement.hidden = true;
    emptyElement.style.display = "none";
    renderFilteredResults();
  }

  input?.addEventListener("input", (event) => {
    const value = event.target.value;

    activeSearchType = "Todos";
    renderResults(value);
    updateUrl(value);
  });

  if (input && initialQuery) {
    input.value = initialQuery;
    renderResults(initialQuery);
    input.focus();
  }
</script>

<style>
  .advanced-search-hero {
    position: relative;
    display: grid;
    grid-template-columns: 1fr minmax(230px, 320px);
    gap: 32px;
    align-items: end;
    overflow: hidden;
  }

  .advanced-search-hero-content,
  .advanced-search-hero-card {
    position: relative;
    z-index: 1;
  }

  .advanced-search-hero-content {
    align-self: center;
  }

  .advanced-search-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
    max-width: 100%;
  }

  .advanced-search-hero-actions .button {
    box-sizing: border-box;
    flex: 0 1 auto;
    max-width: 100%;
    min-width: 0;
  }

  .advanced-search-hero-card,
  .search-stat-card,
  .search-result,
  .advanced-explore-card {
    border: 1px solid #eadcc4;
    box-shadow: 0 14px 34px rgba(45, 36, 24, 0.05);
  }

  .advanced-search-hero-card {
    display: grid;
    gap: 10px;
    padding: 24px;
    border-radius: 24px;
    background: white;
    box-shadow: 0 18px 42px rgba(45, 36, 24, 0.1);
  }

  .advanced-search-hero-card span,
  .search-stat-card span,
  .search-label,
  .search-result-type,
  .advanced-explore-card span,
  .advanced-explore-header span {
    color: #8a5a2b;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .advanced-search-hero-card strong {
    color: #2d2418;
    font-size: 3rem;
    line-height: 1;
  }

  .advanced-search-hero-card p,
  .search-result p,
  .advanced-explore-card p {
    margin: 0;
    color: #6a5c4d;
    line-height: 1.55;
  }

  .search-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-top: 24px;
  }

  .search-stat-card {
    padding: 22px;
    border-radius: 22px;
    background: white;
  }

  .search-stat-card span {
    display: block;
    margin-bottom: 10px;
  }

  .search-stat-card strong {
    display: block;
    color: #2d2418;
    font-size: 2rem;
    line-height: 1;
  }

  .advanced-search-section {
    margin-top: 24px;
  }

  .enhanced-search-panel {
    padding: 22px;
    border-radius: 24px;
    background: #fffaf0;
    border: 1px solid #eadcc4;
  }

  .search-label {
    display: block;
  }

  :global(.search-filters) {
    display: flex;
    gap: 8px;
    margin-top: 18px;
    overflow-x: auto;
    padding-bottom: 8px;
    scrollbar-width: thin;
    scrollbar-color: rgba(93, 50, 18, 0.34) transparent;
  }

  :global(.search-filters[hidden]) {
    display: none;
  }

  :global(.search-filters::-webkit-scrollbar) {
    height: 8px;
  }

  :global(.search-filters::-webkit-scrollbar-track) {
    background: transparent;
  }

  :global(.search-filters::-webkit-scrollbar-thumb) {
    border-radius: 999px;
    background: rgba(93, 50, 18, 0.34);
  }

  :global(.search-filters::-webkit-scrollbar-thumb:hover) {
    background: rgba(93, 50, 18, 0.48);
  }

  :global(.search-filters button) {
    display: inline-flex;
    flex: 0 0 auto;
    min-height: 32px;
    align-items: center;
    gap: 6px;
    padding: 0 11px;
    border: 1px solid #eadcc4;
    border-radius: 999px;
    background: #fffaf0;
    color: #5d3212;
    font: inherit;
    font-size: 0.82rem;
    font-weight: 900;
    line-height: 1;
    white-space: nowrap;
    cursor: pointer;
  }

  :global(.search-filters button span) {
    display: inline;
    font: inherit;
    font-weight: 900;
    line-height: 1;
  }

  :global(.search-filters button.is-active) {
    background: #5d3212;
    border-color: #5d3212;
    color: #fffaf0;
  }

  :global(.search-filters button:hover) {
    border-color: #c8a982;
    background: #fff7e8;
  }

  :global(.search-filters button.is-active:hover) {
    background: #5d3212;
    border-color: #5d3212;
    color: #fffaf0;
  }

  .advanced-explore-block {
    display: grid;
    gap: 16px;
    margin-top: 32px;
    padding: 20px;
    border-radius: 24px;
    background: #fffaf0;
    border: 1px solid #eadcc4;
  }

  .advanced-explore-header {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
  }

  .advanced-explore-header h3 {
    margin: 0;
    color: #2d2418;
    font-size: 1.28rem;
  }

  .advanced-explore-header .eyebrow {
    margin-bottom: 6px;
  }

  .advanced-explore-header span {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: white;
    border: 1px solid #eadcc4;
    white-space: nowrap;
  }

  .advanced-explore-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .advanced-explore-card {
    display: grid;
    gap: 8px;
    min-height: 170px;
    padding: 18px;
    border-radius: 20px;
    background: white;
    text-decoration: none;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .advanced-explore-card:hover {
    transform: translateY(-2px);
    border-color: #c8a982;
    box-shadow: 0 14px 30px rgba(45, 36, 24, 0.08);
  }

  .advanced-explore-card strong {
    color: #2d2418;
    font-size: 1.05rem;
    line-height: 1.25;
  }

  .advanced-explore-card small {
    align-self: end;
    color: #5d3212;
    font-size: 0.82rem;
    font-weight: 900;
  }

  .enhanced-search-empty {
    margin-top: 20px;
  }

  .search-results-summary {
    margin-top: 22px;
    color: #5d3212;
    font-weight: 900;
  }

  .enhanced-search-results {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 16px;
  }

  .search-result {
    display: grid;
    align-content: start;
    gap: 7px;
    min-height: 138px;
    padding: 15px 16px;
    border-radius: 18px;
    background: white;
    text-decoration: none;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .search-result:hover {
    transform: translateY(-2px);
    border-color: #c8a982;
    box-shadow: 0 14px 30px rgba(45, 36, 24, 0.08);
  }

  .search-result h3 {
    margin: 0;
    color: #2d2418;
    font-size: 1rem;
    line-height: 1.28;
  }

  .search-result p {
    display: -webkit-box;
    overflow: hidden;
    font-size: 0.94rem;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
  }

  .search-result-type {
    width: fit-content;
    margin-bottom: 2px;
    padding: 4px 9px;
    border-radius: 999px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
  }

  :global(html[data-theme="dark"]) .advanced-search-hero-card,
  :global(html[data-theme="dark"]) .search-stat-card,
  :global(html[data-theme="dark"]) .search-section {
    background: #18110c;
    border-color: #3a2a1d;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.28);
  }

  :global(html[data-theme="dark"]) .enhanced-search-panel,
  :global(html[data-theme="dark"]) .advanced-explore-block,
  :global(html[data-theme="dark"]) .search-result,
  :global(html[data-theme="dark"]) .advanced-explore-card {
    background: #21160e;
    border-color: #3a2a1d;
  }

  :global(html[data-theme="dark"]) .advanced-search-hero-card span,
  :global(html[data-theme="dark"]) .search-stat-card span,
  :global(html[data-theme="dark"]) .search-label,
  :global(html[data-theme="dark"]) .search-result-type,
  :global(html[data-theme="dark"]) .search-results-summary,
  :global(html[data-theme="dark"]) .advanced-explore-card span,
  :global(html[data-theme="dark"]) .advanced-explore-card small,
  :global(html[data-theme="dark"]) .advanced-explore-header span {
    color: #e9b872;
  }

  :global(html[data-theme="dark"]) .advanced-search-hero-card strong,
  :global(html[data-theme="dark"]) .search-stat-card strong,
  :global(html[data-theme="dark"]) .search-result h3,
  :global(html[data-theme="dark"]) .advanced-explore-header h3,
  :global(html[data-theme="dark"]) .advanced-explore-card strong {
    color: #fff5e8;
  }

  :global(html[data-theme="dark"]) .advanced-search-hero-card p,
  :global(html[data-theme="dark"]) .search-result p,
  :global(html[data-theme="dark"]) .advanced-explore-card p {
    color: #d8c8b6;
  }

  :global(html[data-theme="dark"]) .advanced-explore-header span,
  :global(html[data-theme="dark"]) .search-result-type {
    background: #18110c;
    border-color: #3a2a1d;
    color: #f3d6ad;
  }

  :global(html[data-theme="dark"] .search-filters) {
    scrollbar-color: rgba(233, 184, 114, 0.5) transparent;
  }

  :global(html[data-theme="dark"] .search-filters::-webkit-scrollbar-thumb) {
    background: rgba(233, 184, 114, 0.5);
  }

  :global(html[data-theme="dark"] .search-filters::-webkit-scrollbar-thumb:hover) {
    background: rgba(233, 184, 114, 0.68);
  }

  :global(html[data-theme="dark"] .search-filters button) {
    background: #21160e;
    border-color: #4a3523;
    color: #e9b872;
  }

  :global(html[data-theme="dark"] .search-filters button:hover) {
    background: #312113;
    border-color: #6c4c2f;
    color: #fff5e8;
  }

  :global(html[data-theme="dark"] .search-filters button.is-active),
  :global(html[data-theme="dark"] .search-filters button.is-active:hover) {
    background: #e9b872;
    border-color: #e9b872;
    color: #1b120b;
  }

  @media (max-width: 960px) {
    .advanced-search-hero {
      grid-template-columns: 1fr;
    }

    .search-stats,
    .advanced-explore-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .enhanced-search-results {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .search-stats,
    .advanced-explore-grid,
    .enhanced-search-results {
      grid-template-columns: 1fr;
    }

    .advanced-search-hero {
      overflow: hidden;
    }

    .advanced-search-hero-content {
      min-width: 0;
      max-width: 100%;
    }

    .advanced-search-hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      width: auto;
      max-width: 100%;
    }

    .advanced-search-hero-actions .button {
      box-sizing: border-box;
      width: auto;
      max-width: 100%;
      min-width: 0;
