---
import { sitePath } from "../../lib/site-paths";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAllRoutes,
  getLessonsByRouteId,
  type Route,
  type Lesson,
} from "../../lib/queries";

type Props = {
  route: Route;
  lessons: Lesson[];
};

export function getStaticPaths() {
  const routes = getAllRoutes();

  return routes.map((route) => ({
    params: { slug: route.slug },
    props: {
      route,
      lessons: getLessonsByRouteId(route.id),
    },
  }));
}

const { route, lessons } = Astro.props;
---

<BaseLayout
  title={route.title}
  description={route.description ?? "Ruta guiada para estudiar la Biblia visualmente."}
>
  <main class="page">
    <div class="breadcrumb">
      <a href={sitePath("/")}>Inicio</a> → Rutas → {route.title}
    </div>

    <section class="hero">
      <p class="eyebrow">Ruta · {lessons.length} lecciones</p>

      <h1>{route.title}</h1>

      <p class="subtitle">
        {route.description}
      </p>

      {lessons.length > 0 && (
        <div class="actions">
          <a href={sitePath(`/lecciones/${lessons[0].slug}/`)} class="button">
            Empezar lección 1
          </a>
        </div>
      )}
    </section>

    <section class="grid">
      <article class="card">
        <h2>Nivel</h2>
        <p>{route.level}</p>
      </article>

      <article class="card">
        <h2>Duración</h2>
        <p>{route.estimated_duration}</p>
      </article>

      <article class="card">
        <h2>Estado</h2>
        <p>{route.status}</p>
      </article>
    </section>

    <section class="section">
      <h2>Lecciones de la ruta</h2>

      <ol class="list">
        {lessons.map((lesson) => (
          <li>
            {lesson.status !== "Borrador" ? (
              <a href={sitePath(`/lecciones/${lesson.slug}/`)}>
                {lesson.title}
              </a>
            ) : (
              <span>{lesson.title} · próximamente</span>
            )}
          </li>
        ))}
      </ol>
    </section>
  </main>
</BaseLayout>