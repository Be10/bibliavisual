---
import { sitePath } from "../../lib/site-paths";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAllRoutes,
  getLessonsByRouteId,
  getBibleRefsByLessonId,
  getEventsByLessonId,
  getBooksByLessonId,
  getGlossaryByLessonId,
  getPeopleByLessonId,
  getPlacesByLessonId,
  getPointsByLessonId,
  getQuestionsByLessonId,
  getTopicsByLessonId,
  getPassagesByLessonId,
  getVisualResourcesByLessonId,
  type Event,
  type Book,
  type Lesson,
  type LessonBibleRef,
  type LessonPoint,
  type LessonQuestion,
  type RelatedItem,
  type Passage,
  type Route,
  type VisualResource,
} from "../../lib/queries";

type Props = {
  route: Route;
  lesson: Lesson;
  previousLesson: Lesson | null;
  nextLesson: Lesson | null;
  totalRouteLessons: number;
  bibleRefs: LessonBibleRef[];
  points: LessonPoint[];
  questions: LessonQuestion[];
  topics: RelatedItem[];
  people: RelatedItem[];
  places: RelatedItem[];
  glossary: RelatedItem[];
  events: Event[];
  books: Book[];
  passages: Passage[];
  visualResources: VisualResource[];
};

export function getStaticPaths() {
  const routes = getAllRoutes();

  return routes.flatMap((route) => {
    const publishedLessons = getLessonsByRouteId(route.id)
      .filter((lesson) => lesson.status !== "Borrador")
      .sort((a, b) => a.lesson_number - b.lesson_number);

    return publishedLessons.map((lesson, index) => ({
      params: { slug: lesson.slug },
      props: {
        route,
        lesson,
        previousLesson: publishedLessons[index - 1] ?? null,
        nextLesson: publishedLessons[index + 1] ?? null,
        totalRouteLessons: publishedLessons.length,
        bibleRefs: getBibleRefsByLessonId(lesson.id),
        points: getPointsByLessonId(lesson.id),
        questions: getQuestionsByLessonId(lesson.id),
        topics: getTopicsByLessonId(lesson.id),
        people: getPeopleByLessonId(lesson.id),
        places: getPlacesByLessonId(lesson.id),
        glossary: getGlossaryByLessonId(lesson.id),
        events: getEventsByLessonId(lesson.id),
        books: getBooksByLessonId(lesson.id),
        passages: getPassagesByLessonId(lesson.id),
        visualResources: getVisualResourcesByLessonId(lesson.id),
      },
    }));
  });
}

const {
  route,
  lesson,
  previousLesson,
  nextLesson,
  totalRouteLessons,
  bibleRefs,
  points,
  questions,
  topics,
  people,
  places,
  glossary,
  events,
  books,
  passages,
  visualResources,
} = Astro.props;

const progressPercent =
  totalRouteLessons > 0
    ? Math.round((lesson.lesson_number / totalRouteLessons) * 100)
    : 0;

const lessonStepLabel = `Lección ${lesson.lesson_number} de ${totalRouteLessons}`;
const routePath = `/rutas/${route.slug}/`;

function getVisualResourceImageUrl(url: string | null) {
  if (!url) return null;

  return url.startsWith("/") ? sitePath(url) : url;
}

function truncateVisualText(value: string | null, maxLength = 104) {
  const text = value?.trim() || "Recurso visual en preparación editorial.";

  if (text.length <= maxLength) {
    return text;
  }

  const trimmed = text.slice(0, maxLength).trim();
  const lastSpaceIndex = trimmed.lastIndexOf(" ");

  if (lastSpaceIndex <= 0) {
    return `${trimmed}...`;
  }

  return `${trimmed.slice(0, lastSpaceIndex)}...`;
}

function truncateVisualTitle(value: string, maxLength = 62) {
  const title = value.trim();

  if (title.length <= maxLength) {
    return title;
  }

  const trimmed = title.slice(0, maxLength).trim();
  const lastSpaceIndex = trimmed.lastIndexOf(" ");

  if (lastSpaceIndex <= 0) {
    return `${trimmed}...`;
  }

  return `${trimmed.slice(0, lastSpaceIndex)}...`;
}

const relatedCount =
  topics.length +
  people.length +
  places.length +
  glossary.length +
  events.length +
  books.length +
  passages.length;

const hasStudyGuide =
  Boolean(lesson.main_idea) ||
  points.length > 0 ||
  passages.length > 0 ||
  bibleRefs.length > 0 ||
  visualResources.length > 0 ||
  Boolean(lesson.explanation) ||
  relatedCount > 0 ||
  questions.length > 0 ||
  Boolean(lesson.remember) ||
  Boolean(lesson.application);

const storylineStages = [
  {
    label: "Creación",
    description: "Dios crea todas las cosas buenas.",
    active: lesson.lesson_number >= 1 && lesson.lesson_number <= 2,
  },
  {
    label: "Caída",
    description: "El pecado rompe la comunión con Dios.",
    active: lesson.lesson_number === 3,
  },
  {
    label: "Promesa",
    description: "Dios anuncia y desarrolla su plan de redención.",
    active: lesson.lesson_number >= 4 && lesson.lesson_number <= 10,
  },
  {
    label: "Israel",
    description: "Dios forma un pueblo y revela su pacto.",
    active: lesson.lesson_number >= 11 && lesson.lesson_number <= 18,
  },
  {
    label: "Jesús",
    description: "El Mesías cumple la promesa de Dios.",
    active: lesson.lesson_number === 19,
  },
  {
    label: "Iglesia",
    description: "El evangelio se anuncia a las naciones.",
    active: lesson.lesson_number === 20,
  },
  {
    label: "Nueva creación",
    description: "Dios consumará su reino para siempre.",
    active: lesson.lesson_number === 20,
  },
];
---

<BaseLayout
  title={lesson.title}
  description={lesson.summary ?? "Lección de la Enciclopedia Bíblica Visual."}
>
  <main class="page">
    <div class="breadcrumb">
      <a href={sitePath("/")}>Inicio</a> →
      <a href={sitePath(routePath)}>{route.title}</a> →
      Lección {lesson.lesson_number}
    </div>

    <section class="hero">
      <p class="eyebrow">{lesson.eyebrow ?? `Lección ${lesson.lesson_number}`}</p>

      <h1>{lesson.title}</h1>

      {lesson.summary && (
        <p class="subtitle">
          {lesson.summary}
        </p>
      )}
    </section>

    <section class="lesson-progress-panel" aria-label={`Progreso del recorrido: ${lessonStepLabel}`}>
      <div class="lesson-progress-main">
        <p class="eyebrow">Recorrido guiado</p>

        <h2>{lessonStepLabel}</h2>

        <div class="lesson-progress-bar" aria-hidden="true">
          <span style={`width: ${progressPercent}%`}></span>
        </div>

        <p>
          Has avanzado hasta el {progressPercent}% de la ruta
          <strong> {route.title}</strong>.
        </p>
      </div>

      <nav class="lesson-progress-actions" aria-label="Navegación rápida de la lección">
        {previousLesson ? (
          <a href={sitePath(`/lecciones/${previousLesson.slug}/`)} class="mini-nav-link">
            <span>← Anterior</span>
            <strong>{previousLesson.title}</strong>
          </a>
        ) : (
          <div class="mini-nav-link disabled">
            <span>Inicio</span>
            <strong>Primera lección</strong>
          </div>
        )}

        {nextLesson ? (
          <a href={sitePath(`/lecciones/${nextLesson.slug}/`)} class="mini-nav-link next">
            <span>Siguiente →</span>
            <strong>{nextLesson.title}</strong>
          </a>
        ) : (
          <div class="mini-nav-link disabled next">
            <span>Final</span>
            <strong>Última lección</strong>
          </div>
        )}
      </nav>
    </section>

    {hasStudyGuide && (
      <section class="lesson-study-panel" aria-label="Resumen de estudio de la lección">
        <div class="study-card">
          <span>Tiempo estimado</span>
          <strong>{lesson.estimated_time ?? "7–10 minutos"}</strong>
        </div>

        <div class="study-card">
          <span>Pasajes</span>
          <strong>{passages.length > 0 ? passages.length : bibleRefs.length}</strong>
        </div>

        <div class="study-card">
          <span>Conexiones</span>
          <strong>{relatedCount}</strong>
        </div>

        <div class="study-card">
          <span>Visuales</span>
          <strong>{visualResources.length}</strong>
        </div>

        <div class="study-card">
          <span>Estado</span>
          <strong>{lesson.status}</strong>
        </div>

        <nav class="lesson-toc" aria-label="Índice de la lección">
          {lesson.main_idea && <a href="#idea-principal">Idea principal</a>}
          {points.length > 0 && <a href="#resumen">Resumen</a>}
          {(passages.length > 0 || bibleRefs.length > 0) && <a href="#pasajes">Pasajes</a>}
          {visualResources.length > 0 && <a href="#recursos-visuales">Recursos visuales</a>}
          {lesson.explanation && <a href="#explicacion">Explicación</a>}
          {relatedCount > 0 && <a href="#conexiones">Conexiones</a>}
          {questions.length > 0 && <a href="#preguntas">Preguntas</a>}
          {(lesson.remember || lesson.application) && <a href="#recordar-aplicar">Recordar y aplicar</a>}
        </nav>
      </section>
    )}

    {lesson.main_idea && (
      <section class="section main-idea-section" id="idea-principal">
        <div class="section-header">
          <div>
            <p class="eyebrow">En una frase</p>
            <h2>Idea principal</h2>
          </div>
        </div>

        <div class="main-idea-card">
          <span class="quote-mark" aria-hidden="true"></span>
          <p>{lesson.main_idea}</p>
        </div>
      </section>
    )}

    {points.length > 0 && (
      <section class="section lesson-points-section" id="resumen">
        <div class="section-header">
          <div>
            <p class="eyebrow">Resumen guiado</p>
            <h2>Resumen en 5 ideas</h2>
          </div>

          <span class="section-count">
            {points.length} ideas
          </span>
        </div>

        <ol class="lesson-points-list">
          {points.map((point, index) => (
            <li>
              <span class="lesson-point-number">
                {String(index + 1).padStart(2, "0")}
              </span>

              <p>{point.point_text}</p>
            </li>
          ))}
        </ol>
      </section>
    )}

    {(passages.length > 0 || bibleRefs.length > 0) && (
      <section class="section passage-study-section" id="pasajes">
        <div class="section-header">
          <div>
            <p class="eyebrow">Base bíblica</p>
            <h2>Pasajes bíblicos principales</h2>
          </div>

          <span class="section-count">
            {passages.length > 0 ? passages.length : bibleRefs.length} pasajes
          </span>
        </div>

        <p class="section-intro">
          Estos pasajes sostienen la lección y ayudan a ubicar el tema dentro del
          desarrollo de la historia bíblica.
        </p>

        {passages.length > 0 ? (
          <div class="passage-study-grid">
            {passages.map((passage) => (
              <a href={sitePath(`/pasajes/${passage.slug}/`)} class="passage-study-card">
                <span>Pasaje</span>
                <strong>{passage.display_reference}</strong>
                <small>Leer el pasaje completo</small>
              </a>
            ))}
          </div>
        ) : (
          <div class="passage-study-grid">
            {bibleRefs.map((ref) => (
              <div class="passage-study-card">
                <span>Referencia</span>
                <strong>{ref.reference}</strong>
                <small>Referencia bíblica principal</small>
              </div>
            ))}
          </div>
        )}
      </section>
    )}

    {visualResources.length > 0 && (
      <section class="section lesson-visual-section" id="recursos-visuales">
        <div class="section-header">
          <div>
            <p class="eyebrow">Apoyo visual</p>
            <h2>Recursos visuales de esta lección</h2>
          </div>

          <span class="section-count">
            {visualResources.length} {visualResources.length === 1 ? "recurso" : "recursos"}
          </span>
        </div>

        <p class="section-intro">
          Estos recursos ayudan a visualizar ideas clave de la lección mediante
          infografías, mapas, esquemas o materiales editoriales relacionados.
        </p>

        <div class="lesson-visual-grid">
          {visualResources.map((resource) => {
            const imageUrl = getVisualResourceImageUrl(resource.url);

            return (
              <a
                href={sitePath(`/recursos/${resource.slug}/`)}
                class="lesson-visual-card"
              >
                <div class="lesson-visual-media">
                  {imageUrl ? (
                    <img
                      src={imageUrl}
                      alt={resource.alt_text ?? resource.title}
                      loading="lazy"
                    />
                  ) : (
                    <div class="lesson-visual-placeholder" aria-hidden="true">
                      <span>{resource.resource_type}</span>
                    </div>
                  )}
                </div>

                <div class="lesson-visual-body">
                  <span>{resource.resource_type}</span>

                  <strong title={resource.title}>
                    {truncateVisualTitle(resource.title)}
                  </strong>

                  <p>{truncateVisualText(resource.description)}</p>

                  <small>{resource.status}</small>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    {books.length > 0 && (
      <section class="section">
        <h2>Libros relacionados</h2>

        <ul class="pill-list">
          {books.map((book) => (
            <li>
              <a href={sitePath(`/libros/${book.slug}/`)}>{book.name}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {lesson.explanation && (
      <section class="section" id="explicacion">
        <h2>Explicación sencilla</h2>

        <div class="content">
          <p>{lesson.explanation}</p>
        </div>
      </section>
    )}

    <section class="section storyline-section">
      <div class="section-header">
        <div>
          <p class="eyebrow">Panorama bíblico</p>
          <h2>La Biblia en una línea</h2>
        </div>

        <a href={sitePath("/linea-de-tiempo/")} class="button secondary">
          Ver línea de tiempo
        </a>
      </div>

      <ol class="storyline">
        {storylineStages.map((stage) => (
          <li class:list={["storyline-item", stage.active && "is-active"]}>
            <span class="storyline-dot" aria-hidden="true"></span>

            <div class="storyline-content">
              <strong>{stage.label}</strong>
              <small>{stage.description}</small>
            </div>
          </li>
        ))}
      </ol>
    </section>

    {events.length > 0 && (
      <section class="section">
        <h2>Eventos relacionados</h2>

        <ul class="pill-list">
          {events.map((event) => (
            <li>
              <a href={sitePath(`/eventos/${event.slug}/`)}>{event.title}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {relatedCount > 0 && (
      <section class="section connections-section" id="conexiones">
        <div class="section-header">
          <div>
            <p class="eyebrow">Exploración relacionada</p>
            <h2>Conexiones de esta lección</h2>
          </div>

          <span class="section-count">
            {relatedCount} conexiones
          </span>
        </div>

        <p class="section-intro">
          Usa estas conexiones para ampliar la lección: personajes, lugares, temas,
          libros, eventos y pasajes relacionados dentro de la Enciclopedia Bíblica Visual.
        </p>

        <div class="connections-grid">
          {people.length > 0 && (
            <article class="connection-card">
              <div class="connection-card-header">
                <h3>Personajes</h3>
                <span>{people.length}</span>
              </div>

              <ul class="connection-list">
                {people.map((person) => (
                  <li>
                    <a href={sitePath(`/personajes/${person.slug}/`)}>{person.title}</a>
                  </li>
                ))}
              </ul>
            </article>
          )}

          {places.length > 0 && (
            <article class="connection-card">
              <div class="connection-card-header">
                <h3>Lugares</h3>
                <span>{places.length}</span>
              </div>

              <ul class="connection-list">
                {places.map((place) => (
                  <li>
                    <a href={sitePath(`/lugares/${place.slug}/`)}>{place.title}</a>
                  </li>
                ))}
              </ul>
            </article>
          )}

          {topics.length > 0 && (
            <article class="connection-card">
              <div class="connection-card-header">
                <h3>Temas</h3>
                <span>{topics.length}</span>
              </div>

              <ul class="connection-list">
                {topics.map((topic) => (
                  <li>
                    <a href={sitePath(`/temas/${topic.slug}/`)}>{topic.title}</a>
                  </li>
                ))}
              </ul>
            </article>
          )}

          {books.length > 0 && (
            <article class="connection-card">
              <div class="connection-card-header">
                <h3>Libros</h3>
                <span>{books.length}</span>
              </div>

              <ul class="connection-list">
                {books.map((book) => (
                  <li>
                    <a href={sitePath(`/libros/${book.slug}/`)}>{book.name}</a>
                  </li>
                ))}
              </ul>
            </article>
          )}

          {events.length > 0 && (
            <article class="connection-card">
              <div class="connection-card-header">
                <h3>Eventos</h3>
                <span>{events.length}</span>
              </div>

              <ul class="connection-list">
                {events.map((event) => (
                  <li>
                    <a href={sitePath(`/eventos/${event.slug}/`)}>{event.title}</a>
                  </li>
                ))}
              </ul>
            </article>
          )}

          {passages.length > 0 && (
            <article class="connection-card">
              <div class="connection-card-header">
                <h3>Pasajes</h3>
                <span>{passages.length}</span>
              </div>

              <ul class="connection-list">
                {passages.map((passage) => (
                  <li>
                    <a href={sitePath(`/pasajes/${passage.slug}/`)}>{passage.display_reference}</a>
                  </li>
                ))}
              </ul>
            </article>
          )}

          {glossary.length > 0 && (
            <article class="connection-card">
              <div class="connection-card-header">
                <h3>Glosario</h3>
                <span>{glossary.length}</span>
              </div>

              <ul class="connection-list">
                {glossary.map((term) => (
                  <li>
                    <a href={sitePath(`/glosario/${term.slug}/`)}>{term.title}</a>
                  </li>
                ))}
              </ul>
            </article>
          )}
        </div>
      </section>
    )}

    {questions.length > 0 && (
      <section class="section" id="preguntas">
        <h2>Preguntas para pensar</h2>

        <ol class="list">
          {questions.map((question) => (
            <li>{question.question_text}</li>
          ))}
        </ol>
      </section>
    )}

    {(lesson.remember || lesson.application) && (
      <section class="grid" id="recordar-aplicar">
        {lesson.remember && (
          <article class="card">
            <h2>Para recordar</h2>

            <div class="content">
              <p>{lesson.remember}</p>
            </div>
          </article>
        )}

        {lesson.application && (
          <article class="card">
            <h2>Para aplicar</h2>

            <div class="content">
              <p>{lesson.application}</p>
            </div>
          </article>
        )}
      </section>
    )}

    <section class="section continue-section">
      <div class="section-header">
        <div>
          <p class="eyebrow">Recorrido guiado</p>
          <h2>Continuar ruta</h2>
        </div>

        <a href={sitePath(routePath)} class="button secondary">
          Ver ruta completa
        </a>
      </div>

      <nav class="lesson-nav" aria-label="Navegación entre lecciones">
        {previousLesson ? (
          <a href={sitePath(`/lecciones/${previousLesson.slug}/`)} class="lesson-nav-card">
            <span>← Lección anterior</span>
            <strong>
              Lección {previousLesson.lesson_number}: {previousLesson.title}
            </strong>
          </a>
        ) : (
          <div class="lesson-nav-card disabled">
            <span>Inicio de la ruta</span>
            <strong>Esta es la primera lección del recorrido.</strong>
          </div>
        )}

        <a
          href={sitePath(routePath)}
          class="lesson-nav-card center"
        >
          <span>Ruta principal</span>
          <strong>Ver {totalRouteLessons} lecciones</strong>
        </a>

        {nextLesson ? (
          <a href={sitePath(`/lecciones/${nextLesson.slug}/`)} class="lesson-nav-card next">
            <span>Lección siguiente →</span>
            <strong>
              Lección {nextLesson.lesson_number}: {nextLesson.title}
            </strong>
          </a>
        ) : (
          <div class="lesson-nav-card disabled next">
            <span>Final de la ruta</span>
            <strong>Has llegado a la última lección.</strong>
          </div>
        )}
      </nav>
    </section>
  </main>
</BaseLayout>

<style>
  .lesson-visual-section,
  .lesson-visual-section * {
    box-sizing: border-box;
  }

  .lesson-visual-section {
    overflow: hidden;
  }

  .lesson-visual-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    align-items: stretch;
    justify-content: start;
    max-width: 100%;
  }

  .lesson-visual-card {
    display: grid;
    grid-template-rows: 225px auto;
    min-width: 0;
    max-width: 100%;
    min-height: 455px;
    overflow: hidden;
    border: 1px solid #eadcc4;
    border-radius: 22px;
    background: #fffaf0;
    box-shadow: 0 14px 34px rgba(45, 36, 24, 0.05);
    text-decoration: none;
  }

  .lesson-visual-card:hover {
    border-color: #c8a982;
    box-shadow: 0 14px 30px rgba(45, 36, 24, 0.08);
  }

  .lesson-visual-media {
    width: 100%;
    height: 225px;
    min-width: 0;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, rgba(233, 184, 114, 0.28), transparent 36%),
      linear-gradient(135deg, #fff2d8, #f7dfb7);
  }

  .lesson-visual-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lesson-visual-placeholder {
    display: grid;
    width: 100%;
    height: 100%;
    min-width: 0;
    place-items: center;
    padding: 20px;
    text-align: center;
  }

  .lesson-visual-placeholder span,
  .lesson-visual-body span {
    display: block;
    max-width: 100%;
    color: #8a5a2b;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    line-height: 1.25;
    text-transform: uppercase;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .lesson-visual-body {
    display: grid;
    grid-template-rows: auto auto auto auto;
    align-content: start;
    gap: 10px;
    min-width: 0;
    max-width: 100%;
    padding: 20px 22px 22px;
    overflow: hidden;
  }

  .lesson-visual-body strong {
    display: block;
    min-width: 0;
    max-width: 100%;
    overflow: visible;
    color: #2d2418;
    font-size: 1.08rem;
    line-height: 1.32;
