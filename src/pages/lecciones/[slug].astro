---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAllLessons,
  getBibleRefsByLessonId,
  getEventsByLessonId,
  getBooksByLessonId,
  getGlossaryByLessonId,
  getPeopleByLessonId,
  getPlacesByLessonId,
  getPointsByLessonId,
  getQuestionsByLessonId,
  getTopicsByLessonId,
  getPassagesByLessonId,
  type Event,
  type Book,
  type Lesson,
  type LessonBibleRef,
  type LessonPoint,
  type LessonQuestion,
  type RelatedItem,
  type Passage,
} from "../../lib/queries";

type Props = {
  lesson: Lesson;
  previousLesson: Lesson | null;
  nextLesson: Lesson | null;
  bibleRefs: LessonBibleRef[];
  points: LessonPoint[];
  questions: LessonQuestion[];
  topics: RelatedItem[];
  people: RelatedItem[];
  places: RelatedItem[];
  glossary: RelatedItem[];
  events: Event[];
  books: Book[];
  passages: Passage[];
};

export function getStaticPaths() {
  const publishedLessons = getAllLessons()
    .filter((lesson) => lesson.status !== "Borrador")
    .sort((a, b) => a.lesson_number - b.lesson_number);

  return publishedLessons.map((lesson, index) => ({
    params: { slug: lesson.slug },
    props: {
      lesson,
      previousLesson: publishedLessons[index - 1] ?? null,
      nextLesson: publishedLessons[index + 1] ?? null,
      bibleRefs: getBibleRefsByLessonId(lesson.id),
      points: getPointsByLessonId(lesson.id),
      questions: getQuestionsByLessonId(lesson.id),
      topics: getTopicsByLessonId(lesson.id),
      people: getPeopleByLessonId(lesson.id),
      places: getPlacesByLessonId(lesson.id),
      glossary: getGlossaryByLessonId(lesson.id),
      events: getEventsByLessonId(lesson.id),
      books: getBooksByLessonId(lesson.id),
      passages: getPassagesByLessonId(lesson.id),
    },
  }));
}

const {
  lesson,
  previousLesson,
  nextLesson,
  bibleRefs,
  points,
  questions,
  topics,
  people,
  places,
  glossary,
  events,
  books,
  passages,
} = Astro.props;
---

<BaseLayout
  title={lesson.title}
  description={lesson.summary ?? "Lección de la Enciclopedia Bíblica Visual."}
>
  <main class="page">
    <div class="breadcrumb">
      <a href="/">Inicio</a> →
      <a href="/rutas/panorama-visual-de-la-biblia/">Panorama Visual de la Biblia</a> →
      Lección {lesson.lesson_number}
    </div>

    <section class="hero">
      <p class="eyebrow">{lesson.eyebrow ?? `Lección ${lesson.lesson_number}`}</p>

      <h1>{lesson.title}</h1>

      {lesson.summary && (
        <p class="subtitle">
          {lesson.summary}
        </p>
      )}
    </section>

    {lesson.main_idea && (
      <section class="section">
        <h2>Idea principal</h2>

        <div class="content">
          <p>{lesson.main_idea}</p>
        </div>
      </section>
    )}

    {points.length > 0 && (
      <section class="section">
        <h2>Resumen en 5 ideas</h2>

        <ol class="list">
          {points.map((point) => (
            <li>{point.point_text}</li>
          ))}
        </ol>
      </section>
    )}

    {passages.length > 0 ? (
      <section class="section">
        <h2>Pasajes bíblicos principales</h2>

        <ul class="pill-list">
          {passages.map((passage) => (
            <li>
              <a href={`/pasajes/${passage.slug}/`}>{passage.display_reference}</a>
            </li>
          ))}
        </ul>
      </section>
    ) : (
      bibleRefs.length > 0 && (
        <section class="section">
          <h2>Pasajes bíblicos principales</h2>

          <ul class="pill-list">
            {bibleRefs.map((ref) => (
              <li>
                <span>{ref.reference}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    )}

    {books.length > 0 && (
      <section class="section">
        <h2>Libros relacionados</h2>

        <ul class="pill-list">
          {books.map((book) => (
            <li>
              <a href={`/libros/${book.slug}/`}>{book.name}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {lesson.explanation && (
      <section class="section">
        <h2>Explicación sencilla</h2>

        <div class="content">
          <p>{lesson.explanation}</p>
        </div>
      </section>
    )}

    <section class="section">
      <h2>La Biblia en una línea</h2>

      <ul class="pill-list">
        <li>Creación</li>
        <li>Caída</li>
        <li>Promesa</li>
        <li>Israel</li>
        <li>Jesús</li>
        <li>Iglesia</li>
        <li>Nueva creación</li>
      </ul>
    </section>

  {events.length > 0 && (
    <section class="section">
      <h2>Eventos relacionados</h2>

      <ul class="pill-list">
        {events.map((event) => (
          <li>
            <a href={`/eventos/${event.slug}/`}>{event.title}</a>
          </li>
        ))}
      </ul>
    </section>
)}

    <section class="grid">
      {people.length > 0 && (
        <article class="card">
          <h2>Personajes</h2>
          <ul class="list">
            {people.map((person) => (
                <li>
                    <a href={`/personajes/${person.slug}/`}>{person.title}</a>
                </li>
            ))}
          </ul>
        </article>
      )}

      {topics.length > 0 && (
        <article class="card">
          <h2>Temas</h2>
          <ul class="list">
            {topics.map((topic) => (
                <li>
                    <a href={`/temas/${topic.slug}/`}>{topic.title}</a>
                </li>
            ))}
          </ul>
        </article>
      )}

      {glossary.length > 0 && (
        <article class="card">
          <h2>Glosario</h2>
          <ul class="list">
            {glossary.map((term) => (
                <li>
                    <a href={`/glosario/${term.slug}/`}>{term.title}</a>
                </li>
            ))}
          </ul>
        </article>
      )}
    </section>

    {places.length > 0 && (
      <section class="section">
        <h2>Lugares relacionados</h2>

        <ul class="pill-list">
            {places.map((place) => (
                <li>
                    <a href={`/lugares/${place.slug}/`}>{place.title}</a>
                </li>
            ))}
        </ul>
      </section>
    )}

    {lesson.remember && (
      <section class="section">
        <h2>Qué debo recordar</h2>

        <div class="content">
          <p>{lesson.remember}</p>
        </div>
      </section>
    )}

    {questions.length > 0 && (
      <section class="section">
        <h2>Preguntas de estudio</h2>

        <ol class="list">
          {questions.map((question) => (
            <li>{question.question_text}</li>
          ))}
        </ol>
      </section>
    )}

    <section class="section">
      <a href="/rutas/panorama-visual-de-la-biblia/" class="button secondary">
        Volver a la ruta
      </a>
    </section>

    {(previousLesson || nextLesson) && (
      <section class="section">
        <h2>Continuar ruta</h2>

        <nav class="lesson-nav" aria-label="Navegación entre lecciones">
          {previousLesson ? (
            <a href={`/lecciones/${previousLesson.slug}/`} class="lesson-nav-card">
              <span>← Lección anterior</span>
              <strong>
                Lección {previousLesson.lesson_number}: {previousLesson.title}
              </strong>
            </a>
          ) : (
            <div class="lesson-nav-placeholder"></div>
          )}

          {nextLesson ? (
            <a href={`/lecciones/${nextLesson.slug}/`} class="lesson-nav-card next">
              <span>Lección siguiente →</span>
              <strong>
                Lección {nextLesson.lesson_number}: {nextLesson.title}
              </strong>
            </a>
          ) : (
            <div class="lesson-nav-placeholder"></div>
          )}
        </nav>
      </section>
    )}
  </main>
</BaseLayout>