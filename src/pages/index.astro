---
import BaseLayout from "../layouts/BaseLayout.astro";

const siteTitle = "Enciclopedia Bíblica Visual";
---

<BaseLayout title={siteTitle}>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">Proyecto en construcción</p>

      <h1>Enciclopedia Bíblica Visual</h1>

      <p class="subtitle">
        Rutas guiadas, mapas, líneas de tiempo, personajes, lugares, temas y recursos visuales
        para estudiar la Biblia con claridad.
      </p>

      <div class="actions">
        <a href="/rutas/panorama-visual-de-la-biblia/" class="button">
          Ver ruta principal
        </a>

        <a href="/explorar/" class="button secondary">
          Explorar enciclopedia
        </a>

        <a href="/buscar/" class="button secondary">
          Buscar contenido
        </a>

        <a href="/biblia/" class="button secondary">
          Leer Biblia
        </a>

        <a href="/libros/" class="button secondary">
          Ver libros bíblicos
        </a>

        <a href="/pasajes/" class="button secondary">
          Ver pasajes
        </a>

        <a href="/linea-de-tiempo/" class="button secondary">
          Ver línea de tiempo
        </a>

        <a href="/mapa/" class="button secondary">
          Ver mapa bíblico
        </a>
      </div>
    </section>

    <section class="grid">
      <article class="card">
        <h2>Rutas guiadas</h2>
        <p>
          Estudios organizados paso a paso para avanzar con orden y enfoque.
        </p>
      </article>

      <article class="card">
        <h2>Exploración libre</h2>
        <p>
          Personajes, lugares, temas, eventos, glosario y recursos visuales conectados entre sí.
        </p>
      </article>

      <article class="card">
		<h2>Línea de tiempo</h2>
		<p>
			Eventos ordenados cronológicamente para entender el desarrollo de la historia bíblica.
		</p>
	  </article>
    </section>
  </main>
</BaseLayout>