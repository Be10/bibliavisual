---
import { sitePath } from "../lib/site-paths";
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Enciclopedia Bíblica Visual con rutas guiadas, mapas, líneas de tiempo y recursos visuales.",
} = Astro.props;

const siteName = "Enciclopedia Bíblica Visual";
const pageTitle = title === siteName ? title : `${title} | ${siteName}`;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>

    <script is:inline>
      const storedTheme = localStorage.getItem("ebv-theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      const initialTheme = storedTheme ?? (prefersDark ? "dark" : "light");

      document.documentElement.dataset.theme = initialTheme;
    </script>
  </head>

  <body>
    <header class="site-header">
      <a href={sitePath("/")} class="logo">Enciclopedia Bíblica Visual</a>

      <nav class="nav" aria-label="Navegación principal">
        <a href={sitePath("/rutas/panorama-visual-de-la-biblia/")}>Ruta principal</a>
        <a href={sitePath("/explorar/")}>Explorar</a>
        <a href={sitePath("/buscar/")}>Buscar</a>
        <a href={sitePath("/biblia/")}>Biblia</a>
        <a href={sitePath("/mapa/")}>Mapa</a>
        <a href={sitePath("/acerca/")}>Acerca</a>

        <button
          type="button"
          class="theme-toggle"
          data-theme-toggle
          aria-label="Cambiar a modo oscuro"
          aria-pressed="false"
        >
          <span class="theme-toggle-icon" aria-hidden="true">🌙</span>
        </button>
      </nav>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="site-footer-inner">
        <p>
          Enciclopedia Bíblica Visual · Recurso educativo en desarrollo.
        </p>

        <nav class="footer-links" aria-label="Navegación secundaria">
          <a href={sitePath("/explorar/")}>Explorar</a>
          <a href={sitePath("/buscar/")}>Buscar</a>
          <a href={sitePath("/lecciones/")}>Lecciones</a>
          <a href={sitePath("/biblia/")}>Biblia</a>
          <a href={sitePath("/libros/")}>Libros</a>
          <a href={sitePath("/pasajes/")}>Pasajes</a>
          <a href={sitePath("/linea-de-tiempo/")}>Línea de tiempo</a>
          <a href={sitePath("/mapa/")}>Mapa</a>
          <a href={sitePath("/temas/")}>Temas</a>
          <a href={sitePath("/personajes/")}>Personajes</a>
          <a href={sitePath("/lugares/")}>Lugares</a>
          <a href={sitePath("/eventos/")}>Eventos</a>
          <a href={sitePath("/glosario/")}>Glosario</a>
          <a href={sitePath("/acerca/")}>Acerca</a>
          <a href={sitePath("/legal/")}>Avisos legales</a>
        </nav>
      </div>
    </footer>
    <script is:inline>
      const themeToggle = document.querySelector("[data-theme-toggle]");

      function syncThemeToggle(theme) {
        if (!themeToggle) return;

        const isDark = theme === "dark";
        const icon = themeToggle.querySelector(".theme-toggle-icon");

        themeToggle.setAttribute("aria-pressed", String(isDark));
        themeToggle.setAttribute(
          "aria-label",
          isDark ? "Cambiar a modo claro" : "Cambiar a modo oscuro"
        );

        if (icon) {
          icon.textContent = isDark ? "☀️" : "🌙";
        }
      }

      const currentTheme = document.documentElement.dataset.theme ?? "light";
      syncThemeToggle(currentTheme);

      themeToggle?.addEventListener("click", () => {
        const activeTheme =
          document.documentElement.dataset.theme === "dark" ? "light" : "dark";

        document.documentElement.dataset.theme = activeTheme;
        localStorage.setItem("ebv-theme", activeTheme);
        syncThemeToggle(activeTheme);
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
  }

  body {
    margin: 0;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    background: #f8f5ee;
    color: #2d2418;
  }

  a {
    color: inherit;
  }

  .site-header {
    width: min(1100px, calc(100% - 32px));
    margin: 0 auto;
    padding: 24px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .logo {
    font-weight: 800;
    text-decoration: none;
    color: #5d3212;
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
  }

  .nav a {
    padding: 9px 12px;
    border-radius: 999px;
    color: #5d3212;
    font-weight: 800;
    text-decoration: none;
  }

  .nav a:hover {
    background: #fff7e8;
  }

  .theme-toggle {
    display: inline-flex;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    padding: 0;
    border-radius: 999px;
    border: 1px solid #c8a982;
    background: #fff7e8;
    color: #5d3212;
    font: inherit;
    font-size: 1.05rem;
    font-weight: 800;
    cursor: pointer;
  }

  .theme-toggle:hover {
    background: #fffaf0;
  }

  .theme-toggle-icon {
    line-height: 1;
  }

  .page {
    width: min(1100px, calc(100% - 32px));
    margin: 0 auto;
    padding: 32px 0 72px;
  }

  .hero {
    padding: 64px 32px;
    border-radius: 28px;
    background: #fffaf0;
    border: 1px solid #eadcc4;
    box-shadow: 0 20px 60px rgba(45, 36, 24, 0.08);
  }

  .eyebrow {
    margin: 0 0 16px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a5a2b;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .subtitle {
    max-width: 760px;
    margin: 24px 0 0;
    font-size: 1.2rem;
    line-height: 1.7;
    color: #5e5143;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    border-radius: 999px;
    background: #5d3212;
    color: #fffaf0;
    font-weight: 700;
    text-decoration: none;
  }

  .button.secondary {
    background: transparent;
    color: #5d3212;
    border: 1px solid #c8a982;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 24px;
  }

  .card {
    padding: 24px;
    border-radius: 22px;
    background: white;
    border: 1px solid #eadcc4;
  }

  .card h2,
  .card h3 {
    margin: 0 0 8px;
  }

  .card p {
    margin: 0;
    line-height: 1.6;
    color: #6a5c4d;
  }

  .section {
    margin-top: 32px;
    padding: 32px;
    border-radius: 24px;
    background: white;
    border: 1px solid #eadcc4;
  }

  .section h2 {
    margin-top: 0;
  }

  .content {
    max-width: 760px;
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .breadcrumb {
    margin-bottom: 16px;
    font-size: 0.95rem;
    color: #7a6a58;
  }

  .list {
    padding-left: 1.2rem;
    line-height: 1.8;
  }

  .pill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding: 0;
    list-style: none;
  }

  .pill-list a,
  .pill-list span {
    display: inline-flex;
    padding: 8px 12px;
    border-radius: 999px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #5d3212;
    text-decoration: none;
    font-weight: 650;
  }

  .entity-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-top: 24px;
  }

  .entity-card {
    display: block;
    padding: 22px;
    border-radius: 22px;
    background: white;
    border: 1px solid #eadcc4;
    text-decoration: none;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease;
  }

  .entity-card:hover {
    transform: translateY(-2px);
    border-color: #c8a982;
    box-shadow: 0 16px 36px rgba(45, 36, 24, 0.08);
  }

  .entity-card h2 {
    margin: 0 0 8px;
    font-size: 1.15rem;
    color: #2d2418;
  }

  .entity-card p {
    margin: 0;
    line-height: 1.6;
    color: #6a5c4d;
  }

  .meta {
    display: inline-flex;
    margin-bottom: 12px;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #8a5a2b;
  }

  .timeline {
    position: relative;
    display: grid;
    gap: 18px;
    margin-top: 32px;
  }

  .timeline-item {
    position: relative;
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 18px;
    align-items: start;
  }

  .timeline-date {
    position: sticky;
    top: 16px;
    padding: 12px 14px;
    border-radius: 18px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #8a5a2b;
    font-weight: 800;
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .timeline-card {
    position: relative;
    padding: 24px;
    border-radius: 22px;
    background: white;
    border: 1px solid #eadcc4;
  }

  .timeline-card::before {
    content: "";
    position: absolute;
    left: -27px;
    top: 30px;
    width: 14px;
    height: 14px;
    border-radius: 999px;
    background: #5d3212;
    box-shadow: 0 0 0 6px #f8f5ee;
  }

  .timeline-card h2 {
    margin: 0 0 8px;
    font-size: 1.25rem;
  }

  .timeline-card p {
    margin: 0;
    line-height: 1.6;
    color: #6a5c4d;
  }

  .timeline-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 14px 0 0;
  }

  .timeline-meta span {
    display: inline-flex;
    padding: 6px 10px;
    border-radius: 999px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #5d3212;
    font-size: 0.85rem;
    font-weight: 700;
  }

    .place-hero {
    position: relative;
    overflow: hidden;
  }

  .place-meta-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-top: 24px;
  }

  .place-meta-card {
    padding: 22px;
    border-radius: 22px;
    background: white;
    border: 1px solid #eadcc4;
  }

  .place-meta-card span {
    display: block;
    margin-bottom: 8px;
    color: #8a5a2b;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .place-meta-card strong {
    display: block;
    color: #2d2418;
    font-size: 1.02rem;
    line-height: 1.4;
  }

  .place-map-panel {
    background: white;
  }

  .place-map-preview,
  .place-empty-map {
    padding: 22px;
    border-radius: 22px;
    background: #fffaf0;
    border: 1px solid #eadcc4;
  }

  .place-map-preview p,
  .place-empty-map p {
    max-width: 760px;
    margin: 0;
    color: #6a5c4d;
    line-height: 1.7;
  }

  .place-empty-map strong {
    display: block;
    margin-bottom: 8px;
    color: #2d2418;
    font-size: 1.1rem;
  }

  .place-map-link {
    display: inline-flex;
    margin-top: 16px;
    color: #5d3212;
    font-weight: 900;
    text-decoration: none;
  }

  .place-map-link:hover {
    text-decoration: underline;
  }

  .place-events-grid,
  .place-lessons-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .place-event-card,
  .place-lesson-card {
    display: grid;
    align-content: start;
    gap: 8px;
    min-height: 176px;
    padding: 22px;
    border-radius: 22px;
    background: #fffaf0;
    border: 1px solid #eadcc4;
    text-decoration: none;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .place-event-card:hover,
  .place-lesson-card:hover {
    transform: translateY(-2px);
    border-color: #c8a982;
    box-shadow: 0 14px 30px rgba(45, 36, 24, 0.08);
  }

  .place-event-card span,
  .place-lesson-card span {
    color: #8a5a2b;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .place-event-card strong,
  .place-lesson-card strong {
    color: #2d2418;
    font-size: 1.12rem;
    line-height: 1.35;
  }

  .place-event-card small,
  .place-lesson-card small {
    color: #6a5c4d;
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .map-shell {
    margin-top: 32px;
    overflow: hidden;
    border-radius: 28px;
    background: white;
    border: 1px solid #eadcc4;
    box-shadow: 0 20px 60px rgba(45, 36, 24, 0.08);
  }

  #biblical-map {
    width: 100%;
    height: 620px;
  }

  .leaflet-popup-pane {
    z-index: 900;
  }

  .map-layer-switcher {
    min-width: 250px;
    padding: 12px;
    border-radius: 20px;
    background: rgba(255, 250, 240, 0.94);
    border: 1px solid rgba(234, 220, 196, 0.95);
    box-shadow: 0 18px 42px rgba(45, 36, 24, 0.18);
    backdrop-filter: blur(14px);
  }

  .map-layer-current {
    display: none;
    width: 100%;
    min-height: 38px;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 0 12px;
    border-radius: 999px;
    border: 1px solid #eadcc4;
    background: #fff7e8;
    color: #5d3212;
    font: inherit;
    cursor: pointer;
  }

  .map-layer-current span {
    color: #8a5a2b;
    font-size: 0.64rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .map-layer-current strong {
    color: #5d3212;
    font-size: 0.88rem;
    font-weight: 900;
  }

  .map-layer-current em {
    color: #8a5a2b;
    font-style: normal;
    font-weight: 900;
    transition: transform 160ms ease;
  }

  .map-layer-switcher.is-open .map-layer-current em {
    transform: rotate(180deg);
  }

  .map-layer-options {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  .map-layer-button {
    min-height: 36px;
    padding: 0 10px;
    border: 1px solid #eadcc4;
    border-radius: 999px;
    background: rgba(255, 247, 232, 0.72);
    color: #5d3212;
    font: inherit;
    font-size: 0.86rem;
    font-weight: 900;
    cursor: pointer;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .map-layer-button:hover {
    background: #fff7e8;
    border-color: #c8a982;
  }

  .map-layer-button.is-active {
    background: #5d3212;
    border-color: #5d3212;
    color: #fffaf0;
    box-shadow: 0 8px 18px rgba(93, 50, 18, 0.24);
  }

  .map-layer-button.is-active:hover {
    background: #5d3212;
    border-color: #5d3212;
  }

  .map-layer-button:focus-visible,
  .map-layer-current:focus-visible {
    outline: 3px solid rgba(200, 169, 130, 0.5);
    outline-offset: 2px;
  }

  .ebv-map-marker {
    background: transparent;
    border: 0;
  }

  .ebv-map-marker span {
    position: relative;
    display: block;
    width: 30px;
    height: 30px;
    transform: rotate(-45deg);
    border-radius: 999px 999px 999px 0;
    background: #7a3f16;
    border: 3px solid #fffaf0;
    box-shadow:
      0 8px 18px rgba(45, 36, 24, 0.34),
      0 0 0 2px rgba(122, 63, 22, 0.25);
  }

  .ebv-map-marker span::after {
    content: "";
    position: absolute;
    inset: 8px;
    border-radius: 999px;
    background: #f2c078;
    box-shadow: inset 0 0 0 2px rgba(93, 50, 18, 0.22);
  }

  .map-popup {
    width: min(280px, calc(100vw - 112px));
    max-width: min(280px, calc(100vw - 112px));
    box-sizing: border-box;
  }

  .map-popup,
  .map-popup * {
    box-sizing: border-box;
  }

  .map-popup-compact {
    display: grid;
    gap: 10px;
    width: 100%;
    min-width: 0;
    max-width: 100%;
  }

  .map-popup-compact span {
    color: #8a5a2b;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .map-popup h3 {
    margin: 0;
    color: #2d2418;
    font-size: 1.12rem;
    line-height: 1.25;
  }

  .map-popup p {
    margin: 0;
    color: #5e5143;
    line-height: 1.55;
  }

  .map-popup ul {
    margin: 6px 0 12px;
    padding-left: 1.2rem;
  }

  .map-popup li {
    margin: 4px 0;
  }

  .map-popup p,
  .map-popup li,
  .map-popup a {
    overflow-wrap: anywhere;
  }

  .map-popup a {
    font-weight: 800;
    color: #5d3212;
  }

  .map-popup-disclosure {
    display: grid;
    width: 100%;
    max-width: 100%;
  }

  .map-popup-toggle {
    display: inline-flex;
    width: fit-content;
    min-height: 34px;
    align-items: center;
    gap: 8px;
    margin-top: 2px;
    padding: 0 13px;
    border-radius: 999px;
    border: 1px solid #eadcc4;
    background: #fff7e8;
    color: #5d3212;
    font: inherit;
    font-size: 0.88rem;
    font-weight: 900;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .map-popup-toggle::-webkit-details-marker {
    display: none;
  }

  .map-popup-toggle::marker {
    content: "";
  }

  .map-popup-toggle:hover {
    background: #fffaf0;
    border-color: #c8a982;
  }

  .map-popup-toggle em {
    font-style: normal;
    transition: transform 160ms ease;
  }

  .map-popup-disclosure[open] .map-popup-toggle em {
    transform: rotate(180deg);
  }

  .map-popup-details {
    display: grid;
    gap: 10px;
    width: 100%;
    max-width: 100%;
    max-height: 300px;
    overflow-y: auto;
    margin-top: 14px;
    padding-top: 14px;
    padding-right: 6px;
    border-top: 1px solid #eadcc4;
  }

  .map-popup-details::-webkit-scrollbar {
    width: 6px;
  }

  .map-popup-details::-webkit-scrollbar-thumb {
    border-radius: 999px;
    background: rgba(138, 90, 43, 0.42);
  }

  .map-popup-detail-group {
    display: grid;
    gap: 4px;
    min-width: 0;
  }

  .map-popup-place-link {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    margin-top: 2px;
  }

  .leaflet-control-zoom {
    overflow: hidden;
    border: 1px solid #eadcc4;
    border-radius: 12px;
    box-shadow: 0 12px 28px rgba(45, 36, 24, 0.16);
  }

  .leaflet-control-zoom a {
    color: #2d2418;
    border-color: #eadcc4;
  }

  .leaflet-control-zoom a:hover {
    background: #fff7e8;
    color: #5d3212;
  }

  .leaflet-popup-content-wrapper,
  .leaflet-popup-tip {
    background: white;
    color: #2d2418;
  }

  .leaflet-popup-content-wrapper {
    width: auto;
    max-width: min(340px, calc(100vw - 80px));
    border-radius: 18px;
    box-shadow: 0 18px 42px rgba(45, 36, 24, 0.22);
  }

  .leaflet-popup-content {
    width: auto !important;
    max-width: min(280px, calc(100vw - 112px));
    margin: 22px 24px 20px;
    color: #2d2418;
  }

  .leaflet-container a.leaflet-popup-close-button {
    top: 10px;
    right: 10px;
    width: 30px;
    height: 30px;
    border-radius: 999px;
    color: #7a6a58;
    font-size: 22px;
    line-height: 28px;
    text-align: center;
  }

  .leaflet-container a.leaflet-popup-close-button:hover {
    background: #fff7e8;
    color: #2d2418;
  }

  .leaflet-control-attribution {
    background: rgba(255, 250, 240, 0.88);
    color: #5e5143;
  }

  .leaflet-control-attribution a {
    color: #5d3212;
    font-weight: 700;
  }

  .chapter-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }

  .chapter-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 46px;
    height: 46px;
    padding: 0 12px;
    border-radius: 14px;
    background: white;
    border: 1px solid #eadcc4;
    color: #5d3212;
