---
import { sitePath } from "../lib/site-paths";
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Enciclopedia Bíblica Visual con rutas guiadas, mapas, líneas de tiempo y recursos visuales.",
} = Astro.props;

const siteName = "Enciclopedia Bíblica Visual";
const pageTitle = title === siteName ? title : `${title} | ${siteName}`;

const searchDataUrl = sitePath("/buscar/datos.json");
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>

    <style is:inline>
      html[data-theme="dark"] .button {
        background: #e9b872 !important;
        border-color: #e9b872 !important;
        color: #1b120b !important;
      }

      html[data-theme="dark"] .button.secondary {
        background: transparent !important;
        border-color: #6c4c2f !important;
        color: #e9b872 !important;
      }

      html[data-theme="dark"] .button.secondary:hover {
        background: #312113 !important;
        border-color: #e9b872 !important;
        color: #fff5e8 !important;
      }

      .hero {
        position: relative;
        overflow: hidden;
      }

      .hero::after {
        content: "";
        position: absolute;
        right: -90px;
        bottom: -120px;
        width: 320px;
        height: 320px;
        border-radius: 999px;
        background: radial-gradient(circle, rgba(200, 169, 130, 0.28), transparent 68%);
        pointer-events: none;
      }

      .hero > * {
        position: relative;
        z-index: 1;
      }

            /*
        Estilo crítico para evitar parpadeo de la línea de tiempo.
        Debe coincidir con el layout final de /linea-de-tiempo/ desde el primer render.
      */
      .timeline-ready .timeline-period,
      .timeline-ready .timeline-card,
      .timeline-ready .timeline-card-header,
      .timeline-ready .timeline-marker,
      .timeline-ready .timeline-marker span,
      .timeline-ready .timeline-date,
      .timeline-ready .timeline-order,
      .timeline-ready .timeline-meta,
      .timeline-ready .timeline-meta span,
      .timeline-ready .timeline-period-header strong {
        box-sizing: border-box;
      }

      .timeline-ready .timeline-period {
        display: grid;
        gap: 18px;
        padding: 22px;
        border-radius: 24px;
      }

      .timeline-ready .timeline-period-header strong {
        display: inline-flex;
        min-height: 34px;
        max-width: 100%;
        align-items: center;
        padding: 7px 12px;
        border-radius: 18px;
        background: #fff;
        border: 1px solid #eadcc4;
        color: #5d3212;
        font-size: 0.86rem;
        line-height: 1.22;
        white-space: normal;
        overflow-wrap: anywhere;
      }

      .timeline-ready .timeline-list {
        position: relative;
        display: grid;
        gap: 14px;
      }

      .timeline-ready .timeline-list::before {
        content: "";
        position: absolute;
        top: 12px;
        bottom: 12px;
        left: 13px;
        width: 2px;
        background: #eadcc4;
      }

      .timeline-ready .timeline-item {
        position: relative;
        display: grid;
        grid-template-columns: 28px minmax(0, 1fr);
        gap: 14px;
      }

      .timeline-ready .timeline-marker {
        position: relative;
        display: flex;
        justify-content: center;
        padding-top: 18px;
        z-index: 1;
      }

      .timeline-ready .timeline-marker span {
        width: 12px;
        height: 12px;
        flex: 0 0 12px;
        border-radius: 999px;
        background: #8a5a2b;
        border: 3px solid #fffaf0;
        box-shadow: 0 0 0 1px #c8a982;
      }

      .timeline-ready .timeline-card {
        display: grid;
        gap: 10px;
        min-width: 0;
        padding: 18px;
        border-radius: 20px;
        background: #fff;
        border: 1px solid #eadcc4;
      }

      .timeline-ready .timeline-card-header {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: center;
      }

      .timeline-ready .timeline-date,
      .timeline-ready .timeline-order,
      .timeline-ready .timeline-meta span {
        display: inline-flex;
        min-height: 30px;
        max-width: 100%;
        align-items: center;
        padding: 7px 12px;
        border-radius: 18px;
        background: #fff7e8;
        border: 1px solid #eadcc4;
        color: #8a5a2b;
        line-height: 1.22;
        white-space: normal;
        overflow-wrap: anywhere;
        word-break: normal;
      }

      .timeline-ready .timeline-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        min-width: 0;
      }

      html[data-theme="dark"] .timeline-ready .timeline-list::before {
        background: #4a3523;
      }

      html[data-theme="dark"] .timeline-ready .timeline-marker span {
        background: #e9b872;
        border-color: #21160e;
        box-shadow: 0 0 0 1px #6c4c2f;
      }

      html[data-theme="dark"] .timeline-ready .timeline-period-header strong,
      html[data-theme="dark"] .timeline-ready .timeline-date,
      html[data-theme="dark"] .timeline-ready .timeline-order,
      html[data-theme="dark"] .timeline-ready .timeline-meta span {
        background: #18110c;
        border-color: #3a2a1d;
        color: #e9b872;
      }

      @media (max-width: 640px) {
        .timeline-ready .timeline-period {
          padding: 18px;
        }

        .timeline-ready .timeline-card {
          padding: 18px;
        }

        .timeline-ready .timeline-card-header {
          flex-direction: column;
          align-items: flex-start;
        }

        .timeline-ready .timeline-date,
        .timeline-ready .timeline-order,
        .timeline-ready .timeline-meta span {
          padding: 8px 12px;
          border-radius: 16px;
          line-height: 1.25;
          letter-spacing: 0.06em;
        }

        .timeline-ready .timeline-date {
          max-width: min(100%, 220px);
        }
      }

      .timeline-page .timeline-date,
      .timeline-page .timeline-order,
      .timeline-page .timeline-meta span {
        background: #fff7e8;
        border: 1px solid #eadcc4;
        color: #8a5a2b;
      }

      .timeline-page .timeline-period-header strong {
        background: white;
        border: 1px solid #eadcc4;
        color: #5d3212;
      }

      html[data-theme="dark"] .timeline-page .timeline-period-header strong,
      html[data-theme="dark"] .timeline-page .timeline-date,
      html[data-theme="dark"] .timeline-page .timeline-order,
      html[data-theme="dark"] .timeline-page .timeline-meta span {
        background: #18110c;
        border-color: #3a2a1d;
        color: #e9b872;
      }

      @media (max-width: 640px) {
        .timeline-page .timeline-date,
        .timeline-page .timeline-order,
        .timeline-page .timeline-meta span {
          padding: 8px 12px;
          border-radius: 16px;
          line-height: 1.25;
          letter-spacing: 0.06em;
        }

        .timeline-page .timeline-date {
          max-width: min(100%, 220px);
        }

        .timeline-page .timeline-meta span {
          max-width: 100%;
        }
      }

      html[data-theme="dark"] .lesson-progress-panel,
      html[data-theme="dark"] .lesson-toc a,
      html[data-theme="dark"] .mini-nav-link {
        background: #18110c !important;
        border-color: #3a2a1d !important;
        color: #fff5e8 !important;
      }

      html[data-theme="dark"] .lesson-progress-panel *,
      html[data-theme="dark"] .lesson-toc a,
      html[data-theme="dark"] .mini-nav-link span,
      html[data-theme="dark"] .mini-nav-link strong {
        color: inherit;
      }

      html[data-theme="dark"] .lesson-toc a,
      html[data-theme="dark"] .mini-nav-link span {
        color: #e9b872 !important;
      }

      html[data-theme="dark"] .mini-nav-link strong,
      html[data-theme="dark"] .lesson-progress-main h2,
      html[data-theme="dark"] .lesson-progress-main strong {
        color: #fff5e8 !important;
      }

      html[data-theme="dark"] .lesson-progress-main p {
        color: #d8c8b6 !important;
      }

      html[data-theme="dark"] .lesson-progress-bar {
        background: #4a3523 !important;
      }

      html[data-theme="dark"] .lesson-progress-bar span {
        background: #e9b872 !important;
      }
    </style>

    <script is:inline>
      function getPreferredTheme() {
        const storedTheme = localStorage.getItem("ebv-theme");

        if (storedTheme === "dark" || storedTheme === "light") {
          return storedTheme;
        }

        return window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      }

      function applyTheme(theme) {
        document.documentElement.dataset.theme = theme;
      }

      applyTheme(getPreferredTheme());
    </script>
  </head>

  <body>
    <header class="site-header" data-site-header>
  <a href={sitePath("/")} class="logo">Enciclopedia Bíblica Visual</a>

  <div class="header-actions">
    <div
      class="global-search-shell"
      data-global-search-shell
      data-search-url={searchDataUrl}
    >
      <button
        type="button"
        class="global-search-toggle"
        data-global-search-toggle
        aria-label="Abrir búsqueda"
        aria-expanded="false"
      >
        🔍
      </button>

      <form
        class="global-search-form"
        action={sitePath("/buscar/")}
        method="get"
        role="search"
        aria-label="Búsqueda global"
        data-global-search-form
      >
        <label class="sr-only" for="global-search">
          Buscar en la enciclopedia
        </label>

        <input
          id="global-search"
          name="q"
          type="search"
          placeholder="Buscar..."
          autocomplete="off"
          data-global-search-input
        />

        <button
          type="button"
          class="global-search-submit"
          data-global-search-submit
          aria-label="Icono de búsqueda"
        >
          🔍
        </button>
      </form>

      <div
        class="global-search-popover"
        data-global-search-popover
        hidden
      >
        <div
          class="global-search-filters"
          data-global-search-filters
          aria-label="Filtros de búsqueda"
        ></div>

        <div
          class="global-search-results"
          data-global-search-results
          aria-label="Resultados de búsqueda"
        ></div>

        <a
          href={sitePath("/buscar/")}
          class="global-search-all"
          data-global-search-all
        >
          Ver todos los resultados →
        </a>
      </div>
    </div>

    <div class="global-menu-shell">
      <button
        type="button"
        class="menu-toggle"
        data-menu-toggle
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        ☰
      </button>

      <nav
        class="global-menu"
        data-global-menu
        aria-label="Menú principal"
        hidden
      >
        <a href={sitePath("/buscar/")}>Búsqueda avanzada</a>
        <a href={sitePath("/rutas/panorama-visual-de-la-biblia/")}>Ruta principal</a>
        <a href={sitePath("/biblia/")}>Leer la Biblia</a>
        <a href={sitePath("/recursos/")}>Recursos visuales</a>
        <a href={sitePath("/acerca/")}>Acerca de EBV</a>


        <div class="menu-theme-row">
          <span>Cambiar tema</span>

          <button
            type="button"
            class="theme-toggle menu-theme-toggle"
            data-theme-toggle
            aria-label="Cambiar a modo oscuro"
            aria-pressed="false"
          >
            <span class="theme-toggle-icon" aria-hidden="true">🌙</span>
          </button>
        </div>
      </nav>
    </div>
  </div>
</header>

<button
  type="button"
  class="theme-toggle floating-theme-toggle"
  data-theme-toggle
  aria-label="Cambiar a modo oscuro"
  aria-pressed="false"
>
  <span class="theme-toggle-icon" aria-hidden="true">🌙</span>
</button>

    <slot />

    <footer class="site-footer">
      <div class="site-footer-inner">
        <p>
          Enciclopedia Bíblica Visual · Recurso educativo en desarrollo.
        </p>

        <nav class="footer-links" aria-label="Navegación secundaria">
          <a href={sitePath("/buscar/")}>Búsqueda avanzada</a>
          <a href={sitePath("/biblia/")}>Leer la Biblia</a>
          <a href={sitePath("/acerca/")}>Acerca de EBV</a>
          <a href={sitePath("/legal/")}>Avisos legales</a>
        </nav>
      </div>
    </footer>
    <script>
  import {
    SEARCH_FILTER_ORDER,
    getAvailableSearchFilters,
    getDisplaySearchResults,
    getSearchCounts,
    getSearchResults,
    normalizeSearchText,
  } from "../lib/search-engine";

  (() => {
    const siteHeader = document.querySelector("[data-site-header]");
    const themeToggleButtons = document.querySelectorAll("[data-theme-toggle]");

    const menuToggle = document.querySelector("[data-menu-toggle]");
    const globalMenu = document.querySelector("[data-global-menu]");

    const searchShell = document.querySelector("[data-global-search-shell]");
    const searchToggle = document.querySelector("[data-global-search-toggle]");
    const searchForm = document.querySelector("[data-global-search-form]");
    const searchInput = document.querySelector("[data-global-search-input]");
    const searchSubmit = document.querySelector("[data-global-search-submit]");
    const searchPopover = document.querySelector("[data-global-search-popover]");
    const searchFilters = document.querySelector("[data-global-search-filters]");
    const searchResults = document.querySelector("[data-global-search-results]");
    const searchAllLink = document.querySelector("[data-global-search-all]");

    let searchItems = null;
    let activeSearchType = "Todos";

    function getPreferredTheme() {
      const storedTheme = localStorage.getItem("ebv-theme");

      if (storedTheme === "dark" || storedTheme === "light") {
        return storedTheme;
      }

      return window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light";
    }

    function applyTheme(theme) {
      document.documentElement.dataset.theme = theme;
    }

    function syncThemeToggle(theme) {
      const isDark = theme === "dark";

      themeToggleButtons.forEach((button) => {
        const icon = button.querySelector(".theme-toggle-icon");

        button.setAttribute("aria-pressed", String(isDark));
        button.setAttribute(
          "aria-label",
          isDark ? "Cambiar a modo claro" : "Cambiar a modo oscuro"
        );

        if (icon) {
          icon.textContent = isDark ? "☀️" : "🌙";
        }
      });
    }

    function syncThemeFromStorage() {
      const theme = getPreferredTheme();

      applyTheme(theme);
      syncThemeToggle(theme);
    }

    function normalizeText(value) {
      return normalizeSearchText(value);
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    async function loadSearchItems() {
      if (searchItems) return searchItems;

      const searchUrl = searchShell?.getAttribute("data-search-url");

      if (!searchUrl) {
        searchItems = [];
        return searchItems;
      }

      try {
        const response = await fetch(searchUrl);
        searchItems = await response.json();
      } catch {
        searchItems = [];
      }

      return searchItems;
    }

    function openMenu() {
      if (!globalMenu || !menuToggle) return;

      globalMenu.hidden = false;
      menuToggle.setAttribute("aria-expanded", "true");
    }

    function closeMenu() {
      if (!globalMenu || !menuToggle) return;

      globalMenu.hidden = true;
      menuToggle.setAttribute("aria-expanded", "false");
    }

    function toggleMenu() {
      if (!globalMenu) return;

      if (globalMenu.hidden) {
        openMenu();
        closeSearchPopover();
      } else {
        closeMenu();
      }
    }

    function openSearchShell() {
      if (!searchShell || !searchToggle) return;

      searchShell.classList.add("is-open");
      siteHeader?.classList.add("search-open");
      searchToggle.setAttribute("aria-expanded", "true");
      searchToggle.setAttribute("aria-label", "Cerrar búsqueda");
      syncSearchSubmitIcon();

      window.requestAnimationFrame(() => {
        searchInput?.focus();
      });
    }

    function closeSearchShell() {
      if (!searchShell || !searchToggle) return;

      searchShell.classList.remove("is-open");
      siteHeader?.classList.remove("search-open");
      searchToggle.setAttribute("aria-expanded", "false");
      searchToggle.setAttribute("aria-label", "Abrir búsqueda");
      closeSearchPopover();
      syncSearchSubmitIcon();
    }

    function openSearchPopover() {
      if (!searchPopover) return;

      searchPopover.hidden = false;
    }

    function closeSearchPopover() {
      if (!searchPopover) return;

      searchPopover.hidden = true;
    }

    function isMobileSearch() {
      return window.matchMedia("(max-width: 760px)").matches;
    }

    function syncSearchSubmitIcon() {
      if (!searchSubmit) return;

      const isOpen = Boolean(searchShell?.classList.contains("is-open"));

      if (isMobileSearch() && isOpen) {
        searchSubmit.textContent = "✕";
        searchSubmit.setAttribute("aria-label", "Cerrar búsqueda");
        searchSubmit.classList.add("is-close");
        return;
      }

      searchSubmit.textContent = "🔍";
      searchSubmit.setAttribute("aria-label", "Icono de búsqueda");
      searchSubmit.classList.remove("is-close");
    }

    function updateAllResultsLink(query, hasResults = false) {
      if (!searchAllLink) return;

      const normalizedQuery = normalizeText(query);
      const url = new URL(searchAllLink.href);

      if (normalizedQuery) {
        url.searchParams.set("q", query);
        searchAllLink.textContent = hasResults
          ? "Ver todos los resultados →"
          : "Ir al buscador avanzado →";
      } else {
        url.searchParams.delete("q");
        searchAllLink.textContent = "Ir al buscador avanzado →";
      }

      searchAllLink.href = `${url.pathname}${url.search}`;
    }

    function renderFilters(results) {
      if (!searchFilters) return;

      const counts = getSearchCounts(results);

      if (
        activeSearchType !== "Todos" &&
        !SEARCH_FILTER_ORDER.includes(activeSearchType)
      ) {
        activeSearchType = "Todos";
      }

      if (activeSearchType !== "Todos" && !counts[activeSearchType]) {
        activeSearchType = "Todos";
      }

      const filters = getAvailableSearchFilters(results);

      searchFilters.innerHTML = [
        `<button type="button" data-global-search-filter="Todos">Todos <span>${results.length}</span></button>`,
        ...filters.map(
          ({ type, count }) =>
            `<button type="button" data-global-search-filter="${escapeHtml(type)}">${escapeHtml(type)} <span>${count}</span></button>`
        ),
      ].join("");

      searchFilters
        .querySelectorAll("[data-global-search-filter]")
        .forEach((button) => {
          button.classList.toggle(
            "is-active",
            button.getAttribute("data-global-search-filter") === activeSearchType
          );

          button.addEventListener("click", (event) => {
            event.preventDefault();
            event.stopPropagation();

            activeSearchType =
              button.getAttribute("data-global-search-filter") ?? "Todos";

            renderSearchResults(searchInput?.value ?? "");
            openSearchPopover();
          });
        });
    }

    function renderResultCard(item) {
      return `
        <a href="${escapeHtml(item.url)}" class="global-search-result">
          <span>${escapeHtml(item.type)}</span>
          <strong>${escapeHtml(item.title)}</strong>
          <small>${escapeHtml(item.summary)}</small>
        </a>
      `;
    }

    async function renderSearchResults(rawQuery) {
      if (!searchResults || !searchFilters) return;

      const query = normalizeText(rawQuery);

      updateAllResultsLink(rawQuery, false);

      if (!query) {
        searchResults.innerHTML = `
          <div class="global-search-state">
            Escribe una palabra para comenzar.
          </div>
        `;
        searchFilters.innerHTML = "";
        openSearchPopover();
        return;
      }

      const items = await loadSearchItems();

      const results = getSearchResults(items, rawQuery);

      if (results.length === 0) {
        searchResults.innerHTML = `
          <div class="global-search-state">
            No se encontraron resultados.
          </div>
        `;
        searchFilters.innerHTML = "";
        openSearchPopover();
        return;
      }

      updateAllResultsLink(rawQuery, true);

      renderFilters(results);

      searchFilters
        .querySelectorAll("[data-global-search-filter]")
        .forEach((button) => {
          button.classList.toggle(
            "is-active",
            button.getAttribute("data-global-search-filter") === activeSearchType
          );
        });

      const filteredResults = getDisplaySearchResults(
        results,
        activeSearchType,
        80
      );

      searchResults.innerHTML = filteredResults.map(renderResultCard).join("");

      openSearchPopover();
    }

    syncThemeFromStorage();

    themeToggleButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const activeTheme =
          document.documentElement.dataset.theme === "dark" ? "light" : "dark";

        localStorage.setItem("ebv-theme", activeTheme);
        applyTheme(activeTheme);
        syncThemeToggle(activeTheme);
      });
    });

    menuToggle?.addEventListener("click", toggleMenu);

    searchToggle?.addEventListener("click", (event) => {
      event.preventDefault();
      event.stopPropagation();

      if (searchShell?.classList.contains("is-open")) {
        closeSearchShell();
        return;
      }

      openSearchShell();
      closeMenu();
    });

    searchSubmit?.addEventListener("click", (event) => {
      event.preventDefault();
      event.stopPropagation();

      if (isMobileSearch() && searchShell?.classList.contains("is-open")) {
        closeSearchShell();
        return;
      }

      openSearchShell();
      searchInput?.focus();
    });

    searchInput?.addEventListener("input", () => {
      activeSearchType = "Todos";
      renderSearchResults(searchInput.value);
    });

    searchInput?.addEventListener("focus", () => {
      openSearchShell();
      renderSearchResults(searchInput.value);
    });

    searchPopover?.addEventListener("click", (event) => {
      event.stopPropagation();
    });

    searchFilters?.addEventListener("click", (event) => {
      event.stopPropagation();
    });

    searchResults?.addEventListener("click", (event) => {
      event.stopPropagation();
    });

    searchForm?.addEventListener("submit", (event) => {
      event.preventDefault();

      const query = searchInput?.value?.trim() ?? "";

      if (!query) {
        searchInput?.focus();
        return;
      }

      renderSearchResults(query);
    });

    document.addEventListener("click", (event) => {
      const target = event.target;

      if (!(target instanceof Node)) return;

      const clickedInsideSearch = Boolean(searchShell?.contains(target));
      const clickedInsideMenu = Boolean(globalMenu?.contains(target));
      const clickedMenuToggle = Boolean(menuToggle?.contains(target));

      if (!clickedInsideSearch) {
        closeSearchPopover();

        if (window.matchMedia("(max-width: 760px)").matches) {
          closeSearchShell();
        }
      }

      if (!clickedInsideMenu && !clickedMenuToggle) {
        closeMenu();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeMenu();
        closeSearchShell();
      }
    });

    window.addEventListener("pageshow", () => {
      syncThemeFromStorage();
    });

    window
      .matchMedia("(prefers-color-scheme: dark)")
      .addEventListener("change", () => {
        const storedTheme = localStorage.getItem("ebv-theme");

        if (storedTheme !== "dark" && storedTheme !== "light") {
          syncThemeFromStorage();
        }
      });
  })();
</script>


  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
  }

  body {
    margin: 0;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    background: #f8f5ee;
    color: #2d2418;
  }

  a {
    color: inherit;
  }

  .site-header {
    width: min(1100px, calc(100% - 32px));
    margin: 0 auto;
    padding: 24px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .logo {
    font-weight: 800;
    text-decoration: none;
    color: #5d3212;
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
  }

  .nav a {
    padding: 9px 12px;
    border-radius: 999px;
    color: #5d3212;
    font-weight: 800;
    text-decoration: none;
  }

  .nav a:hover {
    background: #fff7e8;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .header-search {
    display: inline-flex;
    align-items: center;
    width: min(240px, 100%);
    min-height: 40px;
    border: 1px solid #eadcc4;
    border-radius: 999px;
    background: #fffaf0;
    overflow: hidden;
  }

  .header-search input {
    width: 100%;
    min-width: 0;
    height: 40px;
    padding: 0 4px 0 14px;
    border: 0;
    outline: 0;
    background: transparent;
    color: #2d2418;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .header-search input::placeholder {
    color: #8a7560;
    opacity: 1;
  }

  .header-search button {
    display: inline-flex;
    width: 40px;
    height: 40px;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    border: 0;
    border-left: 1px solid #eadcc4;
    background: #fff7e8;
    color: #5d3212;
    font: inherit;
    cursor: pointer;
  }

  .header-search button:hover {
    background: #f1dfc5;
  }

  .header-search:focus-within {
    border-color: #c8a982;
    box-shadow: 0 0 0 4px rgba(200, 169, 130, 0.22);
  }

  .theme-toggle {
    display: inline-flex;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    padding: 0;
    border-radius: 999px;
    border: 1px solid #c8a982;
    background: #fff7e8;
    color: #5d3212;
    font: inherit;
    font-size: 1.05rem;
    font-weight: 800;
    cursor: pointer;
  }

  .theme-toggle:hover {
    background: #fffaf0;
  }

  .theme-toggle-icon {
    line-height: 1;
  }

  .page {
    width: min(1100px, calc(100% - 32px));
    margin: 0 auto;
    padding: 32px 0 72px;
  }

  .hero {
    position: relative;
    padding: 64px 32px;
    border-radius: 28px;
    background: #fffaf0;
    border: 1px solid #eadcc4;
    box-shadow: 0 20px 60px rgba(45, 36, 24, 0.08);
    overflow: hidden;
  }

  .hero::after {
    content: "";
    position: absolute;
    right: -90px;
    bottom: -120px;
    width: 320px;
    height: 320px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(200, 169, 130, 0.28), transparent 68%);
    pointer-events: none;
  }

  .hero > * {
    position: relative;
    z-index: 1;
  }

  .eyebrow {
    margin: 0 0 16px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a5a2b;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .subtitle {
    max-width: 760px;
    margin: 24px 0 0;
    font-size: 1.2rem;
    line-height: 1.7;
    color: #5e5143;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    border-radius: 999px;
    background: #5d3212;
    color: #fffaf0;
    font-weight: 700;
    text-decoration: none;
  }

  .button.secondary {
    background: transparent;
    color: #5d3212;
    border: 1px solid #c8a982;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 24px;
  }

  .card {
    padding: 24px;
    border-radius: 22px;
    background: white;
    border: 1px solid #eadcc4;
  }

  .card h2,
  .card h3 {
    margin: 0 0 8px;
  }

  .card p {
    margin: 0;
    line-height: 1.6;
    color: #6a5c4d;
  }

  .section {
    margin-top: 32px;
    padding: 32px;
    border-radius: 24px;
    background: white;
    border: 1px solid #eadcc4;
  }

  .section h2 {
    margin-top: 0;
  }

  .content {
    max-width: 760px;
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .breadcrumb {
    margin-bottom: 16px;
    font-size: 0.95rem;
    color: #7a6a58;
  }

  .list {
    padding-left: 1.2rem;
    line-height: 1.8;
  }

  .pill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding: 0;
    list-style: none;
  }

  .pill-list a,
  .pill-list span {
    display: inline-flex;
    padding: 8px 12px;
    border-radius: 999px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #5d3212;
    text-decoration: none;
    font-weight: 650;
  }

  .entity-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-top: 24px;
  }

  .entity-card {
    display: block;
    padding: 22px;
    border-radius: 22px;
    background: white;
    border: 1px solid #eadcc4;
    text-decoration: none;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease;
  }

  .entity-card:hover {
    transform: translateY(-2px);
    border-color: #c8a982;
    box-shadow: 0 16px 36px rgba(45, 36, 24, 0.08);
  }

  .entity-card h2 {
    margin: 0 0 8px;
    font-size: 1.15rem;
    color: #2d2418;
  }

  .entity-card p {
    margin: 0;
    line-height: 1.6;
    color: #6a5c4d;
  }

  .meta {
    display: inline-flex;
    margin-bottom: 12px;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #8a5a2b;
  }

  .timeline {
    position: relative;
    display: grid;
    gap: 18px;
    margin-top: 32px;
  }

  .timeline-item {
    position: relative;
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 18px;
    align-items: start;
  }

  .timeline-date {
    position: sticky;
    top: 16px;
    padding: 12px 14px;
    border-radius: 18px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #8a5a2b;
    font-weight: 800;
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .timeline-card {
    position: relative;
    padding: 24px;
    border-radius: 22px;
    background: white;
    border: 1px solid #eadcc4;
  }

  .timeline-card::before {
    content: "";
    position: absolute;
    left: -27px;
    top: 30px;
    width: 14px;
    height: 14px;
    border-radius: 999px;
    background: #5d3212;
    box-shadow: 0 0 0 6px #f8f5ee;
  }

  .timeline-card h2 {
    margin: 0 0 8px;
    font-size: 1.25rem;
  }

  .timeline-card p {
    margin: 0;
    line-height: 1.6;
    color: #6a5c4d;
  }

  .timeline-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 14px 0 0;
  }

  .timeline-meta span {
    display: inline-flex;
    padding: 6px 10px;
    border-radius: 999px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #5d3212;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .place-hero {
    position: relative;
    display: grid;
    grid-template-columns: 1fr minmax(220px, 320px);
    gap: 28px;
    align-items: end;
    overflow: hidden;
  }

  .place-hero::after {
    content: "";
    position: absolute;
    right: -90px;
    bottom: -120px;
    width: 320px;
    height: 320px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(200, 169, 130, 0.28), transparent 68%);
    pointer-events: none;
  }

  .place-hero-content {
    position: relative;
    z-index: 1;
  }

  .place-hero-card {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 10px;
    padding: 24px;
    border-radius: 24px;
    background: white;
    border: 1px solid #eadcc4;
    box-shadow: 0 18px 42px rgba(45, 36, 24, 0.1);
  }

  .place-hero-card span {
    color: #8a5a2b;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .place-hero-card strong {
    color: #2d2418;
    font-size: 1.5rem;
    line-height: 1.2;
  }

  .place-hero-card p {
    margin: 0;
    color: #6a5c4d;
    line-height: 1.6;
  }

  .place-meta-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-top: 24px;
  }

  .place-meta-card {
    padding: 22px;
    border-radius: 22px;
    background: white;
    border: 1px solid #eadcc4;
    box-shadow: 0 14px 34px rgba(45, 36, 24, 0.05);
  }

  .place-meta-card span {
    display: block;
    margin-bottom: 8px;
    color: #8a5a2b;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .place-meta-card strong {
    display: block;
    color: #2d2418;
    font-size: 1.02rem;
    line-height: 1.4;
    overflow-wrap: anywhere;
  }

  .place-map-panel,
  .place-importance-section,
  .place-events-section,
  .place-lessons-section,
  .place-empty-section {
    background: white;
  }

  .place-map-preview,
  .place-empty-map,
  .place-importance-card {
    display: grid;
    gap: 14px;
    padding: 22px;
    border-radius: 22px;
    background: #fffaf0;
    border: 1px solid #eadcc4;
  }

  .place-map-preview strong,
  .place-empty-map strong {
    display: block;
    color: #2d2418;
    font-size: 1.1rem;
    line-height: 1.35;
  }

  .place-map-preview p,
  .place-empty-map p,
  .place-importance-card p,
  .place-empty-section p {
    max-width: 760px;
    margin: 0;
    color: #6a5c4d;
    line-height: 1.7;
  }

  .place-map-link {
    display: inline-flex;
    width: fit-content;
    color: #5d3212;
    font-weight: 900;
    text-decoration: none;
  }

  .place-map-link:hover {
    text-decoration: underline;
  }

  .place-events-grid,
  .place-lessons-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .place-event-card,
  .place-lesson-card {
    display: grid;
    align-content: start;
    gap: 8px;
    min-height: 176px;
    padding: 22px;
    border-radius: 22px;
    background: #fffaf0;
    border: 1px solid #eadcc4;
    text-decoration: none;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .place-event-card:hover,
  .place-lesson-card:hover {
    transform: translateY(-2px);
    border-color: #c8a982;
    box-shadow: 0 14px 30px rgba(45, 36, 24, 0.08);
  }

  .place-event-card span,
  .place-lesson-card span {
    color: #8a5a2b;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .place-event-card strong,
  .place-lesson-card strong {
    color: #2d2418;
    font-size: 1.12rem;
    line-height: 1.35;
  }

  .place-event-card small,
  .place-lesson-card small {
    color: #6a5c4d;
    font-size: 0.92rem;
    line-height: 1.55;
  }


  .places-index-hero {
    position: relative;
    display: grid;
    grid-template-columns: 1fr minmax(220px, 300px);
    gap: 28px;
    align-items: end;
    overflow: hidden;
  }

  .places-index-hero::after {
    content: "";
    position: absolute;
    right: -90px;
    bottom: -120px;
    width: 320px;
    height: 320px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(200, 169, 130, 0.28), transparent 68%);
    pointer-events: none;
  }

  .places-index-hero-content {
    position: relative;
    z-index: 1;
  }

  .places-index-hero-card {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 8px;
    padding: 24px;
    border-radius: 24px;
    background: white;
    border: 1px solid #eadcc4;
    box-shadow: 0 18px 42px rgba(45, 36, 24, 0.1);
  }

  .places-index-hero-card span,
  .places-summary-card span,
  .place-directory-card-main span {
    color: #8a5a2b;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .places-index-hero-card strong {
    color: #2d2418;
    font-size: 3rem;
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .places-index-hero-card p,
  .places-summary-card p,
  .place-directory-card-main p {
    margin: 0;
    color: #6a5c4d;
    line-height: 1.6;
  }

  .places-summary-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-top: 24px;
  }

  .places-summary-card {
    display: grid;
    gap: 8px;
    padding: 22px;
    border-radius: 22px;
    background: white;
    border: 1px solid #eadcc4;
    box-shadow: 0 14px 34px rgba(45, 36, 24, 0.05);
  }

  .places-summary-card strong {
    color: #2d2418;
    font-size: 2rem;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .places-directory-section {
    background: white;
  }

  .places-directory-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .place-directory-card {
    display: grid;
    grid-template-rows: 1fr auto auto;
    gap: 16px;
    min-height: 330px;
    padding: 22px;
    border-radius: 22px;
    background: #fffaf0;
    border: 1px solid #eadcc4;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .place-directory-card:hover {
    transform: translateY(-2px);
    border-color: #c8a982;
    box-shadow: 0 14px 30px rgba(45, 36, 24, 0.08);
  }

  .place-directory-card-main {
    display: grid;
    align-content: start;
    gap: 10px;
  }

  .place-directory-card-main h2 {
    margin: 0;
    color: #2d2418;
    font-size: 1.25rem;
    line-height: 1.25;
  }

  .place-directory-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .place-directory-meta span {
    display: inline-flex;
    min-height: 28px;
    align-items: center;
    padding: 0 10px;
    border-radius: 999px;
    background: white;
    border: 1px solid #eadcc4;
    color: #5d3212;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .place-directory-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .place-directory-link {
    display: inline-flex;
    min-height: 38px;
    align-items: center;
    justify-content: center;
    padding: 0 14px;
    border-radius: 999px;
    background: transparent;
    border: 1px solid #c8a982;
    color: #5d3212;
    font-size: 0.9rem;
    font-weight: 900;
    text-decoration: none;
  }

  .place-directory-link.primary {
    background: #5d3212;
    border-color: #5d3212;
    color: #fffaf0;
  }

  .place-directory-link:hover {
    background: #fff7e8;
  }

  .place-directory-link.primary:hover {
    background: #6d3a16;
  }

  .place-directory-link.disabled {
    cursor: default;
    opacity: 0.66;
  }

  .map-shell {
    margin-top: 32px;
    overflow: hidden;
    border-radius: 28px;
    background: white;
    border: 1px solid #eadcc4;
    box-shadow: 0 20px 60px rgba(45, 36, 24, 0.08);
  }

  #biblical-map {
    width: 100%;
    height: 620px;
  }

  .leaflet-popup-pane {
    z-index: 900;
  }

  .map-layer-switcher {
    min-width: 250px;
    padding: 12px;
    border-radius: 20px;
    background: rgba(255, 250, 240, 0.94);
    border: 1px solid rgba(234, 220, 196, 0.95);
    box-shadow: 0 18px 42px rgba(45, 36, 24, 0.18);
    backdrop-filter: blur(14px);
  }

  .map-layer-current {
    display: none;
    width: 100%;
    min-height: 38px;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 0 12px;
    border-radius: 999px;
    border: 1px solid #eadcc4;
    background: #fff7e8;
    color: #5d3212;
    font: inherit;
    cursor: pointer;
  }

  .map-layer-current span {
    color: #8a5a2b;
    font-size: 0.64rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .map-layer-current strong {
    color: #5d3212;
    font-size: 0.88rem;
    font-weight: 900;
  }

  .map-layer-current em {
    color: #8a5a2b;
    font-style: normal;
    font-weight: 900;
    transition: transform 160ms ease;
  }

  .map-layer-switcher.is-open .map-layer-current em {
    transform: rotate(180deg);
  }

  .map-layer-options {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  .map-layer-button {
    min-height: 36px;
    padding: 0 10px;
    border: 1px solid #eadcc4;
    border-radius: 999px;
    background: rgba(255, 247, 232, 0.72);
    color: #5d3212;
    font: inherit;
    font-size: 0.86rem;
    font-weight: 900;
    cursor: pointer;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .map-layer-button:hover {
    background: #fff7e8;
    border-color: #c8a982;
  }

  .map-layer-button.is-active {
    background: #5d3212;
    border-color: #5d3212;
    color: #fffaf0;
    box-shadow: 0 8px 18px rgba(93, 50, 18, 0.24);
  }

  .map-layer-button.is-active:hover {
    background: #5d3212;
    border-color: #5d3212;
  }

  .map-layer-button:focus-visible,
  .map-layer-current:focus-visible {
    outline: 3px solid rgba(200, 169, 130, 0.5);
    outline-offset: 2px;
  }

  .ebv-map-marker {
    background: transparent;
    border: 0;
  }

  .ebv-map-marker span {
    position: relative;
    display: block;
    width: 30px;
    height: 30px;
    transform: rotate(-45deg);
    border-radius: 999px 999px 999px 0;
    background: #7a3f16;
    border: 3px solid #fffaf0;
    box-shadow:
      0 8px 18px rgba(45, 36, 24, 0.34),
      0 0 0 2px rgba(122, 63, 22, 0.25);
  }

  .ebv-map-marker span::after {
    content: "";
    position: absolute;
    inset: 8px;
    border-radius: 999px;
    background: #f2c078;
    box-shadow: inset 0 0 0 2px rgba(93, 50, 18, 0.22);
  }

  .map-popup {
    width: min(280px, calc(100vw - 112px));
    max-width: min(280px, calc(100vw - 112px));
    box-sizing: border-box;
  }

  .map-popup,
  .map-popup * {
    box-sizing: border-box;
  }

  .map-popup-compact {
    display: grid;
    gap: 10px;
    width: 100%;
    min-width: 0;
    max-width: 100%;
  }

  .map-popup-compact span {
    color: #8a5a2b;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .map-popup h3 {
    margin: 0;
    color: #2d2418;
    font-size: 1.12rem;
    line-height: 1.25;
  }

  .map-popup p {
    margin: 0;
    color: #5e5143;
    line-height: 1.55;
  }

  .map-popup ul {
    margin: 6px 0 12px;
    padding-left: 1.2rem;
  }

