---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Enciclopedia Bíblica Visual con rutas guiadas, mapas, líneas de tiempo y recursos visuales.",
} = Astro.props;

const siteName = "Enciclopedia Bíblica Visual";
const pageTitle = title === siteName ? title : `${title} | ${siteName}`;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
  </head>

  <body>
    <header class="site-header">
      <a href="/" class="logo">Enciclopedia Bíblica Visual</a>

      <nav class="nav">
        <a href="/rutas/panorama-visual-de-la-biblia/">Ruta principal</a>
        <a href="/explorar/">Explorar</a>
        <a href="/buscar/">Buscar</a>
        <a href="/biblia/">Biblia</a>
        <a href="/libros/">Libros</a>
        <a href="/pasajes/">Pasajes</a>
        <a href="/linea-de-tiempo/">Línea de tiempo</a>
        <a href="/mapa/">Mapa</a>
        <a href="/temas/">Temas</a>
        <a href="/personajes/">Personajes</a>
        <a href="/lugares/">Lugares</a>
        <a href="/eventos/">Eventos</a>
        <a href="/glosario/">Glosario</a>
      </nav>
    </header>

    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
  }

  body {
    margin: 0;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    background: #f8f5ee;
    color: #2d2418;
  }

  a {
    color: inherit;
  }

  .site-header {
    width: min(1100px, calc(100% - 32px));
    margin: 0 auto;
    padding: 24px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .logo {
    font-weight: 800;
    text-decoration: none;
    color: #5d3212;
  }

  .nav {
    display: flex;
    gap: 16px;
    font-size: 0.95rem;
  }

  .nav a {
    color: #6a5c4d;
    text-decoration: none;
  }

  .nav a:hover {
    color: #5d3212;
    text-decoration: underline;
  }

  .page {
    width: min(1100px, calc(100% - 32px));
    margin: 0 auto;
    padding: 32px 0 72px;
  }

  .hero {
    padding: 64px 32px;
    border-radius: 28px;
    background: #fffaf0;
    border: 1px solid #eadcc4;
    box-shadow: 0 20px 60px rgba(45, 36, 24, 0.08);
  }

  .eyebrow {
    margin: 0 0 16px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a5a2b;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .subtitle {
    max-width: 760px;
    margin: 24px 0 0;
    font-size: 1.2rem;
    line-height: 1.7;
    color: #5e5143;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    border-radius: 999px;
    background: #5d3212;
    color: #fffaf0;
    font-weight: 700;
    text-decoration: none;
  }

  .button.secondary {
    background: transparent;
    color: #5d3212;
    border: 1px solid #c8a982;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 24px;
  }

  .card {
    padding: 24px;
    border-radius: 22px;
    background: white;
    border: 1px solid #eadcc4;
  }

  .card h2,
  .card h3 {
    margin: 0 0 8px;
  }

  .card p {
    margin: 0;
    line-height: 1.6;
    color: #6a5c4d;
  }

  .section {
    margin-top: 32px;
    padding: 32px;
    border-radius: 24px;
    background: white;
    border: 1px solid #eadcc4;
  }

  .section h2 {
    margin-top: 0;
  }

  .content {
    max-width: 760px;
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .breadcrumb {
    margin-bottom: 16px;
    font-size: 0.95rem;
    color: #7a6a58;
  }

  .list {
    padding-left: 1.2rem;
    line-height: 1.8;
  }

  .pill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding: 0;
    list-style: none;
  }

  .pill-list a,
  .pill-list span {
    display: inline-flex;
    padding: 8px 12px;
    border-radius: 999px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #5d3212;
    text-decoration: none;
    font-weight: 650;
  }

  .entity-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-top: 24px;
  }

  .entity-card {
    display: block;
    padding: 22px;
    border-radius: 22px;
    background: white;
    border: 1px solid #eadcc4;
    text-decoration: none;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease;
  }

  .entity-card:hover {
    transform: translateY(-2px);
    border-color: #c8a982;
    box-shadow: 0 16px 36px rgba(45, 36, 24, 0.08);
  }

  .entity-card h2 {
    margin: 0 0 8px;
    font-size: 1.15rem;
    color: #2d2418;
  }

  .entity-card p {
    margin: 0;
    line-height: 1.6;
    color: #6a5c4d;
  }

  .meta {
    display: inline-flex;
    margin-bottom: 12px;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #8a5a2b;
  }

  .timeline {
    position: relative;
    display: grid;
    gap: 18px;
    margin-top: 32px;
  }

  .timeline-item {
    position: relative;
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 18px;
    align-items: start;
  }

  .timeline-date {
    position: sticky;
    top: 16px;
    padding: 12px 14px;
    border-radius: 18px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #8a5a2b;
    font-weight: 800;
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .timeline-card {
    position: relative;
    padding: 24px;
    border-radius: 22px;
    background: white;
    border: 1px solid #eadcc4;
  }

  .timeline-card::before {
    content: "";
    position: absolute;
    left: -27px;
    top: 30px;
    width: 14px;
    height: 14px;
    border-radius: 999px;
    background: #5d3212;
    box-shadow: 0 0 0 6px #f8f5ee;
  }

  .timeline-card h2 {
    margin: 0 0 8px;
    font-size: 1.25rem;
  }

  .timeline-card p {
    margin: 0;
    line-height: 1.6;
    color: #6a5c4d;
  }

  .timeline-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 14px 0 0;
  }

  .timeline-meta span {
    display: inline-flex;
    padding: 6px 10px;
    border-radius: 999px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #5d3212;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .map-shell {
    margin-top: 32px;
    overflow: hidden;
    border-radius: 28px;
    background: white;
    border: 1px solid #eadcc4;
    box-shadow: 0 20px 60px rgba(45, 36, 24, 0.08);
  }

  #biblical-map {
    width: 100%;
    height: 620px;
  }

  .map-popup {
    max-width: 260px;
  }

  .map-popup h3 {
    margin: 0 0 6px;
    font-size: 1rem;
  }

  .map-popup p {
    margin: 0 0 10px;
    line-height: 1.5;
  }

  .map-popup a {
    font-weight: 800;
    color: #5d3212;
  }

    .chapter-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }

  .chapter-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 46px;
    height: 46px;
    padding: 0 12px;
    border-radius: 14px;
    background: white;
    border: 1px solid #eadcc4;
    color: #5d3212;
    font-weight: 800;
    text-decoration: none;
  }

  .chapter-link:hover {
    border-color: #c8a982;
    background: #fff7e8;
  }

  .bible-reader {
    display: grid;
    gap: 14px;
    margin-top: 24px;
  }

  .verse {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid #eadcc4;
  }

  .verse-number {
    color: #8a5a2b;
    font-weight: 900;
    font-size: 0.9rem;
  }

  .verse-text {
    margin: 0;
    line-height: 1.8;
    color: #2d2418;
    font-size: 1.08rem;
    white-space: pre-line;
  }

  .chapter-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 12px;
    margin-top: 28px;
  }

  .copyright-box {
    margin-top: 28px;
    padding: 18px;
    border-radius: 18px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #6a5c4d;
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .passage-reader {
    display: grid;
    gap: 28px;
    margin-top: 24px;
  }

  .passage-chapter {
    display: grid;
    gap: 10px;
  }

  .passage-chapter h3 {
    margin: 0 0 6px;
    color: #5d3212;
    font-size: 1.2rem;
  }

  .verse-ref-link {
    color: inherit;
    text-decoration: none;
  }

  .verse-ref-link:hover {
    text-decoration: underline;
  }

  .search-panel {
    display: grid;
    gap: 18px;
    margin-top: 28px;
  }

  .search-input {
    width: 100%;
    padding: 18px 20px;
    border-radius: 20px;
    border: 1px solid #eadcc4;
    background: white;
    color: #2d2418;
    font-size: 1.05rem;
    outline: none;
  }

  .search-input:focus {
    border-color: #c8a982;
    box-shadow: 0 0 0 4px rgba(200, 169, 130, 0.18);
  }

  .search-help {
    margin: 0;
    color: #6a5c4d;
    line-height: 1.6;
  }

  .search-results {
    display: grid;
    gap: 14px;
    margin-top: 24px;
  }

  .search-result {
    display: block;
    padding: 20px;
    border-radius: 20px;
    background: white;
    border: 1px solid #eadcc4;
    text-decoration: none;
  }

  .search-result:hover {
    border-color: #c8a982;
    background: #fffaf0;
  }

  .search-result h2 {
    margin: 0 0 8px;
    color: #2d2418;
    font-size: 1.15rem;
  }

  .search-result p {
    margin: 0;
    color: #6a5c4d;
    line-height: 1.6;
  }

  .search-result-type {
    display: inline-flex;
    margin-bottom: 10px;
    padding: 5px 9px;
    border-radius: 999px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #8a5a2b;
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .search-empty {
    padding: 24px;
    border-radius: 20px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #6a5c4d;
    line-height: 1.6;
  }

  .explore-group {
    display: grid;
    gap: 18px;
    margin-top: 28px;
  }

  .explore-heading {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 6px;
  }

  .explore-heading h2 {
    margin: 0;
  }

  .explore-heading p {
    margin: 0;
    color: #6a5c4d;
    line-height: 1.5;
  }

  .explore-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .explore-card {
    display: block;
    padding: 22px;
    border-radius: 22px;
    background: white;
    border: 1px solid #eadcc4;
    text-decoration: none;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease;
  }

  .explore-card:hover {
    transform: translateY(-2px);
    border-color: #c8a982;
    box-shadow: 0 16px 36px rgba(45, 36, 24, 0.08);
  }

  .explore-card h3 {
    margin: 0 0 8px;
    color: #2d2418;
    font-size: 1.15rem;
  }

  .explore-card p {
    margin: 0;
    color: #6a5c4d;
    line-height: 1.6;
  }

  .explore-count {
    display: inline-flex;
    margin-bottom: 12px;
    padding: 5px 9px;
    border-radius: 999px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #8a5a2b;
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  @media (max-width: 760px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .hero {
      padding: 40px 22px;
    }

    .grid {
      grid-template-columns: 1fr;
    }

    .entity-list {
      grid-template-columns: 1fr;
    }

    .timeline-item {
      grid-template-columns: 1fr;
    }

    .timeline-date {
      position: static;
    }

    .timeline-card::before {
      display: none;
    }

    #biblical-map {
      height: 460px;
    }

    .section {
      padding: 24px;
    }

    .explore-grid {
      grid-template-columns: 1fr;
    }
  }
</style>