---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  getBibleRefsByLessonId,
  getGlossaryByLessonId,
  getLessonBySlug,
  getPeopleByLessonId,
  getPlacesByLessonId,
  getPointsByLessonId,
  getQuestionsByLessonId,
  getTopicsByLessonId,
} from "../../../lib/queries";

const lesson = getLessonBySlug("la-biblia-como-una-sola-historia");

if (!lesson) {
  throw new Error("No se encontró la lección.");
}

const bibleRefs = getBibleRefsByLessonId(lesson.id);
const points = getPointsByLessonId(lesson.id);
const questions = getQuestionsByLessonId(lesson.id);
const topics = getTopicsByLessonId(lesson.id);
const people = getPeopleByLessonId(lesson.id);
const places = getPlacesByLessonId(lesson.id);
const glossary = getGlossaryByLessonId(lesson.id);
---

<BaseLayout
  title={lesson.title}
  description={lesson.summary ?? "Lección de la Enciclopedia Bíblica Visual."}
>
  <main class="page">
    <div class="breadcrumb">
      <a href="/">Inicio</a> →
      <a href="/rutas/panorama-visual-de-la-biblia/">Panorama Visual de la Biblia</a> →
      Lección {lesson.lesson_number}
    </div>

    <section class="hero">
      <p class="eyebrow">{lesson.eyebrow}</p>

      <h1>{lesson.title}</h1>

      <p class="subtitle">
        {lesson.summary}
      </p>
    </section>

    <section class="section">
      <h2>Idea principal</h2>

      <div class="content">
        <p>{lesson.main_idea}</p>
      </div>
    </section>

    <section class="section">
      <h2>Resumen en 5 ideas</h2>

      <ol class="list">
        {points.map((point) => (
          <li>{point.point_text}</li>
        ))}
      </ol>
    </section>

    <section class="section">
      <h2>Pasajes bíblicos principales</h2>

      <ul class="pill-list">
        {bibleRefs.map((ref) => (
          <li>
            <span>{ref.reference}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="section">
      <h2>Explicación sencilla</h2>

      <div class="content">
        <p>{lesson.explanation}</p>
      </div>
    </section>

    <section class="section">
      <h2>La Biblia en una línea</h2>

      <ul class="pill-list">
        <li><span>Creación</span></li>
        <li><span>Caída</span></li>
        <li><span>Promesa</span></li>
        <li><span>Israel</span></li>
        <li><span>Jesús</span></li>
        <li><span>Iglesia</span></li>
        <li><span>Nueva creación</span></li>
      </ul>
    </section>

    <section class="grid">
      <article class="card">
        <h2>Personajes</h2>
        <ul class="list">
          {people.map((person) => (
            <li>{person.title}</li>
          ))}
        </ul>
      </article>

      <article class="card">
        <h2>Temas</h2>
        <ul class="list">
          {topics.map((topic) => (
            <li>{topic.title}</li>
          ))}
        </ul>
      </article>

      <article class="card">
        <h2>Glosario</h2>
        <ul class="list">
          {glossary.map((term) => (
            <li>{term.title}</li>
          ))}
        </ul>
      </article>
    </section>

    <section class="section">
      <h2>Lugares relacionados</h2>

      <ul class="pill-list">
        {places.map((place) => (
          <li>
            <span>{place.title}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="section">
      <h2>Qué debo recordar</h2>

      <div class="content">
        <p>{lesson.remember}</p>
      </div>
    </section>

    <section class="section">
      <h2>Preguntas de estudio</h2>

      <ol class="list">
        {questions.map((question) => (
          <li>{question.question_text}</li>
        ))}
      </ol>
    </section>

    <section class="section">
      <a href="/rutas/panorama-visual-de-la-biblia/" class="button secondary">
        Volver a la ruta
      </a>
    </section>
  </main>
</BaseLayout>