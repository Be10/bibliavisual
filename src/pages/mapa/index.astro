---
import "leaflet/dist/leaflet.css";
import { sitePath } from "../../lib/site-paths";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getEventsByPlaceId, getMapPlaces } from "../../lib/queries";

const places = getMapPlaces().map((place) => ({
  ...place,
  events: getEventsByPlaceId(place.id).map((event) => ({
    title: event.title,
    slug: event.slug,
  })),
}));
---

<BaseLayout
  title="Mapa bíblico"
  description="Mapa interactivo con lugares importantes de la historia bíblica."
>
  <main class="page">
    <div class="breadcrumb">
      <a href={sitePath("/")}>Inicio</a> → Mapa bíblico
    </div>

    <section class="hero">
      <p class="eyebrow">Mapa interactivo</p>

      <h1>Mapa bíblico</h1>

      <p class="subtitle">
        Una vista de lugares bíblicos importantes. Este mapa ayuda a ubicar
        geográficamente eventos, personajes y lugares de la historia bíblica.
      </p>

      <div class="actions">
        <a href={sitePath("/lugares/")} class="button secondary">
          Ver lugares
        </a>
      </div>
    </section>

    <section class="map-shell">
      <div id="biblical-map"></div>
    </section>

    <script type="application/json" id="map-places" set:html={JSON.stringify(places)} />
  </main>
</BaseLayout>

<script>
  import L from "leaflet";
  import markerIcon2xUrl from "leaflet/dist/images/marker-icon-2x.png";
  import markerIconUrl from "leaflet/dist/images/marker-icon.png";
  import markerShadowUrl from "leaflet/dist/images/marker-shadow.png";

  type MapPlace = {
    id: string;
    name: string;
    slug: string;
    place_type: string | null;
    summary: string | null;
    latitude: number;
    longitude: number;
    map_zoom: number | null;
    geographical_certainty: string | null;
    events: {
      title: string;
      slug: string;
    }[];
  };

  delete (L.Icon.Default.prototype as any)._getIconUrl;

  L.Icon.Default.mergeOptions({
    iconRetinaUrl: markerIcon2xUrl.src ?? markerIcon2xUrl,
    iconUrl: markerIconUrl.src ?? markerIconUrl,
    shadowUrl: markerShadowUrl.src ?? markerShadowUrl,
  });

  const baseUrl = import.meta.env.BASE_URL;

  function clientSitePath(path: string): string {
    const cleanBase = baseUrl.replace(/\/$/, "");
    const cleanPath = path.startsWith("/") ? path : `/${path}`;

    return `${cleanBase}${cleanPath}`;
  }

const placesElement = document.getElementById("map-places");
const places = placesElement?.textContent
  ? (JSON.parse(placesElement.textContent) as MapPlace[])
  : [];

const selectedPlaceSlug = new URLSearchParams(window.location.search).get("lugar");

const visiblePlaces = selectedPlaceSlug
  ? places.filter((place) => place.slug === selectedPlaceSlug)
  : places;

const map = L.map("biblical-map", {
  scrollWheelZoom: false,
}).setView([31.778, 35.2354], 7);

  const lightLayer = L.tileLayer(
    "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png",
    {
      subdomains: "abcd",
      maxZoom: 20,
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
    }
  );

  const terrainLayer = L.tileLayer(
    "https://server.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}",
    {
      maxZoom: 19,
      attribution:
        "Tiles &copy; Esri &mdash; Sources: Esri, HERE, Garmin, FAO, NOAA, USGS, OpenStreetMap contributors, and the GIS User Community",
    }
  );

  const satelliteLayer = L.tileLayer(
    "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}",
    {
      maxZoom: 19,
      attribution:
        "Tiles &copy; Esri &mdash; Source: Esri, Maxar, Earthstar Geographics, and the GIS User Community",
    }
  );

  const baseLayers = {
    "Satélite": satelliteLayer,
    "Terreno": terrainLayer,
    "Claro": lightLayer,
  };

  let activeBaseLayer = satelliteLayer;

  satelliteLayer.addTo(map);

  const layerControl = L.control({
    position: "topright",
  });

  layerControl.onAdd = () => {
    const container = L.DomUtil.create("div", "map-layer-switcher");

    container.innerHTML = `
      <button
        type="button"
        class="map-layer-current"
        data-layer-toggle
        aria-expanded="false"
      >
        <span>Tipo de mapa</span>
        <strong data-current-layer>Satélite</strong>
        <em aria-hidden="true">▾</em>
      </button>

      <div class="map-layer-options" role="group" aria-label="Tipo de mapa">
        ${Object.keys(baseLayers)
          .map(
            (layerName) => `
              <button
                type="button"
                class="map-layer-button ${layerName === "Satélite" ? "is-active" : ""}"
                data-layer-name="${layerName}"
                aria-pressed="${layerName === "Satélite" ? "true" : "false"}"
              >
                ${layerName}
              </button>
            `
          )
          .join("")}
      </div>
    `;

    L.DomEvent.disableClickPropagation(container);
    L.DomEvent.disableScrollPropagation(container);

    const toggleButton = container.querySelector<HTMLButtonElement>("[data-layer-toggle]");
    const currentLayerLabel = container.querySelector<HTMLElement>("[data-current-layer]");
    const buttons = Array.from(
      container.querySelectorAll<HTMLButtonElement>("[data-layer-name]")
    );

    toggleButton?.addEventListener("click", () => {
      const isOpen = container.classList.toggle("is-open");
      toggleButton.setAttribute("aria-expanded", String(isOpen));
    });

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const layerName = button.dataset.layerName as keyof typeof baseLayers;
        const selectedLayer = baseLayers[layerName];

        if (!selectedLayer) {
          return;
        }

        if (selectedLayer !== activeBaseLayer) {
          map.removeLayer(activeBaseLayer);
          selectedLayer.addTo(map);
          activeBaseLayer = selectedLayer;
        }

        if (currentLayerLabel) {
          currentLayerLabel.textContent = layerName;
        }

        buttons.forEach((currentButton) => {
          const isActive = currentButton === button;

          currentButton.classList.toggle("is-active", isActive);
          currentButton.setAttribute("aria-pressed", String(isActive));
        });

        container.classList.remove("is-open");
        toggleButton?.setAttribute("aria-expanded", "false");
      });
    });

    return container;
  };

  layerControl.addTo(map);

  const bounds = L.latLngBounds([]);
  const markersBySlug = new Map<string, L.Marker>();

  visiblePlaces.forEach((place) => {
    const latLng: [number, number] = [place.latitude, place.longitude];

    const marker = L.marker(latLng).addTo(map);

    markersBySlug.set(place.slug, marker);

    const eventsHtml =
      place.events.length > 0
        ? `
          <p><strong>Eventos:</strong></p>
          <ul>
            ${place.events
              .map(
                (event) =>
                  `<li><a href="${clientSitePath(`/eventos/${event.slug}/`)}">${event.title}</a></li>`
              )
              .join("")}
          </ul>
        `
        : "";

    marker.bindPopup(`
      <div class="map-popup">
        <h3>${place.name}</h3>
        <p>${place.summary ?? ""}</p>
        <p><strong>Certeza:</strong> ${place.geographical_certainty ?? "Pendiente"}</p>
        ${eventsHtml}
        <a href="${clientSitePath(`/lugares/${place.slug}/`)}">Ver lugar</a>
      </div>
    `);

    bounds.extend(latLng);
  });

if (visiblePlaces.length > 0) {
  map.fitBounds(bounds, {
    padding: [48, 48],
    maxZoom: selectedPlaceSlug ? 10 : 8,
  });
}

if (selectedPlaceSlug) {
  const selectedMarker = markersBySlug.get(selectedPlaceSlug);

  if (selectedMarker) {
    const selectedPlace = visiblePlaces.find((place) => place.slug === selectedPlaceSlug);

    if (selectedPlace) {
      map.setView(
        [selectedPlace.latitude, selectedPlace.longitude],
        selectedPlace.map_zoom ?? 10
      );
    }

    selectedMarker.openPopup();
  }
}
</script>