---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAllEvents,
  getBooksByEventId,
  getPeopleByEventId,
  getPlacesByEventId,
  getTopicsByEventId,
  getPassagesByEventId,
  type Event,
  type Book,
  type EventRelatedPlace,
  type RelatedItem,
  type Passage,
} from "../../lib/queries";

type Props = {
  event: Event;
  books: Book[];
  people: RelatedItem[];
  places: EventRelatedPlace[];
  topics: RelatedItem[];
  passages: Passage[];
};

export function getStaticPaths() {
  const events = getAllEvents();

  return events
    .filter((event) => event.status !== "Borrador")
    .map((event) => ({
      params: { slug: event.slug },
      props: {
        event,
        books: getBooksByEventId(event.id),
        people: getPeopleByEventId(event.id),
        places: getPlacesByEventId(event.id),
        topics: getTopicsByEventId(event.id),
        passages: getPassagesByEventId(event.id),
      },
    }));
}

const { event, people, places, topics, books, passages } = Astro.props;

const firstMappablePlace = places.find(
  (place) => place.latitude !== null && place.longitude !== null
);
---

<BaseLayout
  title={event.title}
  description={event.summary ?? "Evento bíblico de la Enciclopedia Bíblica Visual."}
>
  <main class="page">
    <div class="breadcrumb">
      <a href="/">Inicio</a> → Eventos → {event.title}
    </div>

    <section class="hero">
      <p class="eyebrow">{event.event_type ?? "Evento bíblico"}</p>

      <h1>{event.title}</h1>

      {event.summary && (
        <p class="subtitle">
          {event.summary}
        </p>
      )}

      {firstMappablePlace && (
        <div class="actions">
          <a href={`/mapa/?lugar=${firstMappablePlace.slug}`} class="button">
            Ver en el mapa bíblico
          </a>
        </div>
      )}
    </section>

    <section class="grid">
      <article class="card">
        <h2>Período</h2>
        <p>{event.biblical_period ?? "Pendiente"}</p>
      </article>

      <article class="card">
        <h2>Fecha aproximada</h2>
        <p>{event.approximate_date ?? "Pendiente"}</p>
      </article>

      <article class="card">
        <h2>Certeza temporal</h2>
        <p>{event.temporal_certainty ?? "Pendiente"}</p>
      </article>
    </section>

    <section class="section">
      <h2>Descripción</h2>

      <div class="content">
        <p>{event.description ?? "Descripción pendiente."}</p>
      </div>
    </section>

    {books.length > 0 && (
      <section class="section">
        <h2>Libros relacionados</h2>

        <ul class="pill-list">
          {books.map((book) => (
            <li>
              <a href={`/libros/${book.slug}/`}>{book.name}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {passages.length > 0 && (
      <section class="section">
        <h2>Pasajes relacionados</h2>

        <ul class="pill-list">
          {passages.map((passage) => (
            <li>
              <a href={`/pasajes/${passage.slug}/`}>{passage.display_reference}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {(places.length > 0 || people.length > 0 || topics.length > 0) && (
      <section class="grid">
        {places.length > 0 && (
          <article class="card">
            <h2>Lugares</h2>

            <ul class="list">
              {places.map((place) => (
                <li>
                  <a href={`/lugares/${place.slug}/`}>{place.title}</a>
                  {place.geographical_certainty && (
                    <span> · certeza: {place.geographical_certainty}</span>
                  )}
                </li>
              ))}
            </ul>
          </article>
        )}

        {people.length > 0 && (
          <article class="card">
            <h2>Personajes</h2>

            <ul class="list">
              {people.map((person) => (
                <li>
                  <a href={`/personajes/${person.slug}/`}>{person.title}</a>
                </li>
              ))}
            </ul>
          </article>
        )}

        {topics.length > 0 && (
          <article class="card">
            <h2>Temas</h2>

            <ul class="list">
              {topics.map((topic) => (
                <li>
                  <a href={`/temas/${topic.slug}/`}>{topic.title}</a>
                </li>
              ))}
            </ul>
          </article>
        )}
      </section>
    )}

    {places.length > 0 && (
      <section class="section">
        <h2>Lugares relacionados</h2>

        <div class="entity-list">
          {places.map((place) => (
            <a href={`/lugares/${place.slug}/`} class="entity-card">
              <span class="meta">{place.place_type ?? "Lugar"}</span>
              <h2>{place.title}</h2>
              <p>{place.summary ?? "Descripción pendiente."}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="section">
      <h2>Uso en la enciclopedia</h2>

      <ul class="list">
        <li>Línea de tiempo: {event.appears_on_timeline ? "Sí" : "No"}</li>
        <li>Mapa: {event.appears_on_map ? "Sí" : "No"}</li>
        <li>Certeza geográfica: {event.geographical_certainty ?? "Pendiente"}</li>
      </ul>
    </section>

    <section class="section">
      <a href="/eventos/" class="button secondary">
        Volver a eventos
      </a>
    </section>
  </main>
</BaseLayout>