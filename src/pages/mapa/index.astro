---
import "leaflet/dist/leaflet.css";
import { sitePath } from "../../lib/site-paths";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getEventsByPlaceId, getMapPlaces } from "../../lib/queries";

const places = getMapPlaces().map((place) => ({
  ...place,
  events: getEventsByPlaceId(place.id).map((event) => ({
    title: event.title,
    slug: event.slug,
  })),
}));
---

<BaseLayout
  title="Mapa bíblico"
  description="Mapa interactivo con lugares importantes de la historia bíblica."
>
  <main class="page">
    <div class="breadcrumb">
      <a href={sitePath("/")}>Inicio</a> → Mapa bíblico
    </div>

    <section class="hero">
      <p class="eyebrow">Mapa interactivo</p>

      <h1>Mapa bíblico</h1>

      <p class="subtitle">
        Una vista de lugares bíblicos importantes. Este mapa ayuda a ubicar
        geográficamente eventos, personajes y lugares de la historia bíblica.
      </p>

      <div class="actions">
        <a href={sitePath("/lugares/")} class="button secondary">
          Ver lugares
        </a>
      </div>
    </section>

    <section class="map-shell">
      <div id="biblical-map"></div>
    </section>

    <script type="application/json" id="map-places" set:html={JSON.stringify(places)} />
  </main>
</BaseLayout>

<script>
  import L from "leaflet";
  import markerIcon2xUrl from "leaflet/dist/images/marker-icon-2x.png";
  import markerIconUrl from "leaflet/dist/images/marker-icon.png";
  import markerShadowUrl from "leaflet/dist/images/marker-shadow.png";

  type MapPlace = {
    id: string;
    name: string;
    slug: string;
    place_type: string | null;
    summary: string | null;
    latitude: number;
    longitude: number;
    map_zoom: number | null;
    geographical_certainty: string | null;
    events: {
      title: string;
      slug: string;
    }[];
  };

  delete (L.Icon.Default.prototype as any)._getIconUrl;

  L.Icon.Default.mergeOptions({
    iconRetinaUrl: markerIcon2xUrl.src ?? markerIcon2xUrl,
    iconUrl: markerIconUrl.src ?? markerIconUrl,
    shadowUrl: markerShadowUrl.src ?? markerShadowUrl,
  });

  const baseUrl = import.meta.env.BASE_URL;

  function clientSitePath(path: string): string {
    const cleanBase = baseUrl.replace(/\/$/, "");
    const cleanPath = path.startsWith("/") ? path : `/${path}`;

    return `${cleanBase}${cleanPath}`;
  }

  function escapeHtml(value: string | null | undefined): string {
    return String(value ?? "").replace(/[&<>"']/g, (character) => {
      const entities: Record<string, string> = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#039;",
      };

      return entities[character] ?? character;
    });
  }

  const placesElement = document.getElementById("map-places");
  const places = placesElement?.textContent
    ? (JSON.parse(placesElement.textContent) as MapPlace[])
    : [];

  const selectedPlaceSlug = new URLSearchParams(window.location.search).get("lugar");

  const visiblePlaces = selectedPlaceSlug
    ? places.filter((place) => place.slug === selectedPlaceSlug)
    : places;

  const map = L.map("biblical-map", {
    scrollWheelZoom: false,
  }).setView([31.778, 35.2354], 7);

  function moveMapByScreenPixels(x: number, y: number) {
    if (x === 0 && y === 0) {
      return;
    }

    const zoom = map.getZoom();
    const centerPoint = map.project(map.getCenter(), zoom);
    const adjustedCenter = map.unproject(centerPoint.subtract([x, y]), zoom);

    map.setView(adjustedCenter, zoom, {
      animate: false,
    });
  }

  function keepPopupInsideMap(marker: L.Marker) {
    const popup = marker.getPopup();
    const popupElement = popup?.getElement();

    if (!popup || !popupElement) {
      return;
    }

    map.invalidateSize(false);
    popup.update();

    const mapRect = map.getContainer().getBoundingClientRect();
    const popupRect = popupElement.getBoundingClientRect();
    const mapWidth = map.getContainer().clientWidth;

    const sidePadding = mapWidth <= 760 ? 18 : 28;
    const topPadding = mapWidth <= 760 ? 150 : 190;
    const bottomPadding = mapWidth <= 760 ? 12 : 12;

    let shiftX = 0;
    let shiftY = 0;

    if (popupRect.left < mapRect.left + sidePadding) {
      shiftX = mapRect.left + sidePadding - popupRect.left;
    }

    if (popupRect.right > mapRect.right - sidePadding) {
      shiftX = mapRect.right - sidePadding - popupRect.right;
    }

    if (popupRect.top < mapRect.top + topPadding) {
      shiftY = mapRect.top + topPadding - popupRect.top;
    }

    if (popupRect.bottom > mapRect.bottom - bottomPadding) {
      shiftY = mapRect.bottom - bottomPadding - popupRect.bottom;
    }

    if (shiftX !== 0 || shiftY !== 0) {
      moveMapByScreenPixels(shiftX, shiftY);

      window.requestAnimationFrame(() => {
        popup.update();
      });
    }
  }

  function centerMarkerWithPopupSpace(latLng: L.LatLngExpression, zoom: number) {
    map.invalidateSize(false);

    const resolvedLatLng = L.latLng(latLng);
    const mapContainer = map.getContainer();
    const mapHeight = mapContainer.clientHeight;
    const mapWidth = mapContainer.clientWidth;

    const isMobileMap = mapWidth <= 760;

    const targetMarkerY = isMobileMap
      ? mapHeight * 0.92
      : mapHeight * 0.93;

    const currentCenterY = mapHeight / 2;
    const verticalShift = targetMarkerY - currentCenterY;

    const projectedPoint = map.project(resolvedLatLng, zoom);
    const adjustedCenter = map.unproject(
      projectedPoint.subtract([0, verticalShift]),
      zoom
    );

    map.setView(adjustedCenter, zoom, {
      animate: false,
    });
  }

  function stabilizeSelectedPopup(marker: L.Marker, latLng: L.LatLngExpression, zoom: number) {
    const run = () => {
      map.invalidateSize(false);
      centerMarkerWithPopupSpace(latLng, zoom);
    };

    run();

    window.requestAnimationFrame(() => {
      run();

      window.requestAnimationFrame(() => {
        run();
        marker.openPopup();

        window.requestAnimationFrame(() => {
          keepPopupInsideMap(marker);

          window.requestAnimationFrame(() => {
            keepPopupInsideMap(marker);

            window.setTimeout(() => {
              keepPopupInsideMap(marker);
            }, 120);

            window.setTimeout(() => {
              keepPopupInsideMap(marker);
            }, 260);

            window.setTimeout(() => {
              keepPopupInsideMap(marker);
            }, 420);
          });
        });
      });
    });
  }

  const lightLayer = L.tileLayer(
    "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png",
    {
      subdomains: "abcd",
      maxZoom: 20,
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
    }
  );

  const terrainLayer = L.tileLayer(
    "https://server.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}",
    {
      maxZoom: 19,
      attribution:
        "Tiles &copy; Esri &mdash; Sources: Esri, HERE, Garmin, FAO, NOAA, USGS, OpenStreetMap contributors, and the GIS User Community",
    }
  );

  const satelliteLayer = L.tileLayer(
    "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}",
    {
      maxZoom: 19,
      attribution:
        "Tiles &copy; Esri &mdash; Source: Esri, Maxar, Earthstar Geographics, and the GIS User Community",
    }
  );

  const baseLayers = {
    Satélite: satelliteLayer,
    Terreno: terrainLayer,
    Claro: lightLayer,
  };

  let activeBaseLayer = satelliteLayer;

  satelliteLayer.addTo(map);

  const layerControl = L.control({
    position: "topright",
  });

  layerControl.onAdd = () => {
    const container = L.DomUtil.create("div", "map-layer-switcher");

    container.innerHTML = `
      <button
        type="button"
        class="map-layer-current"
        data-layer-toggle
        aria-expanded="false"
      >
        <span>Tipo de mapa</span>
        <strong data-current-layer>Satélite</strong>
        <em aria-hidden="true">▾</em>
      </button>

      <div class="map-layer-options" role="group" aria-label="Tipo de mapa">
        ${Object.keys(baseLayers)
          .map(
            (layerName) => `
              <button
                type="button"
                class="map-layer-button ${layerName === "Satélite" ? "is-active" : ""}"
                data-layer-name="${layerName}"
                aria-pressed="${layerName === "Satélite" ? "true" : "false"}"
              >
                ${layerName}
              </button>
            `
          )
          .join("")}
      </div>
    `;

    L.DomEvent.disableClickPropagation(container);
    L.DomEvent.disableScrollPropagation(container);

    const toggleButton = container.querySelector<HTMLButtonElement>("[data-layer-toggle]");
    const currentLayerLabel = container.querySelector<HTMLElement>("[data-current-layer]");
    const buttons = Array.from(
      container.querySelectorAll<HTMLButtonElement>("[data-layer-name]")
    );

    toggleButton?.addEventListener("click", () => {
      const isOpen = container.classList.toggle("is-open");
      toggleButton.setAttribute("aria-expanded", String(isOpen));
    });

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const layerName = button.dataset.layerName as keyof typeof baseLayers;
        const selectedLayer = baseLayers[layerName];

        if (!selectedLayer) {
          return;
        }

        if (selectedLayer !== activeBaseLayer) {
          map.removeLayer(activeBaseLayer);
          selectedLayer.addTo(map);
          activeBaseLayer = selectedLayer;
        }

        if (currentLayerLabel) {
          currentLayerLabel.textContent = layerName;
        }

        buttons.forEach((currentButton) => {
          const isActive = currentButton === button;

          currentButton.classList.toggle("is-active", isActive);
          currentButton.setAttribute("aria-pressed", String(isActive));
        });

        container.classList.remove("is-open");
        toggleButton?.setAttribute("aria-expanded", "false");
      });
    });

    return container;
  };

  layerControl.addTo(map);

  const bounds = L.latLngBounds([]);
  const markersBySlug = new Map<string, L.Marker>();

  let lockedPopupSlug: string | null = selectedPlaceSlug;
  let temporaryPopupSlug: string | null = null;
  let pointerInsidePopupSlug: string | null = null;
  let popupCloseTimer = 0;

  function clearPopupCloseTimer() {
    if (popupCloseTimer) {
      window.clearTimeout(popupCloseTimer);
      popupCloseTimer = 0;
    }
  }

  function lockPopup(placeSlug: string) {
    clearPopupCloseTimer();

    lockedPopupSlug = placeSlug;
    temporaryPopupSlug = null;
    pointerInsidePopupSlug = placeSlug;
  }

  function releasePopup(placeSlug: string) {
    if (lockedPopupSlug === placeSlug) {
      lockedPopupSlug = null;
    }

    if (temporaryPopupSlug === placeSlug) {
      temporaryPopupSlug = null;
    }

    if (pointerInsidePopupSlug === placeSlug) {
      pointerInsidePopupSlug = null;
    }

    clearPopupCloseTimer();
  }

  function openLockedPopup(placeSlug: string, marker: L.Marker) {
    lockPopup(placeSlug);
    marker.openPopup();

    window.requestAnimationFrame(() => {
      keepPopupInsideMap(marker);
    });
  }

  function closeLockedPopup(placeSlug: string, marker: L.Marker) {
    releasePopup(placeSlug);
    marker.closePopup();
  }

  function toggleLockedPopup(placeSlug: string, marker: L.Marker) {
    if (lockedPopupSlug === placeSlug && marker.isPopupOpen()) {
      closeLockedPopup(placeSlug, marker);
      return;
    }

    openLockedPopup(placeSlug, marker);
  }

  function scheduleTemporaryPopupClose(placeSlug: string, delay = 320) {
    clearPopupCloseTimer();

    popupCloseTimer = window.setTimeout(() => {
      if (lockedPopupSlug === placeSlug) {
        return;
      }

      if (pointerInsidePopupSlug === placeSlug) {
        return;
      }

      const marker = markersBySlug.get(placeSlug);

      if (marker) {
        marker.closePopup();
      }

      if (temporaryPopupSlug === placeSlug) {
        temporaryPopupSlug = null;
      }
    }, delay);
  }

  function openTemporaryPopup(placeSlug: string, marker: L.Marker) {
    if (lockedPopupSlug && lockedPopupSlug !== placeSlug) {
      return;
    }

    clearPopupCloseTimer();

    if (lockedPopupSlug === placeSlug) {
      return;
    }

    if (temporaryPopupSlug && temporaryPopupSlug !== placeSlug) {
      const previousMarker = markersBySlug.get(temporaryPopupSlug);
      previousMarker?.closePopup();
    }

    temporaryPopupSlug = placeSlug;
    pointerInsidePopupSlug = null;

    marker.openPopup();

    window.requestAnimationFrame(() => {
      keepPopupInsideMap(marker);
    });
  }

  const placeIcon = L.divIcon({
    className: "ebv-map-marker",
    html: '<span aria-hidden="true"></span>',
    iconSize: [34, 44],
    iconAnchor: [17, 42],
    popupAnchor: [0, -42],
  });

  visiblePlaces.forEach((place) => {
    const latLng: [number, number] = [place.latitude, place.longitude];

    const marker = L.marker(latLng, {
      icon: placeIcon,
    }).addTo(map);

    markersBySlug.set(place.slug, marker);

    const eventsHtml =
      place.events.length > 0
        ? `
          <div class="map-popup-detail-group">
            <p><strong>Eventos:</strong></p>
            <ul>
              ${place.events
                .map(
                  (event) =>
                    `<li><a href="${clientSitePath(`/eventos/${event.slug}/`)}">${escapeHtml(event.title)}</a></li>`
                )
                .join("")}
            </ul>
          </div>
        `
        : "";

    marker.bindPopup(
      `
      <div class="map-popup" data-popup-place-slug="${escapeHtml(place.slug)}">
        <div class="map-popup-compact">
          <span>${escapeHtml(place.place_type ?? "Lugar bíblico")}</span>
          <h3>${escapeHtml(place.name)}</h3>

          <details class="map-popup-disclosure" data-popup-details-wrapper>
            <summary class="map-popup-toggle">
              Ver detalles
              <em aria-hidden="true">▾</em>
            </summary>

            <div class="map-popup-details">
              ${place.summary ? `<p>${escapeHtml(place.summary)}</p>` : ""}

              <p><strong>Certeza:</strong> ${escapeHtml(place.geographical_certainty ?? "Pendiente")}</p>
              ${eventsHtml}

              <a href="${clientSitePath(`/lugares/${place.slug}/`)}" class="map-popup-place-link">
                Ver lugar
              </a>
            </div>
          </details>
        </div>
      </div>
      `,
      {
        maxWidth: 280,
        minWidth: 0,
        autoPan: false,
        keepInView: false,
        closeOnClick: false,
      }
    );

    marker.off("click");

    let popupResizeObserver: ResizeObserver | null = null;
    let popupUpdateFrame = 0;

    marker.on("mouseover", () => {
      openTemporaryPopup(place.slug, marker);
    });

    marker.on("mouseout", () => {
      if (lockedPopupSlug === place.slug) {
        return;
      }

      scheduleTemporaryPopupClose(place.slug);
    });

    marker.on("click", (event) => {
      L.DomEvent.stop(event);
      toggleLockedPopup(place.slug, marker);
    });

    marker.on("popupopen", () => {
      const popup = marker.getPopup();
      const popupElement = popup?.getElement();

      if (!popup || !popupElement) {
        return;
      }

      const popupCard = popupElement.querySelector<HTMLElement>(".map-popup");
      const disclosure = popupElement.querySelector<HTMLDetailsElement>(
        "[data-popup-details-wrapper]"
      );
      const indicator = popupElement.querySelector<HTMLElement>(
        ".map-popup-toggle em"
      );

      if (!popupCard) {
        return;
      }

      popupElement.addEventListener("mouseenter", () => {
        clearPopupCloseTimer();

        if (!lockedPopupSlug && temporaryPopupSlug === place.slug) {
          pointerInsidePopupSlug = place.slug;
        }
      });

      popupElement.addEventListener("mouseleave", () => {
        if (lockedPopupSlug === place.slug) {
          return;
        }

        if (pointerInsidePopupSlug === place.slug) {
          pointerInsidePopupSlug = null;
        }

        scheduleTemporaryPopupClose(place.slug, 240);
      });

      popupElement.addEventListener("click", (event) => {
        const target = event.target as HTMLElement | null;

        if (target?.closest(".leaflet-popup-close-button")) {
          releasePopup(place.slug);
          return;
        }

        lockPopup(place.slug);
        event.stopPropagation();
      });

      const schedulePopupUpdate = () => {
        window.cancelAnimationFrame(popupUpdateFrame);

        popupUpdateFrame = window.requestAnimationFrame(() => {
          popup.update();
          keepPopupInsideMap(marker);

          window.requestAnimationFrame(() => {
            popup.update();
            keepPopupInsideMap(marker);
          });
        });
      };

      disclosure?.addEventListener("toggle", () => {
        lockPopup(place.slug);

        if (indicator) {
          indicator.textContent = disclosure.open ? "▴" : "▾";
        }

        schedulePopupUpdate();

        window.setTimeout(() => {
          keepPopupInsideMap(marker);
        }, 120);
      });

      popupResizeObserver?.disconnect();

      if ("ResizeObserver" in window) {
        popupResizeObserver = new ResizeObserver(() => {
          schedulePopupUpdate();
        });

        popupResizeObserver.observe(popupCard);
      }

      schedulePopupUpdate();
    });

    marker.on("popupclose", () => {
      popupResizeObserver?.disconnect();
      popupResizeObserver = null;
      window.cancelAnimationFrame(popupUpdateFrame);

      if (lockedPopupSlug === place.slug) {
        lockedPopupSlug = null;
      }

      if (temporaryPopupSlug === place.slug) {
        temporaryPopupSlug = null;
      }

      if (pointerInsidePopupSlug === place.slug) {
        pointerInsidePopupSlug = null;
      }
    });

    bounds.extend(latLng);
  });

  if (!selectedPlaceSlug && visiblePlaces.length > 0) {
    map.fitBounds(bounds, {
      padding: [48, 48],
      maxZoom: 8,
    });
  }

  if (selectedPlaceSlug) {
    const selectedMarker = markersBySlug.get(selectedPlaceSlug);
    const selectedPlace = visiblePlaces.find((place) => place.slug === selectedPlaceSlug);

    if (selectedMarker && selectedPlace) {
      const selectedLatLng: [number, number] = [
        selectedPlace.latitude,
        selectedPlace.longitude,
      ];
      const selectedZoom = selectedPlace.map_zoom ?? 10;

      map.whenReady(() => {
        stabilizeSelectedPopup(selectedMarker, selectedLatLng, selectedZoom);
      });
    }
  }
</script>