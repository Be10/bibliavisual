---
import "maplibre-gl/dist/maplibre-gl.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sitePath } from "../../lib/site-paths";
---

<BaseLayout
  title="Mapa bíblico 3D"
  description="Mapa bíblico experimental con perspectiva, relieve, lugares seleccionados y rutas visuales."
>
  <main class="page map3d-page">
    <div class="breadcrumb">
      <a href={sitePath("/")}>Inicio</a> → Mapa bíblico 3D
    </div>

    <section class="hero map3d-hero">
      <p class="eyebrow">Mapa experimental</p>

      <h1>Mapa bíblico 3D</h1>

      <p class="subtitle">
        Una prueba visual con MapLibre GL JS: mapa inclinado, relieve,
        etiquetas bíblicas, agua animada y una ruta marítima con barco en movimiento.
      </p>

      <div class="actions">
        <a href={sitePath("/mapa/")} class="button secondary">
          Volver al mapa actual
        </a>
      </div>
    </section>

    <section
      class="map3d-shell"
      aria-label="Mapa bíblico 3D interactivo"
      data-boat-base={sitePath("/images/mapa-3d/barcos/")}
    >
      <div class="map3d-toolbar" aria-label="Controles del mapa">
        <button type="button" data-map-action="israel">Israel</button>
        <button type="button" data-map-action="mediterraneo">Mediterráneo</button>
        <button type="button" data-map-action="mesopotamia">Mesopotamia</button>
        <button type="button" data-map-action="ruta">Ruta marítima</button>
      </div>

      <div class="map3d-status">
        <span class="map3d-status-dot"></span>
        Mapa experimental
      </div>

      <div id="biblical-map-3d"></div>

      <div class="map3d-vignette" aria-hidden="true"></div>
    </section>

    <section class="map3d-notes">
      <article>
        <p class="eyebrow">Próximas mejoras</p>
        <h2>Barco bíblico direccional</h2>
        <p>
          Esta versión usa tus imágenes PNG del barco en ocho direcciones. El
          mapa elige automáticamente la imagen correcta según el rumbo visual de
          la ruta: norte, noreste, este, sureste, sur, suroeste, oeste y noroeste.
        </p>
      </article>
    </section>
  </main>
</BaseLayout>

<script>
  import maplibregl from "maplibre-gl";

  type BiblePlace = {
    name: string;
    description: string;
    coordinates: [number, number];
  };

  type BibleArea = {
    name: string;
    coordinates: [number, number];
    size: number;
  };

  type CameraPreset = {
    center: [number, number];
    zoom: number;
    pitch: number;
    bearing: number;
  };

  type RouteSegment = {
    from: [number, number];
    to: [number, number];
    distance: number;
    accumulatedDistance: number;
  };

  type RoutePoint = {
    coordinates: [number, number];
    from: [number, number];
    to: [number, number];
  };

  type BoatDirection = "n" | "ne" | "e" | "se" | "s" | "sw" | "w" | "nw";

  const places: BiblePlace[] = [
    {
      name: "Jerusalén",
      description: "Ciudad central en la historia bíblica.",
      coordinates: [35.2137, 31.7683],
    },
    {
      name: "Belén",
      description: "Ciudad asociada con David y el nacimiento de Jesús.",
      coordinates: [35.2024, 31.7054],
    },
    {
      name: "Nazaret",
      description: "Lugar donde Jesús creció.",
      coordinates: [35.3035, 32.6996],
    },
    {
      name: "Capernaúm",
      description: "Lugar importante del ministerio de Jesús en Galilea.",
      coordinates: [35.575, 32.8803],
    },
    {
      name: "Monte Sinaí",
      description: "Región asociada con la entrega de la Ley.",
      coordinates: [33.9753, 28.5397],
    },
    {
      name: "Ur",
      description: "Lugar asociado con el llamado de Abraham.",
      coordinates: [46.1031, 30.9625],
    },
    {
      name: "Harán",
      description: "Lugar importante en el recorrido de Abraham.",
      coordinates: [39.0319, 36.865],
    },
    {
      name: "Babilonia",
      description: "Ciudad asociada con el exilio de Judá.",
      coordinates: [44.4215, 32.5364],
    },
    {
      name: "Roma",
      description: "Centro imperial relacionado con el avance del evangelio.",
      coordinates: [12.4964, 41.9028],
    },
  ];

  const areas: BibleArea[] = [
    {
      name: "Mar Mediterráneo",
      coordinates: [25.4, 35.4],
      size: 18,
    },
    {
      name: "Mar Rojo",
      coordinates: [35.2, 25.3],
      size: 15,
    },
    {
      name: "Mar Muerto",
      coordinates: [35.49, 31.52],
      size: 13,
    },
    {
      name: "Mar de Galilea",
      coordinates: [35.58, 32.82],
      size: 13,
    },
    {
      name: "Río Jordán",
      coordinates: [35.56, 32.08],
      size: 13,
    },
    {
      name: "Egipto",
      coordinates: [30.4, 27.8],
      size: 19,
    },
    {
      name: "Sinaí",
      coordinates: [33.7, 29.2],
      size: 17,
    },
    {
      name: "Canaán",
      coordinates: [35.0, 31.6],
      size: 16,
    },
    {
      name: "Mesopotamia",
      coordinates: [43.8, 33.6],
      size: 18,
    },
  ];

  const maritimeRoute: [number, number][] = [
    [34.904, 32.5007],
    [33.4299, 35.1264],
    [28.9784, 41.0082],
    [14.3754, 35.9375],
    [12.4964, 41.9028],
  ];

  const baseWaterMotionLines: [number, number][][] = [
    [
      [30.6, 34.7],
      [31.7, 34.9],
      [32.8, 34.8],
      [33.9, 34.5],
    ],
    [
      [27.4, 35.5],
      [28.8, 35.8],
      [30.1, 35.7],
      [31.4, 35.4],
    ],
    [
      [23.0, 36.2],
      [24.4, 36.5],
      [25.8, 36.4],
      [27.1, 36.1],
    ],
    [
      [19.0, 36.7],
      [20.4, 37.0],
      [21.8, 36.9],
      [23.2, 36.6],
    ],
    [
      [24.6, 34.1],
      [25.8, 34.3],
      [27.0, 34.2],
      [28.2, 33.9],
    ],
    [
      [29.4, 33.4],
      [30.6, 33.3],
      [31.7, 33.3],
      [32.8, 33.5],
    ],
    [
      [21.2, 34.8],
      [22.6, 35.0],
      [24.0, 34.9],
      [25.3, 34.6],
    ],
    [
      [17.8, 34.1],
      [19.2, 34.3],
      [20.6, 34.2],
      [22.0, 33.9],
    ],
  ];

  const cameraPresets: Record<string, CameraPreset> = {
    israel: {
      center: [35.2137, 31.7683],
      zoom: 7,
      pitch: 64,
      bearing: -18,
    },
    mediterraneo: {
      center: [24.8, 36.4],
      zoom: 4.2,
      pitch: 58,
      bearing: -12,
    },
    mesopotamia: {
      center: [43.7, 33.4],
      zoom: 5,
      pitch: 62,
      bearing: -22,
    },
    ruta: {
      center: [24.6, 37.5],
      zoom: 4.4,
      pitch: 64,
      bearing: -28,
    },
  };

  const map = new maplibregl.Map({
    container: "biblical-map-3d",
    style: "https://tiles.openfreemap.org/styles/liberty",
    center: [35.2137, 31.7683],
    zoom: 5.5,
    pitch: 62,
    bearing: -18,
    maxPitch: 78,
    attributionControl: true,
  });

  map.addControl(
    new maplibregl.NavigationControl({
      visualizePitch: true,
      showCompass: true,
      showZoom: true,
    }),
    "top-right",
  );

  function getBoatBasePath() {
    const shell = document.querySelector<HTMLElement>(".map3d-shell");
    return shell?.dataset.boatBase ?? "/images/mapa-3d/barcos/";
  }

  function createPopup(place: BiblePlace) {
    return `
      <article class="map3d-popup">
        <strong>${place.name}</strong>
        <p>${place.description}</p>
      </article>
    `;
  }

  function createBoatImage(direction: BoatDirection) {
    const boatBasePath = getBoatBasePath();

    const directionLabel = {
      n: "norte",
      ne: "noreste",
      e: "este",
      se: "sureste",
      s: "sur",
      sw: "suroeste",
      w: "oeste",
      nw: "noroeste",
    }[direction];

    return `
      <div class="map3d-boat-variant map3d-boat-variant-${direction}">
        <span class="map3d-boat-shadow" aria-hidden="true"></span>
        <span class="map3d-boat-wake map3d-boat-wake-main" aria-hidden="true"></span>
        <span class="map3d-boat-wake map3d-boat-wake-soft" aria-hidden="true"></span>

        <img
          class="map3d-boat-image"
          src="${boatBasePath}barco-${direction}.png"
          alt="Barco navegando hacia el ${directionLabel}"
          draggable="false"
        />
      </div>
    `;
  }

  function createDirectionalBoatElement() {
    const element = document.createElement("div");
    element.className = "map3d-directional-boat";

    element.innerHTML = `
      <div class="map3d-directional-boat-float">
        ${createBoatImage("n")}
        ${createBoatImage("ne")}
        ${createBoatImage("e")}
        ${createBoatImage("se")}
        ${createBoatImage("s")}
        ${createBoatImage("sw")}
        ${createBoatImage("w")}
        ${createBoatImage("nw")}
      </div>
    `;

    return element;
  }

  function getApproxDistance(from: [number, number], to: [number, number]) {
    const lngDistance = to[0] - from[0];
    const latDistance = to[1] - from[1];
    const averageLat = ((from[1] + to[1]) / 2) * (Math.PI / 180);
    const adjustedLngDistance = lngDistance * Math.cos(averageLat);

    return Math.sqrt(
      adjustedLngDistance * adjustedLngDistance + latDistance * latDistance,
    );
  }

  function getRouteSegments() {
    const segments: RouteSegment[] = [];
    let accumulatedDistance = 0;

    for (let index = 0; index < maritimeRoute.length - 1; index += 1) {
      const from = maritimeRoute[index];
      const to = maritimeRoute[index + 1];
      const distance = getApproxDistance(from, to);

      segments.push({
        from,
        to,
        distance,
        accumulatedDistance,
      });

      accumulatedDistance += distance;
    }

    return {
      segments,
      totalDistance: accumulatedDistance,
    };
  }

  const routeMetrics = getRouteSegments();

  function interpolateRoutePoint(progress: number): RoutePoint {
    const safeProgress = Math.min(Math.max(progress, 0), 0.999999);
    const targetDistance = safeProgress * routeMetrics.totalDistance;

    const activeSegment =
      routeMetrics.segments.find((segment) => {
        return (
          targetDistance >= segment.accumulatedDistance &&
          targetDistance <= segment.accumulatedDistance + segment.distance
        );
      }) ?? routeMetrics.segments[routeMetrics.segments.length - 1];

    const segmentProgress =
      (targetDistance - activeSegment.accumulatedDistance) /
      activeSegment.distance;

    const lng =
      activeSegment.from[0] +
      (activeSegment.to[0] - activeSegment.from[0]) * segmentProgress;
    const lat =
      activeSegment.from[1] +
      (activeSegment.to[1] - activeSegment.from[1]) * segmentProgress;

    return {
      coordinates: [lng, lat],
      from: activeSegment.from,
      to: activeSegment.to,
    };
  }

  function getBoatDirection(from: [number, number], to: [number, number]): BoatDirection {
    const fromPoint = map.project(from);
    const toPoint = map.project(to);

    const deltaX = toPoint.x - fromPoint.x;
    const deltaY = toPoint.y - fromPoint.y;
    const angle = Math.atan2(deltaY, deltaX) * (180 / Math.PI);
    const normalizedAngle = (angle + 360) % 360;

    if (normalizedAngle >= 337.5 || normalizedAngle < 22.5) {
      return "e";
    }

    if (normalizedAngle >= 22.5 && normalizedAngle < 67.5) {
      return "se";
    }

    if (normalizedAngle >= 67.5 && normalizedAngle < 112.5) {
      return "s";
    }

    if (normalizedAngle >= 112.5 && normalizedAngle < 157.5) {
      return "sw";
    }

    if (normalizedAngle >= 157.5 && normalizedAngle < 202.5) {
      return "w";
    }

    if (normalizedAngle >= 202.5 && normalizedAngle < 247.5) {
      return "nw";
    }

    if (normalizedAngle >= 247.5 && normalizedAngle < 292.5) {
      return "n";
    }

    return "ne";
  }

  function buildWaterMotionData(time: number) {
    return {
      type: "FeatureCollection",
      features: baseWaterMotionLines.map((line, lineIndex) => ({
        type: "Feature",
        properties: {
          wave: lineIndex + 1,
        },
        geometry: {
          type: "LineString",
          coordinates: line.map(([lng, lat], pointIndex) => {
            const phase = time * 0.0012 + lineIndex * 0.72 + pointIndex * 0.95;
            const lngOffset = Math.sin(phase) * 0.028;
            const latOffset = Math.cos(phase * 0.85) * 0.012;

            return [lng + lngOffset, lat + latOffset];
          }),
        },
      })),
    };
  }

  function softenBaseMap() {
    const layers = map.getStyle().layers ?? [];

    for (const layer of layers) {
      if (layer.type === "symbol") {
        map.setLayoutProperty(layer.id, "visibility", "none");
      }

      if (layer.type === "line") {
        const layerId = layer.id.toLowerCase();

        if (
          layerId.includes("road") ||
          layerId.includes("street") ||
          layerId.includes("highway") ||
          layerId.includes("rail")
        ) {
          map.setPaintProperty(layer.id, "line-opacity", 0.14);
          map.setPaintProperty(layer.id, "line-color", "#8c6a3f");
        }

        if (
          layerId.includes("boundary") ||
          layerId.includes("border") ||
          layerId.includes("admin")
        ) {
          map.setPaintProperty(layer.id, "line-opacity", 0.24);
          map.setPaintProperty(layer.id, "line-color", "#7a5933");
        }
      }

      if (layer.type === "fill") {
        const layerId = layer.id.toLowerCase();

        if (
          layerId.includes("water") ||
          layerId.includes("ocean") ||
          layerId.includes("sea")
        ) {
          map.setPaintProperty(layer.id, "fill-color", "#8cb5de");
          map.setPaintProperty(layer.id, "fill-opacity", 0.94);
        }

        if (
          layerId.includes("land") ||
          layerId.includes("earth") ||
          layerId.includes("background")
        ) {
          map.setPaintProperty(layer.id, "fill-color", "#ead8b8");
        }
      }

      if (layer.type === "background") {
        map.setPaintProperty(layer.id, "background-color", "#ead8b8");
      }
    }
  }

  function addTerrain() {
    if (map.getSource("terrain-dem")) {
      return;
    }

    map.addSource("terrain-dem", {
      type: "raster-dem",
      tiles: [
        "https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png",
      ],
      tileSize: 256,
      maxzoom: 12,
      encoding: "terrarium",
    });

    map.setTerrain({
      source: "terrain-dem",
      exaggeration: 1.25,
    });

    map.addLayer({
      id: "terrain-hillshade",
      type: "hillshade",
      source: "terrain-dem",
      paint: {
        "hillshade-shadow-color": "#5a3a1d",
        "hillshade-highlight-color": "#f4ddb3",
        "hillshade-accent-color": "#9d7240",
        "hillshade-exaggeration": 0.36,
      },
    });
  }

  function addWaterMotion() {
    map.addSource("water-motion", {
      type: "geojson",
      data: buildWaterMotionData(performance.now()) as any,
    });

    map.addLayer({
      id: "water-motion-shadow",
      type: "line",
      source: "water-motion",
      paint: {
        "line-color": "#17465b",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          3,
          5,
          7,
          9,
        ],
        "line-opacity": 0.1,
        "line-blur": 4,
      },
    });

    map.addLayer({
      id: "water-motion-lines",
      type: "line",
      source: "water-motion",
      paint: {
        "line-color": "#fff1c9",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          3,
          1.2,
          7,
          2.4,
        ],
        "line-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          3,
          0.14,
          7,
          0.28,
        ],
        "line-blur": 1.1,
        "line-dasharray": [1.3, 2.1],
      },
    });

    function frame(now: number) {
      const source = map.getSource("water-motion") as
        | maplibregl.GeoJSONSource
        | undefined;

      if (source && map.getLayer("water-motion-lines")) {
        source.setData(buildWaterMotionData(now) as any);
      }

      window.requestAnimationFrame(frame);
    }

    window.requestAnimationFrame(frame);
  }

  function addBiblicalPlaces() {
    map.addSource("bible-places", {
      type: "geojson",
      data: {
        type: "FeatureCollection",
        features: places.map((place) => ({
          type: "Feature",
          properties: {
            name: place.name,
            description: place.description,
          },
          geometry: {
            type: "Point",
            coordinates: place.coordinates,
          },
        })),
      },
    });

    map.addLayer({
      id: "bible-places-glow",
      type: "circle",
      source: "bible-places",
      paint: {
        "circle-radius": [
          "interpolate",
          ["linear"],
          ["zoom"],
          3,
          9,
          7,
          16,
        ],
        "circle-color": "#e6b45a",
        "circle-opacity": 0.22,
        "circle-blur": 0.8,
      },
    });

    map.addLayer({
      id: "bible-places-circles",
      type: "circle",
      source: "bible-places",
      paint: {
        "circle-radius": [
          "interpolate",
          ["linear"],
          ["zoom"],
          3,
          4.8,
          7,
          7.5,
        ],
        "circle-color": "#c69a45",
        "circle-stroke-color": "#3a2414",
        "circle-stroke-width": 2,
      },
    });

    map.addLayer({
      id: "bible-places-labels",
      type: "symbol",
      source: "bible-places",
      layout: {
        "text-field": ["get", "name"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          3,
          11,
          7,
          14,
        ],
        "text-offset": [0, 1.35],
        "text-anchor": "top",
        "text-allow-overlap": false,
      },
      paint: {
        "text-color": "#3a2414",
        "text-halo-color": "#f7ecd2",
        "text-halo-width": 1.8,
      },
    });
  }

  function addBiblicalAreas() {
    map.addSource("bible-areas", {
      type: "geojson",
      data: {
        type: "FeatureCollection",
        features: areas.map((area) => ({
          type: "Feature",
          properties: {
            name: area.name,
            size: area.size,
          },
          geometry: {
            type: "Point",
            coordinates: area.coordinates,
          },
        })),
      },
    });

    map.addLayer({
      id: "bible-area-labels",
      type: "symbol",
      source: "bible-areas",
      layout: {
        "text-field": ["get", "name"],
        "text-size": ["get", "size"],
        "text-font": ["Noto Sans Italic"],
        "text-anchor": "center",
        "text-allow-overlap": false,
      },
      paint: {
        "text-color": "#5a3a1d",
        "text-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          3,
          0.62,
          7,
          0.82,
        ],
        "text-halo-color": "#f4e6ca",
        "text-halo-width": 1.4,
      },
    });
  }

  function addMaritimeRoute() {
    map.addSource("maritime-route", {
      type: "geojson",
      data: {
        type: "Feature",
        properties: {},
        geometry: {
          type: "LineString",
          coordinates: maritimeRoute,
        },
      },
    });

    map.addLayer({
      id: "maritime-route-shadow",
      type: "line",
      source: "maritime-route",
      paint: {
        "line-color": "#173f48",
        "line-width": 7,
        "line-opacity": 0.18,
        "line-blur": 1.8,
      },
    });

    map.addLayer({
      id: "maritime-route-line",
      type: "line",
      source: "maritime-route",
      paint: {
        "line-color": "#1d7f96",
        "line-width": 4,
        "line-opacity": 0.68,
        "line-dasharray": [2, 1],
      },
    });
  }

  function addDirectionalBoat() {
    const boatElement = createDirectionalBoatElement();

    const initialPoint = interpolateRoutePoint(0);

    const boatMarker = new maplibregl.Marker({
      element: boatElement,
      anchor: "center",
    })
      .setLngLat(initialPoint.coordinates)
      .addTo(map);

    const duration = 52000;
    const start = performance.now();

    function frame(now: number) {
      const elapsed = (now - start) % duration;
      const progress = elapsed / duration;
      const point = interpolateRoutePoint(progress);
      const direction = getBoatDirection(point.from, point.to);

      boatMarker.setLngLat(point.coordinates);
      boatElement.dataset.direction = direction;

      window.requestAnimationFrame(frame);
    }

    window.requestAnimationFrame(frame);
  }

  function bindMapEvents() {
    map.on("click", "bible-places-circles", (event) => {
      const feature = event.features?.[0];

      if (!feature) {
        return;
      }

      const coordinates = (feature.geometry as any).coordinates.slice() as [
        number,
        number,
      ];

      const place = {
        name: String(feature.properties?.name ?? ""),
        description: String(feature.properties?.description ?? ""),
        coordinates,
      };

      new maplibregl.Popup({
        offset: 18,
        closeButton: true,
        closeOnClick: true,
      })
        .setLngLat(coordinates)
        .setHTML(createPopup(place))
        .addTo(map);
    });

    map.on("mouseenter", "bible-places-circles", () => {
      map.getCanvas().style.cursor = "pointer";
    });

    map.on("mouseleave", "bible-places-circles", () => {
      map.getCanvas().style.cursor = "";
    });
  }

  function bindToolbar() {
    document.querySelectorAll("[data-map-action]").forEach((button) => {
      button.addEventListener("click", () => {
        const action = button.getAttribute("data-map-action");

        if (!action || !cameraPresets[action]) {
          return;
        }

        map.flyTo({
          ...cameraPresets[action],
          speed: 0.8,
          curve: 1.35,
          essential: true,
        });
      });
    });
  }

  map.on("load", () => {
    softenBaseMap();
