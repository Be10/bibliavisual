---
import { sitePath } from "../lib/site-paths";
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Enciclopedia Bíblica Visual con rutas guiadas, mapas, líneas de tiempo y recursos visuales.",
} = Astro.props;

const siteName = "Enciclopedia Bíblica Visual";
const pageTitle = title === siteName ? title : `${title} | ${siteName}`;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
  </head>

  <body>
    <header class="site-header">
      <a href={sitePath("/")} class="logo">Enciclopedia Bíblica Visual</a>

      <nav class="nav" aria-label="Navegación principal">
        <a href={sitePath("/rutas/panorama-visual-de-la-biblia/")}>Ruta principal</a>
        <a href={sitePath("/explorar/")}>Explorar</a>
        <a href={sitePath("/buscar/")}>Buscar</a>
        <a href={sitePath("/biblia/")}>Biblia</a>
        <a href={sitePath("/mapa/")}>Mapa</a>
        <a href={sitePath("/acerca/")}>Acerca</a>
      </nav>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="site-footer-inner">
        <p>
          Enciclopedia Bíblica Visual · Recurso educativo en desarrollo.
        </p>

        <nav class="footer-links" aria-label="Navegación secundaria">
          <a href={sitePath("/explorar/")}>Explorar</a>
          <a href={sitePath("/buscar/")}>Buscar</a>
          <a href={sitePath("/lecciones/")}>Lecciones</a>
          <a href={sitePath("/biblia/")}>Biblia</a>
          <a href={sitePath("/libros/")}>Libros</a>
          <a href={sitePath("/pasajes/")}>Pasajes</a>
          <a href={sitePath("/linea-de-tiempo/")}>Línea de tiempo</a>
          <a href={sitePath("/mapa/")}>Mapa</a>
          <a href={sitePath("/temas/")}>Temas</a>
          <a href={sitePath("/personajes/")}>Personajes</a>
          <a href={sitePath("/lugares/")}>Lugares</a>
          <a href={sitePath("/eventos/")}>Eventos</a>
          <a href={sitePath("/glosario/")}>Glosario</a>
          <a href={sitePath("/acerca/")}>Acerca</a>
          <a href={sitePath("/legal/")}>Avisos legales</a>
        </nav>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
  }

  body {
    margin: 0;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    background: #f8f5ee;
    color: #2d2418;
  }

  a {
    color: inherit;
  }

  .site-header {
    width: min(1100px, calc(100% - 32px));
    margin: 0 auto;
    padding: 24px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .logo {
    font-weight: 800;
    text-decoration: none;
    color: #5d3212;
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
  }

  .nav a {
    padding: 9px 12px;
    border-radius: 999px;
    color: #5d3212;
    font-weight: 800;
    text-decoration: none;
  }

  .nav a:hover {
    background: #fff7e8;
  }

  .page {
    width: min(1100px, calc(100% - 32px));
    margin: 0 auto;
    padding: 32px 0 72px;
  }

  .hero {
    padding: 64px 32px;
    border-radius: 28px;
    background: #fffaf0;
    border: 1px solid #eadcc4;
    box-shadow: 0 20px 60px rgba(45, 36, 24, 0.08);
  }

  .eyebrow {
    margin: 0 0 16px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a5a2b;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .subtitle {
    max-width: 760px;
    margin: 24px 0 0;
    font-size: 1.2rem;
    line-height: 1.7;
    color: #5e5143;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    border-radius: 999px;
    background: #5d3212;
    color: #fffaf0;
    font-weight: 700;
    text-decoration: none;
  }

  .button.secondary {
    background: transparent;
    color: #5d3212;
    border: 1px solid #c8a982;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 24px;
  }

  .card {
    padding: 24px;
    border-radius: 22px;
    background: white;
    border: 1px solid #eadcc4;
  }

  .card h2,
  .card h3 {
    margin: 0 0 8px;
  }

  .card p {
    margin: 0;
    line-height: 1.6;
    color: #6a5c4d;
  }

  .section {
    margin-top: 32px;
    padding: 32px;
    border-radius: 24px;
    background: white;
    border: 1px solid #eadcc4;
  }

  .section h2 {
    margin-top: 0;
  }

  .content {
    max-width: 760px;
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .breadcrumb {
    margin-bottom: 16px;
    font-size: 0.95rem;
    color: #7a6a58;
  }

  .list {
    padding-left: 1.2rem;
    line-height: 1.8;
  }

  .pill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding: 0;
    list-style: none;
  }

  .pill-list a,
  .pill-list span {
    display: inline-flex;
    padding: 8px 12px;
    border-radius: 999px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #5d3212;
    text-decoration: none;
    font-weight: 650;
  }

  .entity-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-top: 24px;
  }

  .entity-card {
    display: block;
    padding: 22px;
    border-radius: 22px;
    background: white;
    border: 1px solid #eadcc4;
    text-decoration: none;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease;
  }

  .entity-card:hover {
    transform: translateY(-2px);
    border-color: #c8a982;
    box-shadow: 0 16px 36px rgba(45, 36, 24, 0.08);
  }

  .entity-card h2 {
    margin: 0 0 8px;
    font-size: 1.15rem;
    color: #2d2418;
  }

  .entity-card p {
    margin: 0;
    line-height: 1.6;
    color: #6a5c4d;
  }

  .meta {
    display: inline-flex;
    margin-bottom: 12px;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #8a5a2b;
  }

  .timeline {
    position: relative;
    display: grid;
    gap: 18px;
    margin-top: 32px;
  }

  .timeline-item {
    position: relative;
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 18px;
    align-items: start;
  }

  .timeline-date {
    position: sticky;
    top: 16px;
    padding: 12px 14px;
    border-radius: 18px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #8a5a2b;
    font-weight: 800;
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .timeline-card {
    position: relative;
    padding: 24px;
    border-radius: 22px;
    background: white;
    border: 1px solid #eadcc4;
  }

  .timeline-card::before {
    content: "";
    position: absolute;
    left: -27px;
    top: 30px;
    width: 14px;
    height: 14px;
    border-radius: 999px;
    background: #5d3212;
    box-shadow: 0 0 0 6px #f8f5ee;
  }

  .timeline-card h2 {
    margin: 0 0 8px;
    font-size: 1.25rem;
  }

  .timeline-card p {
    margin: 0;
    line-height: 1.6;
    color: #6a5c4d;
  }

  .timeline-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 14px 0 0;
  }

  .timeline-meta span {
    display: inline-flex;
    padding: 6px 10px;
    border-radius: 999px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #5d3212;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .map-shell {
    margin-top: 32px;
    overflow: hidden;
    border-radius: 28px;
    background: white;
    border: 1px solid #eadcc4;
    box-shadow: 0 20px 60px rgba(45, 36, 24, 0.08);
  }

  #biblical-map {
    width: 100%;
    height: 620px;
  }

  .map-popup {
    max-width: 260px;
  }

  .map-popup h3 {
    margin: 0 0 6px;
    font-size: 1rem;
  }

  .map-popup p {
    margin: 0 0 10px;
    line-height: 1.5;
  }

  .map-popup a {
    font-weight: 800;
    color: #5d3212;
  }

    .chapter-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }

  .chapter-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 46px;
    height: 46px;
    padding: 0 12px;
    border-radius: 14px;
    background: white;
    border: 1px solid #eadcc4;
    color: #5d3212;
    font-weight: 800;
    text-decoration: none;
  }

  .chapter-link:hover {
    border-color: #c8a982;
    background: #fff7e8;
  }

  .bible-reader {
    display: grid;
    gap: 14px;
    margin-top: 24px;
  }

  .verse {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid #eadcc4;
  }

  .verse-number {
    color: #8a5a2b;
    font-weight: 900;
    font-size: 0.9rem;
  }

  .verse-text {
    margin: 0;
    line-height: 1.8;
    color: #2d2418;
    font-size: 1.08rem;
    white-space: pre-line;
  }

  .chapter-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 12px;
    margin-top: 28px;
  }

  .copyright-box {
    margin-top: 28px;
    padding: 18px;
    border-radius: 18px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #6a5c4d;
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .passage-reader {
    display: grid;
    gap: 28px;
    margin-top: 24px;
  }

  .passage-chapter {
    display: grid;
    gap: 10px;
  }

  .passage-chapter h3 {
    margin: 0 0 6px;
    color: #5d3212;
    font-size: 1.2rem;
  }

  .verse-ref-link {
    color: inherit;
    text-decoration: none;
  }

  .verse-ref-link:hover {
    text-decoration: underline;
  }

  .search-panel {
    display: grid;
    gap: 18px;
    margin-top: 28px;
  }

  .search-input {
    width: 100%;
    padding: 18px 20px;
    border-radius: 20px;
    border: 1px solid #eadcc4;
    background: white;
    color: #2d2418;
    font-size: 1.05rem;
    outline: none;
  }

  .search-input:focus {
    border-color: #c8a982;
    box-shadow: 0 0 0 4px rgba(200, 169, 130, 0.18);
  }

  .search-help {
    margin: 0;
    color: #6a5c4d;
    line-height: 1.6;
  }

  .search-results {
    display: grid;
    gap: 14px;
    margin-top: 24px;
  }

  .search-result {
    display: block;
    padding: 20px;
    border-radius: 20px;
    background: white;
    border: 1px solid #eadcc4;
    text-decoration: none;
  }

  .search-result:hover {
    border-color: #c8a982;
    background: #fffaf0;
  }

  .search-result h2 {
    margin: 0 0 8px;
    color: #2d2418;
    font-size: 1.15rem;
  }

  .search-result p {
    margin: 0;
    color: #6a5c4d;
    line-height: 1.6;
  }

  .search-result-type {
    display: inline-flex;
    margin-bottom: 10px;
    padding: 5px 9px;
    border-radius: 999px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #8a5a2b;
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .search-empty {
    padding: 24px;
    border-radius: 20px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #6a5c4d;
    line-height: 1.6;
  }

  .explore-group {
    display: grid;
    gap: 18px;
    margin-top: 28px;
  }

  .explore-heading {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 6px;
  }

  .explore-heading h2 {
    margin: 0;
  }

  .explore-heading p {
    margin: 0;
    color: #6a5c4d;
    line-height: 1.5;
  }

  .explore-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .explore-card {
    display: block;
    padding: 22px;
    border-radius: 22px;
    background: white;
    border: 1px solid #eadcc4;
    text-decoration: none;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease;
  }

  .explore-card:hover {
    transform: translateY(-2px);
    border-color: #c8a982;
    box-shadow: 0 16px 36px rgba(45, 36, 24, 0.08);
  }

  .explore-card h3 {
    margin: 0 0 8px;
    color: #2d2418;
    font-size: 1.15rem;
  }

  .explore-card p {
    margin: 0;
    color: #6a5c4d;
    line-height: 1.6;
  }

  .explore-count {
    display: inline-flex;
    margin-bottom: 12px;
    padding: 5px 9px;
    border-radius: 999px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #8a5a2b;
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .info-list {
    display: grid;
    gap: 14px;
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
  }

  .info-list li {
    padding: 18px;
    border-radius: 18px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    line-height: 1.6;
    color: #6a5c4d;
  }

  .notice-box {
    padding: 22px;
    border-radius: 22px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #6a5c4d;
    line-height: 1.7;
  }

  .notice-box strong {
    color: #2d2418;
  }

  .site-footer {
    max-width: 1120px;
    margin: 48px auto 0;
    padding: 28px 20px 40px;
    color: #6a5c4d;
    font-size: 0.95rem;
  }

  .site-footer-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 18px;
    border-top: 1px solid #eadcc4;
    padding-top: 24px;
  }

  .site-footer a {
    color: #5d3212;
    font-weight: 800;
    text-decoration: none;
  }

  .site-footer a:hover {
    text-decoration: underline;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
    max-width: 760px;
  }

  .footer-links a {
    white-space: nowrap;
  }

  .section-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 22px;
  }

  .section-header h2 {
    margin-bottom: 0;
  }

  .section-header .eyebrow {
    margin-bottom: 8px;
  }

  .route-hero {
    position: relative;
    overflow: hidden;
  }

  .route-progress {
    max-width: 560px;
    margin-top: 32px;
    padding: 18px;
    border-radius: 20px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
  }

  .route-progress-header {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 12px;
    color: #5d3212;
    font-weight: 800;
  }

  .route-progress-bar {
    height: 12px;
    overflow: hidden;
    border-radius: 999px;
    background: #eadcc4;
  }

  .route-progress-bar span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: #5d3212;
  }

  .route-overview {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-top: 24px;
  }

  .route-stat {
    padding: 22px;
    border-radius: 22px;
    background: white;
    border: 1px solid #eadcc4;
  }

  .route-stat span {
    display: block;
    margin-bottom: 8px;
    color: #8a5a2b;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .route-stat strong {
    display: block;
    color: #2d2418;
    font-size: 1.05rem;
    line-height: 1.4;
  }

  .route-intro {
    background: #fffaf0;
  }

  .lesson-track {
    display: grid;
    gap: 14px;
    padding: 0;
    margin: 0;
    list-style: none;
    counter-reset: lesson;
  }

  .lesson-track-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 18px;
    padding: 20px;
    border-radius: 22px;
    background: #fffaf0;
    border: 1px solid #eadcc4;
    text-decoration: none;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  a.lesson-track-card:hover {
    transform: translateY(-2px);
    border-color: #c8a982;
    box-shadow: 0 14px 30px rgba(45, 36, 24, 0.08);
  }

  .lesson-track-number {
    display: inline-flex;
    width: 48px;
    height: 48px;
    align-items: center;
    justify-content: center;
    border-radius: 16px;
    background: #5d3212;
    color: #fffaf0;
    font-weight: 900;
  }

  .lesson-track-content {
    display: grid;
    gap: 8px;
  }

  .lesson-track-content strong {
    color: #2d2418;
    font-size: 1.2rem;
    line-height: 1.35;
  }

  .lesson-track-content small {
    max-width: 760px;
    color: #5e5143;
    font-size: 0.98rem;
    line-height: 1.6;
  }

  .lesson-track-content em {
    color: #8a5a2b;
    font-size: 0.9rem;
    font-style: normal;
    font-weight: 800;
  }

  .lesson-track-item.is-draft {
    opacity: 0.68;
  }

  .lesson-track-item.is-draft .lesson-track-number {
    background: #c8a982;
  }

    html {
    scroll-behavior: smooth;
  }

  .lesson-study-panel {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
    margin-top: 24px;
    padding: 18px;
    border-radius: 24px;
    background: white;
    border: 1px solid #eadcc4;
  }

  .study-card {
    padding: 18px;
    border-radius: 18px;
    background: #fffaf0;
    border: 1px solid #eadcc4;
  }

  .study-card span {
    display: block;
    margin-bottom: 8px;
    color: #8a5a2b;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .study-card strong {
    display: block;
    color: #2d2418;
    font-size: 1.1rem;
    line-height: 1.35;
  }

  .lesson-toc {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding-top: 4px;
  }

  .lesson-toc a {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 0 14px;
    border-radius: 999px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
    color: #5d3212;
    font-size: 0.92rem;
    font-weight: 800;
    text-decoration: none;
  }

  .lesson-toc a:hover {
    border-color: #c8a982;
    background: #f7efe2;
  }

  .section[id],
  .grid[id] {
    scroll-margin-top: 24px;
  }

  .lesson-progress-panel {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 18px;
    margin-top: 24px;
    padding: 22px;
    border-radius: 26px;
    background: #fff7e8;
    border: 1px solid #eadcc4;
  }

  .lesson-progress-main h2 {
    margin: 0 0 14px;
    color: #2d2418;
    font-size: 1.45rem;
  }

  .lesson-progress-main p {
    margin: 14px 0 0;
    color: #5e5143;
    line-height: 1.7;
  }

  .lesson-progress-main strong {
    color: #2d2418;
  }

  .lesson-progress-bar {
    height: 12px;
    overflow: hidden;
    border-radius: 999px;
