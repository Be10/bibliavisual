---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getRouteBySlug, getLessonsByRouteId } from "../../../lib/queries";

const route = getRouteBySlug("panorama-visual-de-la-biblia");

if (!route) {
  throw new Error("No se encontró la ruta Panorama Visual de la Biblia.");
}

const lessons = getLessonsByRouteId(route.id);
---

<BaseLayout
  title={route.title}
  description={route.description ?? "Ruta guiada para estudiar la Biblia visualmente."}
>
  <main class="page">
    <div class="breadcrumb">
      <a href="/">Inicio</a> → Rutas → {route.title}
    </div>

    <section class="hero">
      <p class="eyebrow">Ruta principal · {lessons.length} lecciones</p>

      <h1>{route.title}</h1>

      <p class="subtitle">
        {route.description}
      </p>

      <div class="actions">
        <a href="/lecciones/la-biblia-como-una-sola-historia/" class="button">
          Empezar lección 1
        </a>
      </div>
    </section>

    <section class="grid">
      <article class="card">
        <h2>Nivel</h2>
        <p>{route.level}</p>
      </article>

      <article class="card">
        <h2>Duración</h2>
        <p>{route.estimated_duration}</p>
      </article>

      <article class="card">
        <h2>Estado</h2>
        <p>{route.status}</p>
      </article>
    </section>

    <section class="section">
      <h2>Lecciones de la ruta</h2>

      <ol class="list">
        {lessons.map((lesson) => (
          <li>
            {lesson.status !== "Borrador" ? (
              <a href={`/lecciones/${lesson.slug}/`}>
                {lesson.title}
              </a>
            ) : (
              <span>{lesson.title} · próximamente</span>
            )}
          </li>
        ))}
      </ol>
    </section>
  </main>
</BaseLayout>