---
import { sitePath } from "../../lib/site-paths";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAllTopics,
  getTopicBySlug,
  type Topic,
} from "../../lib/queries";

type Props = {
  topic: Topic;
};

export function getStaticPaths() {
  const topics = getAllTopics();

  return topics
    .filter((topic) => topic.status !== "Borrador")
    .map((topic) => ({
      params: { slug: topic.slug },
      props: { topic },
    }));
}

const { topic } = Astro.props;
---

<BaseLayout
  title={topic.title}
  description={topic.definition ?? "Tema de la Enciclopedia Bíblica Visual."}
>
  <main class="page">
    <div class="breadcrumb">
      <a href={sitePath("/")}>Inicio</a> → Temas → {topic.title}
    </div>

    <section class="hero">
      <p class="eyebrow">Tema bíblico</p>

      <h1>{topic.title}</h1>

      {topic.definition && (
        <p class="subtitle">
          {topic.definition}
        </p>
      )}
    </section>

    <section class="section">
      <h2>Definición simple</h2>

      <div class="content">
        <p>{topic.definition ?? "Definición pendiente."}</p>
      </div>
    </section>

    <section class="section">
      <h2>Estado del contenido</h2>

      <div class="content">
        <p>{topic.status}</p>
      </div>
    </section>
  </main>
</BaseLayout>