---
import { sitePath } from "../../lib/site-paths";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAllPassages,
  getBibleVersionById,
  getBibleVersesByPassageId,
  getEventsByPassageId,
  getLessonsByPassageId,
  type BibleVerse,
  type Event,
  type Lesson,
  type Passage,
} from "../../lib/queries";

type Props = {
  passage: Passage;
  lessons: Lesson[];
  events: Event[];
  verses: BibleVerse[];
};

export function getStaticPaths() {
  const passages = getAllPassages();

  return passages
    .filter((passage) => passage.status !== "Borrador")
    .map((passage) => ({
      params: { slug: passage.slug },
      props: {
        passage,
        lessons: getLessonsByPassageId(passage.id),
        events: getEventsByPassageId(passage.id),
        verses: getBibleVersesByPassageId(passage.id),
      },
    }));
}

const { passage, lessons, events, verses } = Astro.props;

const version = getBibleVersionById("rvr1960");

const versesByChapter = verses.reduce<Record<number, BibleVerse[]>>(
  (groups, verse) => {
    if (!groups[verse.chapter_number]) {
      groups[verse.chapter_number] = [];
    }

    groups[verse.chapter_number].push(verse);

    return groups;
  },
  {}
);

const chapterNumbers = Object.keys(versesByChapter)
  .map(Number)
  .sort((a, b) => a - b);
---

<BaseLayout
  title={passage.display_reference}
  description={passage.summary ?? "Pasaje bíblico de la Enciclopedia Bíblica Visual."}
>
  <main class="page">
    <div class="breadcrumb">
      <a href={sitePath("/")}>Inicio</a> →
      <a href={sitePath("/pasajes/")}>Pasajes</a> →
      {passage.display_reference}
    </div>

    <section class="hero">
      <p class="eyebrow">
        Pasaje bíblico · {passage.book_name} · {version?.abbreviation ?? "RVR1960"}
      </p>

      <h1>{passage.display_reference}</h1>

      {passage.summary && (
        <p class="subtitle">
          {passage.summary}
        </p>
      )}

      <div class="actions">
        <a href={sitePath(`/libros/${passage.book_slug}/`)} class="button secondary">
          Ver ficha del libro
        </a>

        <a href={sitePath(`/biblia/${passage.book_slug}/${passage.start_chapter}/`)} class="button secondary">
          Leer capítulo
        </a>
      </div>
    </section>

    <section class="grid">
      <article class="card">
        <h2>Libro</h2>
        <p>{passage.book_name}</p>
      </article>

      <article class="card">
        <h2>Inicio</h2>
        <p>
          Capítulo {passage.start_chapter}
          {passage.start_verse ? `:${passage.start_verse}` : ""}
        </p>
      </article>

      <article class="card">
        <h2>Fin</h2>
        <p>
          Capítulo {passage.end_chapter}
          {passage.end_verse ? `:${passage.end_verse}` : ""}
        </p>
      </article>
    </section>

    <section class="section">
      <h2>Texto bíblico</h2>

      {verses.length > 0 ? (
        <div class="passage-reader">
          {chapterNumbers.map((chapterNumber) => (
            <section class="passage-chapter">
              {chapterNumbers.length > 1 && (
                <h3>{passage.book_name} {chapterNumber}</h3>
              )}

              <div class="bible-reader">
                {versesByChapter[chapterNumber].map((verse) => (
                  <article class="verse" id={`v${verse.verse_number}`}>
                    <span class="verse-number">
                      <a
                        href={sitePath(`/biblia/${passage.book_slug}/${verse.chapter_number}/#v${verse.verse_number}`)}
                        class="verse-ref-link"
                      >
                        {verse.verse_number}
                      </a>
                    </span>

                    <p class="verse-text">{verse.verse_text}</p>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>
      ) : (
        <div class="content">
          <p>
            Todavía no hay texto bíblico importado para este pasaje. Cuando ejecutes
            el importador con el CSV autorizado de RVR1960, el texto aparecerá aquí.
          </p>
        </div>
      )}
    </section>

    <section class="section">
      <h2>Resumen del pasaje</h2>

      <div class="content">
        <p>{passage.summary ?? "Resumen pendiente."}</p>
      </div>
    </section>

    {lessons.length > 0 && (
      <section class="section">
        <h2>Lecciones relacionadas</h2>

        <ul class="pill-list">
          {lessons.map((lesson) => (
            <li>
              <a href={sitePath(`/lecciones/${lesson.slug}/`)}>{lesson.title}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {events.length > 0 && (
      <section class="section">
        <h2>Eventos relacionados</h2>

        <div class="entity-list">
          {events.map((event) => (
            <a href={sitePath(`/eventos/${event.slug}/`)} class="entity-card">
              <span class="meta">{event.biblical_period ?? "Evento"}</span>
              <h2>{event.title}</h2>
              <p>{event.summary ?? "Resumen pendiente."}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    {version?.copyright_notice && (
      <section class="copyright-box">
        {version.copyright_notice}
      </section>
    )}

    <section class="section">
      <a href={sitePath("/pasajes/")} class="button secondary">
        Volver a pasajes
      </a>
    </section>
  </main>
</BaseLayout>